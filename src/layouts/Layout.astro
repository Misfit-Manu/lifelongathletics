---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
  description?: string;
}

const { title = "Lifelong Athletics — Become a Lifelong Athlete", description = "Rebuild Habits for Life. Not for a season. Lifelong Athletics coaching by Manu." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet"/>
		<title>{title}</title>
	</head>
	<body>
    <Nav />
		<slot />
    <Footer />
	</body>
</html>

<style is:global>
  :root {
    --black: #080808;
    --surface: #111111;
    --surface2: #181818;
    --border: rgba(255,255,255,0.08);
    --gold: #c9a84c;
    --gold-dim: rgba(201,168,76,0.15);
    --white: #f5f0e8;
    --muted: rgba(245,240,232,0.45);
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'DM Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ─── GRAIN OVERLAY ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 60px;
    background: linear-gradient(to bottom, rgba(8,8,8,0.95), transparent);
    transition: background 0.3s;
  }
  nav.scrolled {
    background: rgba(8,8,8,0.97);
    border-bottom: 1px solid var(--border);
    padding: 16px 60px;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-cta {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold) !important;
    border: 1px solid var(--gold);
    padding: 10px 24px;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s !important;
  }
  .nav-cta:hover { background: var(--gold) !important; color: var(--black) !important; }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 40px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 80%, rgba(201,168,76,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 80% 60% at 50% 100%, rgba(201,168,76,0.04) 0%, transparent 60%);
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.5s forwards;
  }
  h1 em {
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
  }
  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 300;
    font-style: italic;
    color: var(--muted);
    margin-bottom: 56px;
    max-width: 560px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.7s forwards;
  }
  .hero-actions {
    display: flex;
    gap: 20px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.9s forwards;
  }
  .btn-primary {
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 16px 40px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }

  /* ─── SECTIONS ─── */
  section { padding: 120px 60px; }
  .container { max-width: 1100px; margin: 0 auto; }

  .section-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 24px;
  }
  h2 em { font-style: italic; color: var(--gold); }
  .section-body {
    font-size: 1rem;
    color: var(--muted);
    max-width: 540px;
    line-height: 1.8;
  }

  /* ─── WHO IS THIS FOR ─── */
  #who {
    background: var(--black);
  }
  .who-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 80px;
  }
  .persona-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }
  .persona-card {
    background: var(--surface);
    padding: 48px 40px;
    cursor: default;
    transition: background 0.3s;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease, background 0.3s;
    position: relative;
    overflow: hidden;
  }
  .persona-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.4s ease;
    transform-origin: left;
  }
  .persona-card:hover::before { transform: scaleX(1); }
  .persona-card:hover { background: var(--surface2); }
  .persona-card.visible { opacity: 1; transform: translateY(0); }
  .persona-num {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    margin-bottom: 24px;
    display: block;
  }
  .persona-title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .persona-label {
    font-size: 0.75rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 20px;
    font-style: italic;
  }
  .persona-problem {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .persona-promise {
    font-size: 0.85rem;
    color: var(--white);
    line-height: 1.7;
  }
  .persona-visual {
    width: 100%;
    height: 140px;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: rgba(201,168,76,0.04);
    border: 1px solid rgba(201,168,76,0.1);
  }
  .pillar-visual {
    width: 56px;
    height: 56px;
    margin-bottom: 20px;
  }

  /* ─── METHOD ─── */
  #method {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }
  .method-layout {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 100px;
    align-items: start;
  }
  .method-sticky { position: sticky; top: 120px; }
  .pillar {
    padding: 48px 0;
    border-bottom: 1px solid var(--border);
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .pillar:first-child { border-top: 1px solid var(--border); }
  .pillar.visible { opacity: 1; transform: translateX(0); }
  .pillar-num {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.7;
    line-height: 1;
    margin-bottom: 16px;
  }
  .pillar-title {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .pillar-body {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.8;
  }

  /* ─── ABOUT ─── */
  #about {
    background: var(--black);
    border-top: 1px solid var(--border);
  }
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
  }
  .about-credentials {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 48px;
  }
  .cred-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--surface);
    border-left: 2px solid var(--gold);
    font-size: 0.85rem;
    color: var(--white);
  }
  .cred-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }
  .cred-badge {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.4);
    padding: 3px 10px;
    border-radius: 2px;
    margin-left: auto;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .about-quote {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.3;
    color: var(--white);
  }
  .about-quote em {
    font-style: normal;
    color: var(--gold);
    display: block;
    font-size: 0.5em;
    font-family: var(--font-body);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 24px;
  }
  .differentiator-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    margin-top: 60px;
  }
  .diff-item {
    background: var(--surface);
    padding: 28px 32px;
    border-top: 1px solid var(--border);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .diff-item.visible { opacity: 1; transform: translateY(0); }
  .diff-icon {
    width: 36px; height: 36px;
    margin-bottom: 16px;
  }
  .diff-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .diff-body {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
  }
  .service-card {
    background: var(--surface2);
    padding: 36px 32px;
    transition: background 0.3s;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s;
  }
  .service-card:hover { background: #1f1f1f; }
  .service-card.visible { opacity: 1; transform: translateY(0); }
  .service-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--white);
  }
  .service-body {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ─── CTA ─── */
  #apply {
    background: var(--surface);
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .cta-wrap {
    max-width: 700px;
    margin: 0 auto;
  }
  .cta-divider {
    width: 60px;
    height: 1px;
    background: var(--gold);
    margin: 0 auto 48px;
  }
  .apply-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 48px;
    text-align: left;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-field.full { grid-column: 1 / -1; }
  .form-field label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .form-field input,
  .form-field select,
  .form-field textarea {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 14px 18px;
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-color: var(--gold);
  }
  .form-field select option { background: var(--surface2); }
  .form-field textarea { resize: vertical; min-height: 100px; }
  .form-submit {
    grid-column: 1 / -1;
    margin-top: 8px;
  }
  .btn-full {
    width: 100%;
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 18px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-full:hover { opacity: 0.88; }

  /* ─── FOOTER ─── */
  footer {
    padding: 40px 60px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .footer-logo span { color: var(--gold); }
  .footer-copy {
    font-size: 0.75rem;
    color: var(--muted);
  }
  .footer-links {
    display: flex;
    gap: 28px;
  }
  .footer-links a {
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--white); }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    nav { padding: 20px 24px; }
    nav.scrolled { padding: 14px 24px; }
    .nav-links { display: none; }
    section { padding: 80px 24px; }
    #problem { padding: 60px 24px; }
    .stats-row { grid-template-columns: 1fr; }
    .stat-item { border-right: none; border-bottom: 1px solid var(--border); padding: 36px 24px; }
    .stat-item:last-child { border-bottom: none; }
    .who-header { grid-template-columns: 1fr; gap: 32px; }
    .persona-grid { grid-template-columns: 1fr; }
    #who .trust-strip { grid-template-columns: 1fr 1fr !important; }
    #longevity { padding: 80px 24px !important; }
    #longevity > .container > div:first-child { grid-template-columns: 1fr !important; gap: 48px !important; }
    #longevity > .container > div:nth-child(2) { grid-template-columns: 1fr 1fr !important; }
    #services { padding: 80px 24px !important; }
    #services > .container > div:first-child { grid-template-columns: 1fr !important; gap: 32px !important; }
    #services > .container > div:last-child { grid-template-columns: 1fr 1fr !important; }
    .method-layout { grid-template-columns: 1fr; gap: 40px; }
    .method-sticky { position: static; }
    .about-layout { grid-template-columns: 1fr; gap: 48px; }
    .differentiator-grid { grid-template-columns: 1fr; }
    .apply-form { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 20px; text-align: center; padding: 32px 24px; }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
