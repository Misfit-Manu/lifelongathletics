---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
  description?: string;
}

const { title = "Lifelong Athletics — Become a Lifelong Athlete", description = "Rebuild Habits for Life. Not for a season. Lifelong Athletics coaching by Manu." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;700&display=swap" rel="stylesheet"/>
		<title>{title}</title>
	</head>
	<body>
    <Nav />
		<slot />
    <Footer />
    
    <!-- Floating WhatsApp -->
    <a href="https://wa.me/917696483445" class="floating-wa" target="_blank" rel="noopener noreferrer" aria-label="Chat on WhatsApp">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.487-1.761-1.66-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
    </a>
	</body>
</html>

<style is:global>
  :root {
    --black: #080808;
    --surface: #111111;
    --surface2: #181818;
    --border: rgba(255,255,255,0.08);
    --gold: #c9a84c;
    --gold-dim: rgba(201,168,76,0.15);
    --white: #f5f0e8;
    --muted: rgba(245,240,232,0.45);
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'DM Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: var(--font-body);
    font-weight: 300;
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ─── GRAIN OVERLAY ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 60px;
    background: linear-gradient(to bottom, rgba(8,8,8,0.95), transparent);
    transition: background 0.3s;
  }
  nav.scrolled {
    background: rgba(8,8,8,0.97);
    border-bottom: 1px solid var(--border);
    padding: 16px 60px;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-cta {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold) !important;
    border: 1px solid var(--gold);
    padding: 10px 24px;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s !important;
  }
  .nav-cta:hover { background: var(--gold) !important; color: var(--black) !important; }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 40px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 80%, rgba(201,168,76,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 80% 60% at 50% 100%, rgba(201,168,76,0.04) 0%, transparent 60%);
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.5s forwards;
  }
  h1 em {
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
  }
  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 300;
    font-style: italic;
    color: var(--muted);
    margin-bottom: 56px;
    max-width: 560px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.7s forwards;
  }
  .hero-actions {
    display: flex;
    gap: 20px;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.9s forwards;
  }
  .btn-primary {
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 16px 40px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }

  /* ─── HERO 2-COL LAYOUT ─── */
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    max-width: 1100px;
    width: 100%;
    position: relative;
    z-index: 1;
  }
  .hero-text { text-align: left; }
  .hero-actions {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  .hero-photo { display: flex; align-items: center; justify-content: center; }
  .hero-art-frame {
    width: 100%;
    height: 480px;
    background: #080808;
    border: 1px solid var(--border);
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }
  .hero-art-frame::after {
    /* Subtle vignette for editorial depth */
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 80% 70% at 50% 50%, transparent 55%, rgba(8,8,8,0.55) 100%);
    z-index: 2;
  }
  #hero-art {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
    z-index: 1;
  }

  /* ─── SECTIONS ─── */
  section { padding: 120px 60px; }
  .container { max-width: 1100px; margin: 0 auto; }

  .section-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }
  h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 24px;
  }
  h2 em { font-style: italic; color: var(--gold); }
  .section-body {
    font-size: 1rem;
    color: var(--muted);
    max-width: 540px;
    line-height: 1.8;
  }

  /* ─── WHO IS THIS FOR ─── */
  #who {
    background: var(--black);
  }
  .who-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 80px;
  }
  .persona-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }
  .persona-card {
    background: var(--surface);
    padding: 48px 40px;
    cursor: default;
    transition: background 0.3s;
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease, background 0.3s;
    position: relative;
    overflow: hidden;
  }
  .persona-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.4s ease;
    transform-origin: left;
  }
  .persona-card:hover::before { transform: scaleX(1); }
  .persona-card:hover { background: var(--surface2); }
  .persona-card.visible { opacity: 1; transform: translateY(0); }
  .persona-num {
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    margin-bottom: 24px;
    display: block;
  }
  .persona-title {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .persona-label {
    font-size: 0.75rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 20px;
    font-style: italic;
  }
  .persona-problem {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 24px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .persona-promise {
    font-size: 0.85rem;
    color: var(--white);
    line-height: 1.7;
  }
  .persona-visual {
    width: 100%;
    height: 140px;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: rgba(201,168,76,0.04);
    border: 1px solid rgba(201,168,76,0.1);
  }
  .pillar-visual {
    width: 56px;
    height: 56px;
    margin-bottom: 20px;
  }

  /* ─── METHOD ─── */
  #method {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }
  .method-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border);
  }
  .method-card {
    background: var(--surface2);
    padding: 48px 40px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .method-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.4s ease;
    transform-origin: left;
  }
  .method-card:hover::before { transform: scaleX(1); }
  .method-card:hover { background: #1a1a1a; }
  .method-icon {
    width: 52px;
    height: 52px;
    margin-bottom: 24px;
  }
  .method-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.6;
    line-height: 1;
    margin-bottom: 12px;
  }
  .method-card-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .method-card-body {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.75;
  }

  /* ─── ABOUT ─── */
  #about {
    background: var(--black);
    border-top: 1px solid var(--border);
  }
  .about-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
  }
  .about-credentials {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 48px;
  }
  .cred-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--surface);
    border-left: 2px solid var(--gold);
    font-size: 0.85rem;
    color: var(--white);
  }
  .cred-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }
  .cred-badge {
    display: inline-block;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.4);
    padding: 3px 10px;
    border-radius: 2px;
    margin-left: auto;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .about-quote {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.3;
    color: var(--white);
  }
  .about-quote em {
    font-style: normal;
    color: var(--gold);
    display: block;
    font-size: 0.5em;
    font-family: var(--font-body);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 24px;
  }
  .differentiator-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    margin-top: 60px;
  }
  .diff-item {
    background: var(--surface);
    padding: 28px 32px;
    border-top: 1px solid var(--border);
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .diff-item.visible { opacity: 1; transform: translateY(0); }
  .diff-icon {
    width: 36px; height: 36px;
    margin-bottom: 16px;
  }
  .diff-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .diff-body {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ─── TESTIMONIALS ─── */
  #testimonials {
    background: var(--black);
    border-top: 1px solid var(--border);
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border);
  }
  .testimonial-card {
    background: var(--surface);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 32px;
  }
  .testimonial-quote {
    font-family: var(--font-display);
    font-size: 4rem;
    line-height: 0.8;
    color: var(--gold);
    margin-bottom: 12px;
    opacity: 0.7;
  }
  .testimonial-text {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 300;
    font-style: italic;
    line-height: 1.75;
    color: var(--white);
  }
  .testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
  .testimonial-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--white);
  }
  .testimonial-meta {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .service-card {
    background: var(--surface2);
    padding: 36px 32px;
    transition: background 0.3s;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s;
  }
  .service-card:hover { background: #1f1f1f; }
  .service-card.visible { opacity: 1; transform: translateY(0); }
  .service-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 10px;
    color: var(--white);
  }
  .service-body {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ─── CTA ─── */
  #apply {
    background: var(--surface);
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .cta-wrap {
    max-width: 700px;
    margin: 0 auto;
  }
  .cta-divider {
    width: 60px;
    height: 1px;
    background: var(--gold);
    margin: 0 auto 48px;
  }
  .apply-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 48px;
    text-align: left;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .form-field.full { grid-column: 1 / -1; }
  .form-field label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .form-field input,
  .form-field select,
  .form-field textarea {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 14px 18px;
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    border-color: var(--gold);
  }
  .form-field select option { background: var(--surface2); }
  .form-field textarea { resize: vertical; min-height: 100px; }
  .form-submit {
    grid-column: 1 / -1;
    margin-top: 8px;
  }
  .btn-full {
    width: 100%;
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 18px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .btn-full:hover { opacity: 0.88; }

  /* ─── FOOTER ─── */
  footer {
    padding: 40px 60px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .footer-logo span { color: var(--gold); }
  .footer-copy {
    font-size: 0.75rem;
    color: var(--muted);
  }
  .footer-links {
    display: flex;
    gap: 28px;
  }
  .footer-links a {
    font-size: 0.75rem;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--white); }

  /* ─── SERVICE GRID + TRUST STRIP ─── */
  .service-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
  }
  .trust-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    margin-top: 2px;
  }

  /* ─── ANIMATIONS ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── TABLET ─── */
  @media (max-width: 1024px) {
    section { padding: 100px 40px; }
    .hero-inner { gap: 48px; }
    .service-grid { grid-template-columns: repeat(2, 1fr); }
    .trust-strip { grid-template-columns: repeat(2, 1fr); }
    .persona-grid { grid-template-columns: repeat(2, 1fr); }
    .who-header { gap: 48px; }
    .method-cards { grid-template-columns: 1fr; }
    .testimonials-grid { grid-template-columns: 1fr 1fr; }
    .about-layout { gap: 60px; }
  }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    nav { padding: 20px 24px; }
    nav.scrolled { padding: 14px 24px; }
    .nav-links { display: none; }
    section { padding: 80px 24px; }
    #hero { padding: 90px 24px 60px; }
    #problem { padding: 60px 24px; }
    .hero-inner { grid-template-columns: 1fr; gap: 0; }
