---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="The Complete Guide to Muscular Training | Lifelong Athletics" description="Physiology, fibre types, hypertrophy, training principles, and program design — the science of how muscles grow.">

<style is:global>
  :root {
    --navy: #0a0f1e;
    --navy2: #111827;
    --panel: #1a2540;
    --blue: #3a86ff;
    --purple: #7b2d8b;
    --gold: #f5a623;
    --green: #06d6a0;
    --red: #ef233c;
    --white: #ffffff;
    --offwhite: #e8edf4;
    --muted: #8899bb;
    --border: #1e3a5f;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--navy2);
    color: var(--offwhite);
    line-height: 1.75;
  }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, #060b18 0%, #0d1b3e 50%, #1a0a2e 100%);
    padding: 100px 24px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid var(--blue);
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(58,134,255,0.12) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 30%, rgba(123,45,139,0.10) 0%, transparent 60%);
  }
  .hero-tag {
    display: inline-block;
    background: rgba(58,134,255,0.15);
    border: 1px solid rgba(58,134,255,0.4);
    color: var(--blue);
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 6px 18px;
    border-radius: 100px;
    margin-bottom: 28px;
    position: relative;
  }
  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.1;
    max-width: 800px;
    margin: 0 auto 24px;
    position: relative;
  }
  .hero h1 span { color: var(--blue); }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 600px;
    margin: 0 auto 40px;
    position: relative;
  }
  .hero-meta {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    position: relative;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .hero-meta span { display: flex; align-items: center; gap: 6px; }
  .hero-meta strong { color: var(--gold); }

  /* ── STAT STRIP ── */
  .stat-strip {
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    padding: 32px 24px;
  }
  .stat-grid {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 24px;
    text-align: center;
  }
  .stat-item { padding: 12px; }
  .stat-num {
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-label { font-size: 0.82rem; color: var(--muted); }

  /* ── LAYOUT ── */
  .wrapper { max-width: 860px; margin: 0 auto; padding: 0 24px; }
  .content-body { padding: 72px 24px; }

  /* ── TOC ── */
  .toc {
    background: var(--panel);
    border: 1px solid var(--border);
    border-left: 4px solid var(--blue);
    border-radius: 12px;
    padding: 32px 36px;
    margin: 0 auto 72px;
    max-width: 860px;
  }
  .toc h3 {
    font-size: 0.75rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 20px;
  }
  .toc ol {
    list-style: none;
    counter-reset: toc-counter;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 32px;
  }
  .toc li { counter-increment: toc-counter; }
  .toc li a {
    color: var(--offwhite);
    text-decoration: none;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 4px 0;
    transition: color 0.2s;
  }
  .toc li a::before {
    content: counter(toc-counter, decimal-leading-zero);
    font-size: 0.72rem;
    color: var(--blue);
    font-weight: 700;
    min-width: 24px;
  }
  .toc li a:hover { color: var(--blue); }

  /* ── SECTIONS ── */
  .section { margin-bottom: 80px; }
  h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    color: var(--white);
    margin-bottom: 8px;
    scroll-margin-top: 80px;
  }
  .section-rule {
    width: 48px;
    height: 4px;
    border-radius: 2px;
    margin-bottom: 28px;
  }
  h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--white);
    margin: 32px 0 12px;
  }
  p { margin-bottom: 20px; color: var(--offwhite); font-size: 1.0rem; }

  /* ── CALLOUTS ── */
  .callout {
    border-radius: 12px;
    padding: 24px 28px;
    margin: 32px 0;
    border-left: 5px solid;
    position: relative;
  }
  .callout-icon {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 1px;
    margin-bottom: 8px;
    display: block;
  }
  .callout p:last-child { margin-bottom: 0; }
  .callout-key {
    background: rgba(58,134,255,0.08);
    border-color: var(--blue);
  }
  .callout-key .callout-icon { color: var(--blue); }
  .callout-science {
    background: rgba(123,45,139,0.12);
    border-color: var(--purple);
  }
  .callout-science .callout-icon { color: #c084fc; }
  .callout-warning {
    background: rgba(239,35,60,0.08);
    border-color: var(--red);
  }
  .callout-warning .callout-icon { color: var(--red); }
  .callout-tip {
    background: rgba(6,214,160,0.08);
    border-color: var(--green);
  }
  .callout-tip .callout-icon { color: var(--green); }
  .callout-gold {
    background: rgba(245,166,35,0.08);
    border-color: var(--gold);
  }
  .callout-gold .callout-icon { color: var(--gold); }

  /* ── STAT CARDS ── */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 20px;
    margin: 36px 0;
  }
  .stat-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px 20px;
    text-align: center;
  }
  .stat-card .big-num {
    font-size: 2.2rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 8px;
  }
  .stat-card p { font-size: 0.85rem; color: var(--muted); margin: 0; }

  /* ── FORMULA BOX ── */
  .formula-box {
    background: #060b18;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 32px;
    margin: 32px 0;
    text-align: center;
    font-family: 'Courier New', monospace;
  }
  .formula-text {
    font-size: 1.4rem;
    color: var(--gold);
    font-weight: 700;
    letter-spacing: 1px;
  }
  .formula-desc { font-size: 0.85rem; color: var(--muted); margin-top: 10px; font-family: inherit; }

  /* ── COMPARISON TABLE ── */
  .data-table { width: 100%; border-collapse: collapse; margin: 32px 0; font-size: 0.9rem; }
  .data-table thead tr { background: var(--blue); }
  .data-table thead th {
    color: var(--white);
    padding: 14px 16px;
    text-align: left;
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.5px;
  }
  .data-table tbody tr:nth-child(even) { background: rgba(26,37,64,0.6); }
  .data-table tbody tr:hover { background: rgba(58,134,255,0.08); }
  .data-table td { padding: 12px 16px; color: var(--offwhite); border-bottom: 1px solid var(--border); vertical-align: top; }
  .data-table td:first-child { font-weight: 600; color: var(--white); }

  /* ── FIBER CARDS ── */
  .fiber-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
    margin: 32px 0;
  }
  .fiber-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    border-top: 4px solid;
  }
  .fiber-card h4 {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--white);
  }
  .fiber-prop { margin-bottom: 6px; font-size: 0.88rem; }
  .fiber-prop strong { color: var(--gold); margin-right: 6px; }

  /* ── PRINCIPLE STEPS ── */
  .principle-steps { margin: 32px 0; }
  .step {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
    align-items: flex-start;
  }
  .step-num {
    min-width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 900;
    flex-shrink: 0;
  }
  .step-body h4 { font-size: 1rem; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .step-body p { font-size: 0.9rem; color: var(--muted); margin: 0; }

  /* ── IMAGE PLACEHOLDER ── */
  .img-placeholder {
    background: var(--panel);
    border: 2px dashed var(--border);
    border-radius: 12px;
    padding: 56px 24px;
    text-align: center;
    margin: 36px 0;
    color: var(--muted);
    font-size: 0.85rem;
  }
  .img-placeholder .img-icon { font-size: 2.5rem; margin-bottom: 12px; opacity: 0.5; }

  /* ── KINETIC CHAIN ── */
  .kinetic-chain {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: 32px auto;
    max-width: 460px;
  }
  .kc-row {
    display: flex;
    border-radius: 8px;
    overflow: hidden;
    font-size: 0.88rem;
    font-weight: 600;
  }
  .kc-joint {
    flex: 1;
    padding: 10px 14px;
    background: var(--panel);
    color: var(--white);
  }
  .kc-type {
    width: 130px;
    padding: 10px 14px;
    text-align: center;
    font-weight: 800;
    letter-spacing: 1px;
    font-size: 0.78rem;
  }
  .kc-mobility { background: rgba(58,134,255,0.25); color: var(--blue); }
  .kc-stability { background: rgba(6,214,160,0.15); color: var(--green); }

  /* ── TRAINING TABLE ── */
  .training-goal-row {
    display: flex;
    align-items: center;
    padding: 14px 16px;
    border-radius: 8px;
    margin-bottom: 8px;
    gap: 16px;
    background: var(--panel);
    border-left: 5px solid;
  }
  .tg-name { font-weight: 700; min-width: 200px; font-size: 0.95rem; }
  .tg-detail { font-size: 0.85rem; color: var(--muted); flex: 1; }
  .tg-badge {
    font-size: 0.78rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 100px;
    white-space: nowrap;
  }

  /* ── TAKEAWAYS ── */
  .takeaways {
    background: linear-gradient(135deg, #060b18, #0d1b3e);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    margin: 72px 0 0;
  }
  .takeaways h2 { color: var(--white); margin-bottom: 8px; }
  .takeaways-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 32px;
  }
  .takeaway-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .ta-num {
    min-width: 36px;
    height: 36px;
    background: var(--blue);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 0.9rem;
    color: var(--white);
    flex-shrink: 0;
  }
  .ta-text { font-size: 0.9rem; color: var(--offwhite); padding-top: 6px; }

  /* ── NAV ── */
  .site-nav {
    background: rgba(10,15,30,0.95);
    backdrop-filter: blur(10px);
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .nav-brand { font-weight: 900; font-size: 1rem; color: var(--white); letter-spacing: 0.5px; }
  .nav-brand span { color: var(--blue); }
  .nav-chapter { font-size: 0.8rem; color: var(--muted); }

  /* ── FOOTER ── */
  .footer {
    background: var(--navy);
    border-top: 1px solid var(--border);
    padding: 40px 24px;
    text-align: center;
    font-size: 0.82rem;
    color: var(--muted);
  }
  .footer strong { color: var(--blue); }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .toc ol { grid-template-columns: 1fr; }
    .takeaways-grid { grid-template-columns: 1fr; }
    .takeaways { padding: 32px 24px; }
    .stat-grid { grid-template-columns: repeat(2, 1fr); }
  }

/* === Site-integration fixes (theme preserved) === */
.blog-container { padding: 100px 24px 140px !important; }
@media (max-width: 600px) { .blog-container { padding: 90px 16px 120px !important; } }
h2[id], .section[id], .hero, .takeaways, section[id] { scroll-margin-top: 90px; }

/* Hide source-internal nav + TOC (site Nav provided by Layout) */
.site-nav, .sticky-nav, .toc, .toc-wrap { display: none !important; }

/* Cross-link banner — neutral, sits within source palette */
.crosslink-bottom { background: rgba(255,255,255,0.03); border: 1px solid #1e3a5f; border-left: 4px solid #f5a623; border-radius: 12px; padding: 32px 36px; margin: 56px auto 0; max-width: 860px; text-align: center; }
.crosslink-bottom h3 { color: #f5a623; font-size: 1.2rem; font-weight: 700; margin: 0 0 8px; }
.crosslink-bottom p { color: #8899bb; font-size: 14px; margin: 0 0 18px; line-height: 1.6; }
.crosslink-bottom a { display: inline-block; background: #f5a623; color: #0a0f1e; padding: 12px 28px; border-radius: 24px; font-size: 14px; font-weight: 700; text-decoration: none; transition: background 0.2s, transform 0.2s; }
.crosslink-bottom a:hover { background: #fbbf24; transform: translateY(-2px); }
@media (max-width: 600px) { .crosslink-bottom { padding: 24px 20px; } .crosslink-bottom h3 { font-size: 1.05rem; } }
</style>

