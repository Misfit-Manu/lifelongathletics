3) Design her 8-week Base Training cardiorespiratory program alongside the sedentary protocol.
4) At 8-week reassessment, which 5 metabolic outcome metrics would indicate success BEYOND weight loss?`,
    answer:`1) ANSWERING PRIYA'S QUESTION:
"No — 30 min of exercise alone is insufficient if you sit for the remaining 23.5 hours."

KEY EVIDENCE:
• Healy et al. (2008): Total sedentary time linked to metabolic syndrome INDEPENDENT of structured exercise
• Keeling, Buchanan & Dalleck (2018): Breaks every 60–120 min = significantly reduced metabolic risk
• Mechanism: Frequent movement prevents post-meal glucose spikes, improves insulin sensitivity
• COMBINED approach: Structured exercise improves VO₂max; sedentary breaks improve glucose/lipids
→ Priya needs BOTH simultaneously; one without the other leaves half the problem unsolved

2) FITT FOR SEDENTARY TIME REDUCTION (WORKDAY PROTOCOL):
• Frequency: Break every 60–120 minutes (set reminders: 10 AM, 12 PM, 2 PM, 4 PM)
• Intensity: Light activity = <25% VO₂max, <3 METs (walking, standing — NOT hard exercise)
• Time: Each break 5–10 minutes (total 25–35 min accumulated light activity/day)
• Type:
  → 10 AM: 5 min stair walk or hallway laps
  → 12 PM: 10 min post-lunch walk (glucose stabilization after meal)
  → 2 PM: 5 min desk stretching (combat afternoon fatigue)
  → 4 PM: 5–10 min walk before evening commute
  → Environment: Position laptop at standing height; walk to colleagues vs. email

3) BASE TRAINING (8 WEEKS alongside sedentary protocol):
• Frequency: 3 days/week (Mon/Wed/Fri)
• Intensity: Zone 1 (estimate HR <105 bpm for age 55; RPE 3–4; 'talk comfortably')
• Time: Wks 1–2: 15 min; Wks 3–4: 20 min; Wks 5–6: 25 min; Wks 7–8: 30 min
• Type: Brisk walking or stationary cycling (low impact, appropriate for BMI 29)
• Pattern: Morning before work OR lunch (avoids post-work fatigue excuse)
• Note: No talk test assessment needed at Base phase

4) METABOLIC SUCCESS METRICS AT 8 WEEKS (beyond weight):
✓ Fasting glucose: Target reduction 5–10 mg/dL toward <100 mg/dL (improved insulin sensitivity)
✓ Blood pressure: Target ≥5 mmHg systolic reduction (cardio training + weight loss effect)
✓ HDL cholesterol: Target 3–5 mg/dL increase (aerobic training raises HDL)
✓ Resting heart rate: Target 5–10 bpm reduction (aerobic adaptation = more efficient heart)
✓ Waist circumference: Target 1–2 inch reduction (visceral fat = metabolic syndrome driver, more predictive than BMI)
BONUS: Exercise capacity (talk test): Sustain 25–30 min zone 1 comfortably = fitness improvement confirmed`
  }
];

let mcqAnswers=new Array(MCQ.length).fill(null);
let fiAnswers=new Array(FILLIN.length).fill('');
let tfAnswers=new Array(TF.length).fill(null);
let submitted=false;

function switchTab(id,btn){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  btn.classList.add('active');
}

function buildMindmap(){
  const grid=document.getElementById('mm-grid');
  grid.innerHTML=MINDMAP.branches.map((b,i)=>`
    <div class="mm-branch" id="mmb-${i}" onclick="toggleBranch(${i})">
      <div class="mm-branch-header">
        <div class="mm-branch-dot" style="background:${b.color}"></div>
        <div class="mm-branch-name">${b.name}</div>
        <div class="mm-branch-arrow">›</div>
      </div>
      <div class="mm-branch-body">
        <div class="mm-subs">
          ${b.subs.map(s=>`
            <div class="mm-sub">
              <div class="mm-sub-name">${s.name}</div>
              <ul class="mm-sub-points">${s.points.map(p=>`<li>${p}</li>`).join('')}</ul>
            </div>
          `).join('')}
        </div>
      </div>
    </div>
  `).join('');
}

function toggleBranch(i){document.getElementById('mmb-'+i).classList.toggle('open')}

function buildQuiz(){
  document.getElementById('mcq-container').innerHTML=MCQ.map((q,i)=>`
    <div class="q-card" id="mcq-${i}">
      <div class="q-num">Question ${i+1} of 25 — MCQ</div>
      <div class="q-text">${q.q}</div>
      <div class="q-options">
        ${q.opts.map((o,j)=>`
          <div class="q-option" id="mcq-${i}-${j}" onclick="selectMCQ(${i},${j})">
            <div class="opt-letter">${['A','B','C','D'][j]}</div><span>${o}</span>
          </div>`).join('')}
      </div>
      <div class="explanation" id="mcq-exp-${i}">
        <div class="explanation-label">Explanation</div>
        <div class="explanation-text">${q.exp}</div>
      </div>
    </div>`).join('');

  document.getElementById('fillin-container').innerHTML=FILLIN.map((q,i)=>`
    <div class="q-card" id="fi-${i}">
      <div class="q-num">Question ${i+1} of 15 — Fill in the Blank</div>
      <div class="q-text">${q.q}</div>
      <input class="q-input" type="text" placeholder="Type your answer…" oninput="fiAnswers[${i}]=this.value;updateProgress()" id="fi-input-${i}"/>
      <div class="answer-reveal" id="fi-ans-${i}">
        <div class="answer-reveal-label">✓ Correct Answer</div>
        <div class="answer-reveal-text">${q.a}</div>
      </div>
      <div class="explanation" id="fi-exp-${i}">
        <div class="explanation-label">Explanation</div>
        <div class="explanation-text">${q.exp}</div>
      </div>
    </div>`).join('');

  document.getElementById('tf-container').innerHTML=TF.map((q,i)=>`
    <div class="q-card" id="tf-${i}">
      <div class="q-num">Question ${i+1} of 10 — True / False</div>
      <div class="q-text">${q.q}</div>
      <div class="q-tf">
        <button class="q-tf-btn" id="tf-${i}-true" onclick="selectTF(${i},true)">True</button>
        <button class="q-tf-btn" id="tf-${i}-false" onclick="selectTF(${i},false)">False</button>
      </div>
      <div class="explanation" id="tf-exp-${i}">
        <div class="explanation-label">Explanation</div>
        <div class="explanation-text">${q.exp}</div>
      </div>
    </div>`).join('');
}

function buildCases(){
  document.getElementById('cases-container').innerHTML=CASES.map((c,i)=>`
    <div class="case-card">
      <div class="case-header">
        <div class="case-tag">📋 ACE Case Study ${i+1}</div>
        <div class="case-title">${c.title} <em>— ${c.subtitle}</em></div>
      </div>
      <div class="case-body">
        <div class="case-scenario">
          <div class="case-scenario-label">📄 Client Scenario</div>
          <div class="case-scenario-text">${c.scenario}</div>
        </div>
        <div class="case-questions">
          <div class="case-questions-label">❓ Questions to Answer</div>
          <div class="case-questions-text">${c.questions}</div>
        </div>
        <div class="case-answer-area">
          <div class="case-answer-label">Your Answer:</div>
          <textarea class="q-input" rows="8" placeholder="Write your answer here. Apply Chapter 8 concepts specifically to this client scenario…" id="case-input-${i}"></textarea>
        </div>
        <button onclick="toggleModelAnswer(${i})" id="case-btn-${i}" style="margin-top:12px;background:none;border:1px solid var(--border2);color:var(--muted);padding:10px 20px;border-radius:20px;cursor:pointer;font-size:13px;font-family:var(--font-body);transition:var(--trans)" onmouseover="this.style.borderColor='var(--correct)';this.style.color='var(--correct)'" onmouseout="this.style.borderColor='var(--border2)';this.style.color='var(--muted)'">
          👁 Reveal Model Answer
        </button>
        <div class="case-model-answer" id="case-ans-${i}">
          <div class="case-model-label">📘 Model Answer — Chapter 8 Application</div>
          <div class="case-model-text">${c.answer}</div>
        </div>
      </div>
    </div>`).join('');
}

function toggleModelAnswer(i){
  const el=document.getElementById('case-ans-'+i);
  const btn=document.getElementById('case-btn-'+i);
  el.classList.toggle('show');
  btn.textContent=el.classList.contains('show')?'▲ Hide Model Answer':'👁 Reveal Model Answer';
}

function selectMCQ(qi,oi){
  if(submitted)return;
  mcqAnswers[qi]=oi;
  document.querySelectorAll(`#mcq-${qi} .q-option`).forEach((el,j)=>el.classList.toggle('selected',j===oi));
  updateProgress();
}

function selectTF(qi,val){
  if(submitted)return;
  tfAnswers[qi]=val;
  document.getElementById(`tf-${qi}-true`).classList.toggle('selected',val===true);
  document.getElementById(`tf-${qi}-false`).classList.toggle('selected',val===false);
  updateProgress();
}

function updateProgress(){
  const total=mcqAnswers.filter(a=>a!==null).length+fiAnswers.filter(a=>a.trim()!=='').length+tfAnswers.filter(a=>a!==null).length;
  const pct=Math.round((total/50)*100);
  document.getElementById('progress-text').textContent=`${total} of 50 answered`;
  document.getElementById('progress-pct').textContent=`${pct}%`;
  document.getElementById('prog-bar').style.width=pct+'%';
}

function submitQuiz(){
  submitted=true;
  let mcqScore=0,fiScore=0,tfScore=0;
  MCQ.forEach((q,i)=>{
    const u=mcqAnswers[i];
    document.querySelectorAll(`#mcq-${i} .q-option`).forEach((el,j)=>{
      if(j===q.c)el.classList.add('correct-ans');
      if(u!==null&&j===u&&j!==q.c)el.classList.add('wrong-ans');
    });
    if(u===q.c)mcqScore++;
    document.getElementById(`mcq-exp-${i}`).classList.add('show');
  });
  FILLIN.forEach((q,i)=>{
    const u=(fiAnswers[i]||'').toLowerCase().trim();
    const kws=q.a.toLowerCase().replace(/[()]/g,'').split(/[\s\/,]+/).filter(w=>w.length>3);
    const ok=kws.some(kw=>u.includes(kw));
    if(ok)fiScore++;
    document.getElementById(`fi-ans-${i}`).classList.add('show');
    document.getElementById(`fi-exp-${i}`).classList.add('show');
    const inp=document.getElementById(`fi-input-${i}`);
    inp.style.borderColor=ok?'var(--correct)':'var(--incorrect)';
    inp.disabled=true;
  });
  TF.forEach((q,i)=>{
    const u=tfAnswers[i];
    const tB=document.getElementById(`tf-${i}-true`);
    const fB=document.getElementById(`tf-${i}-false`);
    (q.a===true?tB:fB).classList.add('correct-ans');
    if(u!==null&&u!==q.a)(u===true?tB:fB).classList.add('wrong-ans');
    if(u===q.a)tfScore++;
    document.getElementById(`tf-exp-${i}`).classList.add('show');
  });
  const auto=mcqScore+fiScore+tfScore;
  const pct=Math.round((auto/50)*100);
  document.getElementById('score-display').textContent=`${auto}/50`;
  document.getElementById('score-label').textContent=`${pct}% — Auto-graded sections only`;
  const g=document.getElementById('score-grade');
  if(pct>=80){g.textContent='🏆 Excellent — Exam Ready';g.className='result-grade grade-a';}
  else if(pct>=60){g.textContent='📚 Good — Review Weak Areas';g.className='result-grade grade-b';}
  else{g.textContent='🔄 Needs Work — Re-study Chapter';g.className='result-grade grade-c';}
  document.getElementById('rb-mcq').textContent=`${mcqScore}/25`;
  document.getElementById('rb-fi').textContent=`${fiScore}/15`;
  document.getElementById('rb-tf').textContent=`${tfScore}/10`;
  document.getElementById('results').style.display='block';
  document.getElementById('results').scrollIntoView({behavior:'smooth'});
}

function resetQuiz(){
  submitted=false;
  mcqAnswers=new Array(MCQ.length).fill(null);
  fiAnswers=new Array(FILLIN.length).fill('');
  tfAnswers=new Array(TF.length).fill(null);
  buildQuiz();updateProgress();
  document.getElementById('results').style.display='none';
}

buildMindmap();buildQuiz();buildCases();updateProgress();
</script>

</Layout>
