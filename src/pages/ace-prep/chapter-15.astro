      { q:"Why might Priya choose conservative treatment even with a rotator cuff tear?", opts:["Tears always heal without help","Other soft tissue can compensate for rotator cuff function","Surgery is never effective","The cuff has no role in stability"], ans:1, exp:"Rotator cuff functions can often be compensated for by other soft tissue, so some individuals elect conservative treatment and physical therapy." }
    ]
  },
  { num:4, topic:"Knee PFPS — Devon", scenario:"Devon, a recreational runner, has diffuse pain around the front of the kneecap that worsens walking downstairs. Assessment shows knock-knee alignment and weak hip muscles. He is cleared to train.",
    qs:[
      { q:"Devon's presentation is most consistent with:", opts:["Achilles tendinitis","Patellofemoral pain syndrome (PFPS)","Lateral ankle sprain","Carpal tunnel syndrome"], ans:1, exp:"Diffuse anterior knee pain worsening with stairs, plus genu valgum, is characteristic of PFPS." },
      { q:"Which weakness is commonly associated with PFPS?", opts:["Wrist flexors","Hip abductors and external rotators","Neck extensors","Plantar fascia"], ans:1, exp:"Hip abductor and external-rotator weakness can cause femoral internal rotation and abnormal knee valgus in PFPS." },
      { q:"Which activity should you be cautious about recommending for Devon?", opts:["Walking down stairs or downhill","Stationary cycling","Closed-chain hip strengthening","Recumbent biking"], ans:0, exp:"Activities requiring the quadriceps to decelerate knee flexion (walking down stairs/downhill) are often painful and aggravate PFPS." },
      { q:"Which knee exercise should generally be AVOIDED?", opts:["Closed-chain weight-bearing squats to tolerance","Open-chain seated knee extensions","Stationary bike","Posterior-chain strengthening"], ans:1, exp:"Open-chain knee extension exercises exacerbate knee pain and should be avoided in favor of closed-chain options." },
      { q:"Where should much of the corrective focus be directed?", opts:["Strengthening the corresponding hip to improve stability","Maximal calf raises only","Wrist mobility","Neck stretching"], ans:0, exp:"After identifying tightness/instability/malalignment, focus on improving strength in the corresponding hip to improve overall stability." }
    ]
  },
  { num:5, topic:"Post-rehab Lower-extremity — Sam", scenario:"Sam is recovering from a lower-extremity injury and has physician clearance to exercise within limits. He does not want to lose overall fitness while protecting the limb.",
    qs:[
      { q:"Which cardiorespiratory option fits a lower-extremity injury per Table 15-3?", opts:["Running on a treadmill","Water exercise or an upper-body ergometer","Box jumps","Stair sprints"], ans:1, exp:"For lower-extremity injury, appropriate cardio includes water exercise, an upper-body ergometer, and recumbent or stationary bike." },
      { q:"Which muscular-training approach is appropriate?", opts:["Heavy weight-bearing squats immediately","Upper-body seated/lying exercises and PT-prescribed lower-body work","Only the affected limb","Plyometric jumping"], ans:1, exp:"Use upper-body seated or lying exercises, lower-body exercises as prescribed by the PT/physician, and spine/core work that doesn't involve the affected limb." },
      { q:"What must Sam avoid until cleared?", opts:["All upper-body work","Weight-bearing exercise until cleared by a physician/PT","Breathing exercises","Seated rows"], ans:1, exp:"Avoid weight-bearing exercise until cleared by a physician and/or physical therapist, and any movements that cause pain." },
      { q:"Why is the kinetic chain relevant even for a localized lower-leg injury?", opts:["It isn't relevant","A lower-extremity injury affects all weight-bearing movements up the chain","Only the injured muscle matters","It only affects the upper body"], ans:1, exp:"A lower-extremity injury affects the kinetic chain in all weight-bearing movements, so programming must account for the whole chain." },
      { q:"If a prescribed exercise causes pain in the affected area, you should:", opts:["Push through to build tolerance","Stop immediately","Add load","Increase reps"], ans:1, exp:"If the client indicates pain in the affected area, the exercise should stop immediately." }
    ]
  },
  { num:6, topic:"Chronic Pain Coaching — Olivia", scenario:"Olivia has chronic pain from a herniated disc and was referred by her psychologist. She rates her baseline pain at 2 with flare-ups to 5 or 6, associates movement with pain, and is anxious about exercise.",
    qs:[
      { q:"What does the American Psychological Association recommend for coping with chronic pain?", opts:["Complete bed rest","Exercise and staying active","Avoiding all movement","Only medication"], ans:1, exp:"The APA (2019) recommends exercise and staying active as strategies for coping with chronic pain." },
      { q:"Which approach best fits coaching Olivia?", opts:["Tell her which feelings are right or wrong","Use the ACE Mover Method/ABC Approach with open-ended questions and empathy","Push her to a high intensity quickly","Avoid discussing pain"], ans:1, exp:"The ACE Mover Method and ABC Approach use open-ended questions, respect the client's feelings, and let her be the expert in her own life." },
      { q:"How should you use the perceived pain scale with Olivia during sessions?", opts:["Ignore it since she has chronic pain","Ask her to assess pain before and throughout, stopping if it exceeds her threshold","Only ask at the end","Push past her flare-up level"], ans:1, exp:"Ask the client to assess pain before and throughout the session and discontinue if pain exceeds the threshold or she is uncomfortable." },
      { q:"Recognizing chronic pain's emotional toll, you should:", opts:["Judge her progress harshly","Remain empathetic and non-judgmental","Minimize her experience","Avoid communication"], ans:1, exp:"Chronic pain has emotional impacts, so the trainer must remain empathetic and avoid judgment; the experience of pain differs for everyone." },
      { q:"What is an appropriate early focus for her program?", opts:["Maximal deadlifts","Observing how she moves and finding pain-free movements, starting slow","Immediate high-volume training","Unstable-surface plyometrics"], ans:1, exp:"Start by observing movement and finding what she can do without making pain worse, starting slow and adjusting as needed." }
    ]
  },
  { num:7, topic:"Shin Pain in a New Runner — Aisha", scenario:"Aisha recently increased her running and now has aching pain along the inner shin that came on gradually. There is no single point of intense tenderness, and pain eases with rest.",
    qs:[
      { q:"Aisha's diffuse inner-shin pain is most consistent with:", opts:["A stress fracture","Medial tibial stress syndrome (posterior shin splints)","An ACL tear","Carpal tunnel syndrome"], ans:1, exp:"Diffuse pain along the medial tibia from a sudden activity change suggests MTSS, which is periostitis." },
      { q:"How does a stress fracture differ from her presentation?", opts:["It causes diffuse pain","It causes point tenderness at a single spot and worsens with weight-bearing","It never causes pain","It only occurs in the arms"], ans:1, exp:"Stress fractures cause focal point tenderness at a single spot that worsens with weight-bearing and may ache at rest." },
      { q:"Does MTSS typically require complete rest?", opts:["Yes, total rest is mandatory","No, it usually requires modification and lower-impact alternatives","Yes, for a full year","Only surgery helps"], ans:1, exp:"Unlike stress fractures, shin splints usually do not require complete rest but rather modification and cross-training." },
      { q:"Which stretch has been shown to relieve MTSS symptoms?", opts:["Wrist flexor stretch","Pain-free stretching of the calf, especially the soleus","Neck rotation stretch","Shoulder cross-body stretch"], ans:1, exp:"Pain-free stretching of the calf muscles, especially the soleus, has been shown effective for MTSS." },
      { q:"What should you do if her symptoms point instead to a stress fracture?", opts:["Keep increasing her mileage","Refer her to a physician for diagnosis and treatment","Apply heat and continue running","Ignore it"], ans:1, exp:"Any client with symptoms of an acute or stress fracture should be referred to a physician, partly because bone-cancer symptoms can be similar." }
    ]
  }
];

// ── STATE ─────────────────────────────────────────────────────────────────────
let theoryMCQ   = {};
let fibAnswers  = {};
let tfAnswers   = {};
let theoryGraded = false;

let caseAnswers = {};
let caseGraded  = false;

// ── THEORY FUNCTIONS ──────────────────────────────────────────────────────────
function buildTheoryQuiz() {
  const sec = document.getElementById('t-mcq-section');
  sec.innerHTML = '';
  THEORY_MCQ.forEach((q, qi) => {
    const opts = q.opts.map((o, oi) =>
      `<div class="q-option" data-key="tq-${qi}" data-idx="${oi}" onclick="pickTheory(${qi},${oi})">
        <div class="opt-letter">${['A','B','C','D'][oi]}</div>${o}
      </div>`
    ).join('');
    sec.insertAdjacentHTML('beforeend', `
      <div class="q-card" id="tcard-${qi}">
        <div class="q-num">Q${qi + 1}</div>
        <div class="q-text">${q.q}</div>
        <div class="q-options">${opts}</div>
        <div class="q-exp" id="texp-${qi}"><strong>Explanation</strong>${q.exp}</div>
      </div>
    `);
  });
}

function buildFIB() {
  const sec = document.getElementById('t-fib-section');
  sec.innerHTML = '';
  FILLIN.forEach((f, fi) => {
    sec.insertAdjacentHTML('beforeend', `
      <div class="fib-card" id="tfib-card-${fi}">
        <div class="q-num">Q${21 + fi}</div>
        <div class="fib-q">${f.q}</div>
        <div class="fib-input-wrap">
          <input class="q-input" id="tfib-${fi}" type="text" placeholder="Type your answer…"
            oninput="fibAnswers[${fi}]=this.value;updateTheoryProgress()" autocomplete="off"/>
          <span class="fib-feedback" id="tfib-fb-${fi}"></span>
        </div>
        <div class="fib-hint" id="tfib-hint-${fi}"><em>Hint:</em> ${f.hint}</div>
      </div>
    `);
  });
}

function buildTF() {
  const sec = document.getElementById('t-tf-section');
  sec.innerHTML = '';
  TRUEF.forEach((t, ti) => {
    sec.insertAdjacentHTML('beforeend', `
      <div class="tf-card" id="ttf-card-${ti}">
        <div class="q-num">Q${26 + ti}</div>
        <div class="tf-q">${t.q}</div>
        <div class="q-tf">
          <button class="q-tf-btn" id="ttf-${ti}-T" onclick="pickTF(${ti},true)">True</button>
          <button class="q-tf-btn" id="ttf-${ti}-F" onclick="pickTF(${ti},false)">False</button>
        </div>
        <div class="tf-exp" id="ttf-exp-${ti}"><strong>Explanation</strong>${t.exp}</div>
      </div>
    `);
  });
}

function pickTheory(qi, oi) {
  if (theoryGraded) return;
  theoryMCQ[qi] = oi;
  document.querySelectorAll(`[data-key="tq-${qi}"]`).forEach((el, i) => {
    el.classList.toggle('selected', i === oi);
    el.querySelector('.opt-letter').style.background  = (i === oi) ? 'var(--accent)' : '';
    el.querySelector('.opt-letter').style.color       = (i === oi) ? '#000' : '';
    el.querySelector('.opt-letter').style.borderColor = (i === oi) ? 'var(--accent)' : '';
  });
  updateTheoryProgress();
}

function pickTF(ti, val) {
  if (theoryGraded) return;
  tfAnswers[ti] = val;
  document.getElementById(`ttf-${ti}-T`).classList.toggle('selected', val === true);
  document.getElementById(`ttf-${ti}-F`).classList.toggle('selected', val === false);
  updateTheoryProgress();
}

function updateTheoryProgress() {
  let n = Object.keys(theoryMCQ).length;
  FILLIN.forEach((_, fi) => { if (fibAnswers[fi] && fibAnswers[fi].trim()) n++; });
  TRUEF.forEach((_, ti)  => { if (tfAnswers[ti] !== undefined) n++; });
  document.getElementById('t-progress-text').textContent = `${n} of 30 answered`;
  document.getElementById('t-progress-pct').textContent  = `${Math.round(n/30*100)}%`;
  document.getElementById('t-prog-bar').style.width      = `${n/30*100}%`;
}

function submitTheory() {
  if (theoryGraded) return;
  theoryGraded = true;
  document.getElementById('t-submit-btn').disabled = true;

  let mcqC = 0, fibC = 0, tfC = 0;

  THEORY_MCQ.forEach((q, qi) => {
    const sel  = theoryMCQ[qi];
    const opts = document.querySelectorAll(`[data-key="tq-${qi}"]`);
    opts.forEach(el => { el.style.pointerEvents = 'none'; el.classList.remove('selected'); });
    if (sel === undefined) {
      opts[q.c].classList.add('reveal-correct');
    } else if (sel === q.c) {
      mcqC++;
      opts[sel].classList.add('correct-ans');
    } else {
      opts[sel].classList.add('wrong-ans');
      opts[q.c].classList.add('reveal-correct');
    }
    document.getElementById(`texp-${qi}`).classList.add('show');
  });

  FILLIN.forEach((f, fi) => {
    const inp = document.getElementById(`tfib-${fi}`);
    inp.disabled = true;
    const val = (fibAnswers[fi] || '').trim().toLowerCase();
    const ans = f.a.toLowerCase();
    const fb  = document.getElementById(`tfib-fb-${fi}`);
    if (!val) {
      inp.classList.add('fib-wrong');
      fb.textContent = `Answer: ${f.a.toUpperCase()}`;
      fb.className = 'fib-feedback bad';
    } else if (val === ans || ans.includes(val) || val.includes(ans.split(' ')[0])) {
      fibC++;
      inp.classList.add('fib-correct');
      fb.textContent = '✓';
      fb.className = 'fib-feedback ok';
    } else {
      inp.classList.add('fib-wrong');
      fb.textContent = `Answer: ${f.a.toUpperCase()}`;
      fb.className = 'fib-feedback bad';
    }
    document.getElementById(`tfib-hint-${fi}`).classList.add('show');
  });

  TRUEF.forEach((t, ti) => {
    const tBtn = document.getElementById(`ttf-${ti}-T`);
    const fBtn = document.getElementById(`ttf-${ti}-F`);
    [tBtn, fBtn].forEach(b => { b.disabled = true; b.classList.remove('selected'); });
    const sel = tfAnswers[ti];
    if (sel === undefined) {
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
    } else if (sel === t.a) {
      tfC++;
      (sel ? tBtn : fBtn).classList.add('tf-correct');
    } else {
      (sel ? tBtn : fBtn).classList.add('tf-wrong');
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
    }
    document.getElementById(`ttf-exp-${ti}`).classList.add('show');
  });

  const total = mcqC + fibC + tfC;
  document.getElementById('t-score-num').textContent = total;
  document.getElementById('t-rb-mcq').textContent    = `${mcqC}/20`;
  document.getElementById('t-rb-fi').textContent     = `${fibC}/5`;
  document.getElementById('t-rb-tf').textContent     = `${tfC}/5`;
  const result = document.getElementById('theory-result');
  result.classList.add('show');
  result.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function resetTheory() {
  theoryMCQ = {}; fibAnswers = {}; tfAnswers = {}; theoryGraded = false;
  document.getElementById('t-submit-btn').disabled = false;
  document.getElementById('theory-result').classList.remove('show');
  buildTheoryQuiz();
  buildFIB();
  buildTF();
  updateTheoryProgress();
}

// ── CASE FUNCTIONS ────────────────────────────────────────────────────────────
function buildCases() {
  const sec = document.getElementById('c-mcq-section');
  sec.innerHTML = '';
  CASES.forEach((cs, ci) => {
    const block = document.createElement('div');
    block.className = 'case-block';
    block.innerHTML = `
      <div class="case-header">
        <div class="case-num-badge">${cs.num}</div>
        <div class="case-topic-label">${cs.topic}</div>
      </div>
      <div class="scenario-box">${cs.scenario}</div>
    `;
    cs.qs.forEach((q, qi) => {
      const key  = `${ci}-${qi}`;
      const opts = q.opts.map((o, oi) =>
        `<div class="q-option" data-key="cq-${key}" data-idx="${oi}" onclick="pickCase('${key}',${oi})">
          <div class="opt-letter">${['A','B','C','D'][oi]}</div>${o}
        </div>`
      ).join('');
      block.insertAdjacentHTML('beforeend', `
        <div class="q-card" id="ccard-${key}">
          <div class="q-num">Q${ci * 5 + qi + 1}</div>
          <div class="q-text">${q.q}</div>
          <div class="q-options">${opts}</div>
          <div class="q-exp" id="cexp-${key}"><strong>Explanation</strong>${q.exp}</div>
        </div>
      `);
    });
    sec.appendChild(block);
  });
}

function pickCase(key, oi) {
  if (caseGraded) return;
  caseAnswers[key] = oi;
  document.querySelectorAll(`[data-key="cq-${key}"]`).forEach((el, i) => {
    el.classList.toggle('selected', i === oi);
    el.querySelector('.opt-letter').style.background  = (i === oi) ? 'var(--accent)' : '';
    el.querySelector('.opt-letter').style.color       = (i === oi) ? '#000' : '';
    el.querySelector('.opt-letter').style.borderColor = (i === oi) ? 'var(--accent)' : '';
  });
  updateCaseProgress();
}

function updateCaseProgress() {
  const n = Object.keys(caseAnswers).length;
  document.getElementById('c-progress-text').textContent = `${n} of 35 answered`;
  document.getElementById('c-progress-pct').textContent  = `${Math.round(n/35*100)}%`;
  document.getElementById('c-prog-bar').style.width      = `${n/35*100}%`;
}

function submitCases() {
  if (caseGraded) return;
  caseGraded = true;
  document.getElementById('c-submit-btn').disabled = true;

  let correct = 0, wrong = 0, skip = 0;

  CASES.forEach((cs, ci) => {
    cs.qs.forEach((q, qi) => {
      const key  = `${ci}-${qi}`;
      const sel  = caseAnswers[key];
      const opts = document.querySelectorAll(`[data-key="cq-${key}"]`);
      opts.forEach(el => { el.style.pointerEvents = 'none'; el.classList.remove('selected'); });
      if (sel === undefined) {
        skip++;
        opts[q.ans].classList.add('reveal-correct');
      } else if (sel === q.ans) {
        correct++;
        opts[sel].classList.add('correct-ans');
      } else {
        wrong++;
        opts[sel].classList.add('wrong-ans');
        opts[q.ans].classList.add('reveal-correct');
      }
      document.getElementById(`cexp-${key}`).classList.add('show');
    });
  });

  setTimeout(() => showModal(correct, wrong, skip), 350);
}

function retakeCases() {
  caseAnswers = {};
  caseGraded  = false;
  document.getElementById('result-modal').classList.remove('open');
  document.getElementById('c-submit-btn').disabled = false;
  buildCases();
  updateCaseProgress();
}

function showModal(correct, wrong, skip) {
  const pct   = Math.round(correct / 35 * 100);
  const grade = pct >= 90 ? 'A' : pct >= 80 ? 'B' : pct >= 70 ? 'C' : 'D';
  const bands = {
    A: 'Outstanding! Strong command of injury recognition, scope/referral, pain management, and region-specific programming.',
    B: 'Great work. Review any wrong answers — check the healing phases, grading systems, and joint-specific rules.',
    C: 'Passing, but worth another review — especially RICE, the pain scale, and what to avoid for each joint.',
    D: 'Needs more study. Re-read the chapter and use the Theory Guide before retaking.'
  };
  const titles = { A:'Excellent Work!', B:'Good Effort!', C:'Keep Going!', D:'Keep Studying!' };

  const ring = document.getElementById('modal-ring');
  ring.textContent = grade;
  ring.className   = `modal-grade-ring grade-${grade}`;
  document.getElementById('modal-title').textContent   = titles[grade];
  document.getElementById('modal-correct').textContent = correct;
  document.getElementById('modal-wrong').textContent   = wrong;
  document.getElementById('modal-skip').textContent    = skip;
  document.getElementById('modal-pct').textContent     = `${pct}%`;
  document.getElementById('modal-band').textContent    = bands[grade];
  document.getElementById('result-modal').classList.add('open');
}

function closeModal() { document.getElementById('result-modal').classList.remove('open'); }

// ── SHARED ────────────────────────────────────────────────────────────────────
function switchTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}

function buildMindmap() {
  const grid = document.getElementById('mm-grid');
  MINDMAP.branches.forEach(branch => {
    const el = document.createElement('div');
    el.className = 'mm-branch';
    el.innerHTML = `
      <div class="mm-branch-header" onclick="toggleBranch(this.parentElement)">
        <div class="mm-branch-dot" style="background:${branch.color}"></div>
        <div class="mm-branch-name">${branch.name}</div>
        <div class="mm-branch-arrow">▶</div>
      </div>
      <div class="mm-branch-body">
        <div class="mm-subs">
          ${branch.subs.map(s => `
            <div class="mm-sub">
              <div class="mm-sub-name">${s.name}</div>
              <ul class="mm-sub-points">
                ${s.points.map(p => `<li>${p}</li>`).join('')}
              </ul>
            </div>
          `).join('')}
        </div>
      </div>
    `;
    grid.appendChild(el);
  });
}

function toggleBranch(branch) { branch.classList.toggle('open'); }

// ── INIT ──────────────────────────────────────────────────────────────────────
buildMindmap();
buildTheoryQuiz();
buildFIB();
buildTF();
buildCases();
</script>

