---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Effective Communication, Goal Setting & Teaching Techniques — Theory Guide | ACE Prep · Lifelong Athletics" description="Complete theory guide covering the 4 stages of the client-trainer relationship, Cultural Competence, MI & OARS, SMART Goals, Locke & Latham, Motor Learning, VAK, and Tell-Show-Do for ACE-CPT Chapter 4.">

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
  font-size: 17px;
  line-height: 1.75;
  color: #1a1a2e;
  background: #f7f6f2;
}
.blog-container {
  max-width: 860px;
  margin: 0 auto;
  padding: 40px 24px 80px;
  background: #f7f6f2;
}

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, #0d1f35 0%, #0a1a28 50%, #0f2028 100%);
  color: #fff;
  border-radius: 16px;
  padding: 56px 48px;
  margin-bottom: 48px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 280px; height: 280px;
  background: rgba(197,241,53,0.06);
  border-radius: 50%;
}
.hero-tag {
  display: inline-block;
  background: #c5f135;
  color: #000;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 20px;
  margin-bottom: 20px;
}
.hero h1 {
  font-size: clamp(24px, 4vw, 38px);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16px;
  max-width: 640px;
}
.hero p {
  color: rgba(255,255,255,0.65);
  font-size: 15px;
  max-width: 560px;
  margin-bottom: 24px;
}
.back-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #c5f135;
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
}
.back-link:hover { text-decoration: underline; }

/* ── TOC BAR ── */
.toc-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(247,246,242,0.98);
  border-bottom: 1px solid #dddbd6;
  padding: 0;
  margin-bottom: 48px;
  overflow-x: auto;
  white-space: nowrap;
}
.toc-inner {
  display: inline-flex;
  gap: 0;
  padding: 0 4px;
}
.toc-link {
  display: inline-block;
  padding: 14px 16px;
  font-size: 12px;
  font-weight: 600;
  color: #6b7280;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}
.toc-link:hover { color: #111; border-bottom-color: #c5f135; }

/* ── SECTION ── */
.section { margin-bottom: 64px; }
.section-tag {
  display: inline-block;
  background: #c5f135;
  color: #000;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 3px 12px;
  border-radius: 20px;
  margin-bottom: 16px;
}
.section-tag.teal  { background: #22d3ee; color: #000; }
.section-tag.blue  { background: #3b82f6; color: #fff; }
.section-tag.purple{ background: #a855f7; color: #fff; }
.section-tag.orange{ background: #f97316; color: #fff; }
.section-tag.green { background: #10b981; color: #fff; }
.section h2 {
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 800;
  color: #111827;
  margin-bottom: 16px;
  line-height: 1.25;
}
.section p {
  color: #374151;
  margin-bottom: 18px;
  font-size: 16px;
}
.section p strong { color: #111827; }

/* ── DIVIDER ── */
.divider { height: 1px; background: #e5e7eb; margin: 56px 0; }

/* ── CALLOUT ── */
.callout {
  background: #ffffff;
  border-left: 4px solid #c5f135;
  border-radius: 0 8px 8px 0;
  padding: 16px 20px;
  margin: 24px 0;
}
.callout.teal   { border-left-color: #22d3ee; }
.callout.blue   { border-left-color: #3b82f6; }
.callout.purple { border-left-color: #a855f7; }
.callout.orange { border-left-color: #f97316; }
.callout.green  { border-left-color: #10b981; }
.callout p { font-size: 14px; margin: 0; color: #374151; line-height: 1.65; }
.callout strong { color: #111; }

/* ── STAGE FLOW ── */
.stage-flow {
  display: flex;
  align-items: center;
  gap: 0;
  margin: 28px 0;
  flex-wrap: wrap;
  gap: 4px;
}
.stage-pill {
  flex: 1;
  min-width: 120px;
  background: #eeece9;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  padding: 14px 12px;
  text-align: center;
}
.stage-pill.active { background: #f0fdf4; border-color: #86efac; }
.stage-pill .sn { font-size: 10px; font-weight: 700; color: #9ca3af; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
.stage-pill .st { font-size: 14px; font-weight: 800; color: #111; }
.stage-pill.active .st { color: #16a34a; }
.stage-arrow { color: #9ca3af; font-size: 16px; padding: 0 4px; }

/* ── CARD GRID ── */
.card-grid {
  display: grid;
  gap: 14px;
  margin: 24px 0;
}
.card-grid-2 { grid-template-columns: 1fr 1fr; }
.card-grid-3 { grid-template-columns: 1fr 1fr 1fr; }
.card-grid-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }

.card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 18px;
  border-left: 3px solid #c5f135;
}
.card.teal   { border-left-color: #22d3ee; }
.card.blue   { border-left-color: #3b82f6; }
.card.purple { border-left-color: #a855f7; }
.card.orange { border-left-color: #f97316; }
.card.green  { border-left-color: #10b981; }
.card h4 {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 8px;
  color: #111;
}
.card p { font-size: 13px; color: #374151; margin: 0; line-height: 1.6; }

/* ── OARS TABLE ── */
.oars-table { width: 100%; border-collapse: collapse; margin: 24px 0; }
.oars-table th, .oars-table td {
  padding: 12px 14px;
  text-align: left;
  font-size: 14px;
  border-bottom: 1px solid #e5e7eb;
}
.oars-table th {
  background: #eeece9;
  color: #6b7280;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.oars-table tr:hover td { background: #ffffff; }
.oars-letter { font-size: 22px; font-weight: 900; color: #111827; line-height: 1; }
.oars-skill { font-weight: 700; color: #111827; }
.oars-def { color: #6b7280; font-size: 13px; }
.oars-example { color: #f97316; font-size: 13px; font-style: italic; }

/* ── SMART GRID ── */
.smart-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
  margin: 24px 0;
}
.smart-card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 18px 12px;
  text-align: center;
}
.smart-letter { font-size: 32px; font-weight: 900; margin-bottom: 6px; color: #c5f135; }
.smart-word { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; margin-bottom: 6px; }
.smart-desc { font-size: 12px; color: #374151; line-height: 1.5; }
.smart-card:nth-child(1) .smart-letter { color: #22d3ee; }
.smart-card:nth-child(2) .smart-letter { color: #10b981; }
.smart-card:nth-child(3) .smart-letter { color: #f97316; }
.smart-card:nth-child(4) .smart-letter { color: #3b82f6; }
.smart-card:nth-child(5) .smart-letter { color: #a855f7; }

/* ── GOAL TYPES ── */
.goal-types { display: flex; gap: 14px; margin: 20px 0; }
.goal-type {
  flex: 1;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 18px;
}
.goal-type.process { border-top: 3px solid #3b82f6; }
.goal-type.performance { border-top: 3px solid #10b981; }
.goal-type h5 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
.goal-type.process h5 { color: #3b82f6; }
.goal-type.performance h5 { color: #10b981; }
.goal-type p { font-size: 13px; color: #374151; margin: 0; line-height: 1.6; }

/* ── MECHANISM LIST ── */
.mechanism-list { margin: 20px 0; }
.mechanism-item {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 10px;
}
.m-icon { font-size: 20px; min-width: 30px; text-align: center; margin-top: 2px; }
.m-content h5 { font-size: 14px; font-weight: 700; color: #f97316; margin-bottom: 4px; }
.m-content p { font-size: 13px; color: #374151; margin: 0; line-height: 1.5; }

/* ── MOTOR LEARNING STAGES ── */
.stages-row { display: flex; gap: 14px; margin: 24px 0; }
.stage-card {
  flex: 1;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.stage-card .s-num { font-size: 28px; font-weight: 900; line-height: 1; }
.stage-card:nth-child(1) .s-num { color: #3b82f6; }
.stage-card:nth-child(2) .s-num { color: #f97316; }
.stage-card:nth-child(3) .s-num { color: #10b981; }
.stage-card .s-name { font-size: 14px; font-weight: 800; color: #111; }
.stage-card .s-desc { font-size: 13px; color: #6b7280; line-height: 1.5; }

/* ── VAK ROW ── */
.vak-row { display: flex; gap: 14px; margin: 24px 0; }
.vak-card {
  flex: 1;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 18px;
}
.v-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
.vak-card:nth-child(1) .v-label { color: #22d3ee; }
.vak-card:nth-child(2) .v-label { color: #f97316; }
.vak-card:nth-child(3) .v-label { color: #a855f7; }
.v-title { font-size: 15px; font-weight: 700; margin-bottom: 6px; color: #111; }
.v-cue { font-size: 13px; color: #6b7280; font-style: italic; margin-bottom: 6px; }
.v-tip { font-size: 13px; color: #374151; }

/* ── BODY LANGUAGE TABLE ── */
.bl-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
.bl-table th, .bl-table td {
  padding: 11px 14px;
  text-align: left;
  font-size: 14px;
  border-bottom: 1px solid #e5e7eb;
}
.bl-table th { background: #eeece9; color: #6b7280; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
.bl-table tr:hover td { background: #ffffff; }

/* ── MI SPIRIT GRID ── */
.mi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin: 24px 0; }
.mi-card { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 20px; }
.mi-word { font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: #22d3ee; margin-bottom: 6px; }
.mi-def { font-size: 13px; color: #374151; line-height: 1.55; }

/* ── KEY TAKEAWAYS ── */
.takeaways {
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: 12px;
  padding: 32px;
  margin: 48px 0;
}
.takeaways h3 {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #16a34a;
  margin-bottom: 20px;
}
.takeaway-item {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  padding: 10px 0;
  border-bottom: 1px solid #d1fae5;
}
.takeaway-item:last-child { border: none; }
.tick { color: #16a34a; font-size: 14px; margin-top: 3px; flex-shrink: 0; }
.takeaway-item p { font-size: 14px; color: #374151; margin: 0; line-height: 1.55; }

/* ── BACK FOOTER ── */
.page-footer {
  text-align: center;
  color: #9ca3af;
  font-size: 13px;
  padding: 32px 24px;
  border-top: 1px solid #e5e7eb;
  margin-top: 64px;
}
.page-footer a { color: #374151; font-weight: 600; text-decoration: none; }
.page-footer a:hover { color: #000; }

@media (max-width: 680px) {
  .hero { padding: 36px 24px; }
  .card-grid-2, .card-grid-3, .card-grid-4, .smart-grid, .stages-row, .vak-row, .mi-grid, .goal-types { grid-template-columns: 1fr; flex-direction: column; }
  .stage-flow { flex-direction: column; gap: 6px; }
  .stage-arrow { transform: rotate(90deg); }
}

