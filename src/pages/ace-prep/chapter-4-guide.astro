  <!-- HERO -->
  <div class="hero">
    <div class="hero-tag">ACE-CPT · Chapter 4 · Theory Guide</div>
    <h1>Effective Communication, Goal Setting &amp; Teaching Techniques</h1>
    <p>The science of building trust, evoking motivation, setting SMART goals, and teaching motor skills that stick.</p>
    <a href="/ace-prep/chapter-4" class="back-link">← Back to Chapter 4 Hub</a>
  </div>

  <!-- TOC BAR -->
  <nav class="toc-bar">
    <div class="toc-inner">
