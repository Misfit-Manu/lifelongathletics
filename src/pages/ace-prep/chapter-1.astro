    scenario: "Renata is an ACE CPT passionate about understanding the public health context of her work. She wants to understand the global physical inactivity crisis, how it drives demand for personal trainers, and how the ACE IFT Model helps her navigate client relationships.",
    qs: [
      { q: "According to WHO data, what percentage change occurred in global insufficient physical activity from 2001 to 2016?", opts: ["Decreased by 10%","Decreased by 1%","Increased by 5%","No change"], ans: 1, exp: "WHO data found only a nonsignificant 1% change in global insufficient physical activity levels from 2001 (28.5%) to 2016 (27.5%)." },
      { q: "Which of the following is a driver of the projected 10% employment growth for fitness trainers (2016–2026) per the Bureau of Labor Statistics?", opts: ["Declining participation in organized sports","Baby boomers remaining active to prevent injuries, illness, and chronic disease","Reduction in private health insurance coverage for exercise","Decrease in medical fitness facility openings"], ans: 1, exp: "BLS cited baby boomers staying active, employer wellness programs, obesity epidemic focus, and older adults seeking low-impact exercise as growth drivers." },
      { q: "The ACE Integrated Fitness Training (IFT) Model is designed to help personal trainers:", opts: ["Follow a rigid script for every client interaction","Navigate the complete process of working with clients from initial meeting through the ongoing relationship","Expand their scope of practice to include clinical services","Evaluate clients for medical clearance without physician referral"], ans: 1, exp: "The ACE IFT Model helps personal trainers competently navigate the complete process of working with clients from initial meeting through the ongoing relationship." },
      { q: "What is the 2025 global target for physical activity improvement set by the WHO?", opts: ["25% relative reduction in insufficient physical activity","15% reduction in NCD mortality","10% relative reduction in insufficient physical activity","Elimination of physical inactivity as a modifiable risk factor"], ans: 2, exp: "The WHO set a 2025 global target of a 10% relative reduction in insufficient physical activity. Researchers reported this target will not be met at current trends." },
      { q: "In high-income countries, what happened to insufficient physical activity levels from 2001 to 2016?", opts: ["Decreased by 5.2%","Remained unchanged","Increased by 5.2% (from 31.6% to 36.8%)","Increased by 10%"], ans: 2, exp: "In high-income countries, insufficient physical activity increased by 5.2% from 2001 (31.6%) to 2016 (36.8%) — more than twice the rate seen in low-income countries." }
    ]
  }
];

const FILLIN = [
  { q: "The _______ is the accreditation body that provides the gold standard for certification program accreditation in healthcare, fitness, and other industries.", a: "ncca", hint: "National Commission for Certifying Agencies" },
  { q: "A scope of practice defines the _______ range of services a professional can provide in their field.", a: "legal", hint: "legal" },
  { q: "The _______ maintains a registry of 175,000+ exercise professionals who hold current NCCA-accredited certifications.", a: "usreps", hint: "United States Registry of Exercise Professionals" },
  { q: "ACE certifications require a minimum of _______ hours of ACE-approved continuing education credits for renewal every two years.", a: "20", hint: "20" },
  { q: "Personal trainers may share dietary advice endorsed by the federal government, such as the _______ recommendations, which is within their scope of practice.", a: "myplate", hint: "MyPlate" }
];

const TRUEF = [
  { q: "A personal trainer with extensive personal knowledge about supplements may recommend specific supplements to clients if the trainer believes the supplement is safe.", a: false, exp: "Supplement recommendations are outside scope regardless of the trainer's personal knowledge. Clients must be referred to an RD or physician." },
  { q: "The primary purpose of a professional certification such as the ACE CPT is to prove that the professional has mastered everything there is to know about personal training.", a: false, exp: "The primary purpose is to protect the public from harm by assessing minimum competency — the threshold required to work safely with minimal supervision." },
  { q: "Written client permission is required before a personal trainer can share a client's health information with the client's physician.", a: true, exp: "HIPAA and the ACE Code of Ethics require written client permission before sharing health information with any third party, including the referring physician." },
  { q: "A personal trainer who earns a specialty certificate in manual therapeutic manipulation may legally perform those techniques on clients.", a: false, exp: "Manual manipulation falls in the legal domain of other licensed professions. Additional CECs do not extend the personal trainer scope into another profession's legal domain." },
  { q: "The Medical Fitness Association (2013) established the standard that medically integrated health and fitness facilities should hire exercise professionals who hold NCCA-accredited certifications.", a: true, exp: "The Medical Fitness Association mandated NCCA-accredited certifications as the standard for hiring exercise professionals at medical fitness facilities." }
];

// ── STATE ─────────────────────────────────────────────────────────────────────
let mcqAnswers = {};
let fibAnswers = {};
let tfAnswers  = {};
let graded     = false;
let globalQNum = 0;

// ── RENDER ────────────────────────────────────────────────────────────────────
function renderAll() {
  globalQNum = 0;
  renderMCQ();
  renderFIB();
  renderTF();
  updateProgress();
}

function renderMCQ() {
  const sec = document.getElementById('mcq-section');
  sec.innerHTML = '';
  CASES.forEach((cs, ci) => {
    const block = document.createElement('div');
    block.className = 'case-block';
    block.innerHTML = `
      <div class="case-header">
        <div class="case-num-badge">${cs.num}</div>
        <div class="case-topic-label">${cs.topic}</div>
      </div>
      <div class="scenario-box">${cs.scenario}</div>
    `;
    cs.qs.forEach((q, qi) => {
      globalQNum++;
      const qn = globalQNum;
      const card = document.createElement('div');
      card.className = 'q-card';
      card.id = `q-${qn}`;
      const letters = ['A','B','C','D'];
      card.innerHTML = `
        <div class="q-num">Question ${qn}</div>
        <div class="q-text">${q.q}</div>
        <div class="q-options">
          ${q.opts.map((o, oi) => `
            <div class="q-option" data-ci="${ci}" data-qi="${qi}" data-oi="${oi}" onclick="pickMCQ(${ci},${qi},${oi},this)">
              <span class="opt-letter">${letters[oi]}</span>
              <span>${o}</span>
            </div>`).join('')}
        </div>
        <div class="q-exp" id="exp-${qn}"><strong>Explanation</strong>${q.exp}</div>
      `;
      block.appendChild(card);
    });
    sec.appendChild(block);
  });
}

function renderFIB() {
  const sec = document.getElementById('fib-section');
  sec.innerHTML = '';
  FILLIN.forEach((f, fi) => {
    globalQNum++;
    const qn = globalQNum;
    const card = document.createElement('div');
    card.className = 'fib-card';
    card.id = `q-${qn}`;
    card.innerHTML = `
      <div class="q-num">Question ${qn}</div>
      <div class="fib-q">${f.q}</div>
      <div class="fib-input-wrap">
        <input class="q-input" id="fib-${fi}" type="text" placeholder="Your answer…" oninput="trackFIB(${fi})">
        <span class="fib-feedback" id="fib-fb-${fi}"></span>
      </div>
      <div class="fib-hint" id="fib-hint-${fi}">Hint: ${f.hint}</div>
    `;
    sec.appendChild(card);
  });
}

function renderTF() {
  const sec = document.getElementById('tf-section');
  sec.innerHTML = '';
  TRUEF.forEach((t, ti) => {
    globalQNum++;
    const qn = globalQNum;
    const card = document.createElement('div');
    card.className = 'tf-card';
    card.id = `q-${qn}`;
    card.innerHTML = `
      <div class="q-num">Question ${qn}</div>
      <div class="tf-q">${t.q}</div>
      <div class="q-tf">
        <button class="q-tf-btn" id="tf-${ti}-T" onclick="pickTF(${ti},true)">TRUE</button>
        <button class="q-tf-btn" id="tf-${ti}-F" onclick="pickTF(${ti},false)">FALSE</button>
      </div>
      <div class="tf-exp" id="tf-exp-${ti}"><strong>Explanation</strong>${t.exp}</div>
    `;
    sec.appendChild(card);
  });
}

// ── INTERACTIONS ──────────────────────────────────────────────────────────────
function pickMCQ(ci, qi, oi, el) {
  if (graded) return;
  const opts = el.closest('.q-options').querySelectorAll('.q-option');
  opts.forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  mcqAnswers[`${ci}-${qi}`] = oi;
  updateProgress();
}

function trackFIB(fi) {
  fibAnswers[fi] = document.getElementById(`fib-${fi}`).value.trim();
  updateProgress();
}

function pickTF(ti, val) {
  if (graded) return;
  tfAnswers[ti] = val;
  document.getElementById(`tf-${ti}-T`).className = 'q-tf-btn' + (val === true  ? ' selected' : '');
  document.getElementById(`tf-${ti}-F`).className = 'q-tf-btn' + (val === false ? ' selected' : '');
  updateProgress();
}

function updateProgress() {
  const mcqDone = Object.keys(mcqAnswers).length;
  const fibDone = Object.values(fibAnswers).filter(v => v.length > 0).length;
  const tfDone  = Object.keys(tfAnswers).length;
  const total   = mcqDone + fibDone + tfDone;
  const pct = Math.round((total / 45) * 100);
  document.getElementById('progress-text').textContent = `${total} of 45 answered`;
  document.getElementById('progress-pct').textContent  = `${pct}%`;
  document.getElementById('prog-bar').style.width       = `${pct}%`;
}

// ── GRADE ─────────────────────────────────────────────────────────────────────
function submitQuiz() {
  if (graded) return;
  graded = true;
  document.getElementById('submit-btn').disabled = true;

  let correct = 0, wrong = 0, skip = 0;

  // MCQ
  let qn = 0;
  CASES.forEach((cs, ci) => {
    cs.qs.forEach((q, qi) => {
      qn++;
      const sel = mcqAnswers[`${ci}-${qi}`];
      const opts = document.querySelectorAll(`#q-${qn} .q-option`);
      opts.forEach(o => { o.style.pointerEvents = 'none'; });
      if (sel === undefined) {
        opts[q.ans].classList.add('reveal-correct');
        skip++;
      } else if (sel === q.ans) {
        opts[sel].classList.add('correct-ans');
        correct++;
      } else {
        opts[sel].classList.add('wrong-ans');
        opts[q.ans].classList.add('reveal-correct');
        wrong++;
      }
      document.getElementById(`exp-${qn}`).classList.add('show');
    });
  });

  // FIB
  FILLIN.forEach((f, fi) => {
    qn++;
    const inp = document.getElementById(`fib-${fi}`);
    inp.disabled = true;
    const val = (fibAnswers[fi] || '').toLowerCase().trim();
    const ans = f.a.toLowerCase();
    const ok  = val === ans || ans.includes(val) || val.includes(ans.split(' ')[0]);
    if (val === '') {
      skip++;
      document.getElementById(`fib-hint-${fi}`).classList.add('show');
    } else if (ok) {
      inp.classList.add('fib-correct');
      document.getElementById(`fib-fb-${fi}`).className = 'fib-feedback ok';
      document.getElementById(`fib-fb-${fi}`).textContent = '✓';
      correct++;
    } else {
      inp.classList.add('fib-wrong');
      document.getElementById(`fib-fb-${fi}`).className = 'fib-feedback bad';
      document.getElementById(`fib-fb-${fi}`).textContent = `✗ ${f.hint}`;
      document.getElementById(`fib-hint-${fi}`).classList.add('show');
      wrong++;
    }
  });

  // T/F
  TRUEF.forEach((t, ti) => {
    qn++;
    const tBtn = document.getElementById(`tf-${ti}-T`);
    const fBtn = document.getElementById(`tf-${ti}-F`);
    tBtn.disabled = true; fBtn.disabled = true;
    const sel = tfAnswers[ti];
    if (sel === undefined) {
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
      skip++;
    } else if (sel === t.a) {
      (sel ? tBtn : fBtn).classList.add('tf-correct');
      correct++;
    } else {
      (sel ? tBtn : fBtn).classList.add('tf-wrong');
      (!sel ? tBtn : fBtn).classList.add('tf-reveal');
      wrong++;
    }
    document.getElementById(`tf-exp-${ti}`).classList.add('show');
  });

  showModal(correct, wrong, skip);
}

// ── MODAL ─────────────────────────────────────────────────────────────────────
function showModal(correct, wrong, skip) {
  const pct   = Math.round((correct / 45) * 100);
  const grade = pct >= 90 ? 'A' : pct >= 80 ? 'B' : pct >= 70 ? 'C' : 'D';
  const bands = {
    A: "Outstanding! Near-perfect command of scope of practice, certifications, and the healthcare continuum.",
    B: "Great work! Strong grasp of the key concepts. Review any missed questions on scope boundaries.",
    C: "Solid foundation. Focus on supplement rules, HIPAA requirements, and within/outside scope scenarios.",
    D: "Keep studying. Prioritize the scope of practice table and real-world scenarios before your exam."
  };
  const titles = { A:"Excellent Work!", B:"Well Done!", C:"Good Effort!", D:"Keep Studying!" };

  document.getElementById('modal-ring').className   = `modal-grade-ring grade-${grade}`;
  document.getElementById('modal-ring').textContent  = grade;
  document.getElementById('modal-title').textContent = titles[grade];
  document.getElementById('modal-correct').textContent = correct;
  document.getElementById('modal-wrong').textContent   = wrong;
  document.getElementById('modal-skip').textContent    = skip;
  document.getElementById('modal-pct').textContent     = pct + '%';
  document.getElementById('modal-band').textContent    = bands[grade];
  document.getElementById('result-modal').classList.add('open');
}

function closeModal() { document.getElementById('result-modal').classList.remove('open'); }

function retakeQuiz() {
  mcqAnswers = {}; fibAnswers = {}; tfAnswers = {};
  graded = false;
  document.getElementById('result-modal').classList.remove('open');
  document.getElementById('submit-btn').disabled = false;
  renderAll();
  window.scrollTo({ top: document.getElementById('tab-quiz').offsetTop - 80, behavior: 'smooth' });
}

// ── MINDMAP ───────────────────────────────────────────────────────────────────
function buildMindmap() {
  const grid = document.getElementById('mm-grid');
  grid.innerHTML = '';
  MINDMAP.branches.forEach(b => {
    const el = document.createElement('div');
    el.className = 'mm-branch';
    el.innerHTML = `
      <div class="mm-branch-header" onclick="toggleBranch(this)">
        <span class="mm-branch-dot" style="background:${b.color}"></span>
        <span class="mm-branch-name">${b.name}</span>
        <span class="mm-branch-arrow">›</span>
      </div>
      <div class="mm-branch-body">
        <div class="mm-subs">
          ${b.subs.map(s => `
            <div class="mm-sub">
              <div class="mm-sub-name">${s.name}</div>
              <ul class="mm-sub-points">
                ${s.points.map(p => `<li>${p}</li>`).join('')}
              </ul>
            </div>`).join('')}
        </div>
      </div>
    `;
    grid.appendChild(el);
  });
}

function toggleBranch(header) {
  header.closest('.mm-branch').classList.toggle('open');
}

// ── TABS ──────────────────────────────────────────────────────────────────────
function switchTab(name, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => { b.classList.remove('active'); b.classList.remove('glow'); });
  document.getElementById('tab-' + name).classList.add('active');
  btn.classList.add('active');
}

// ── INIT ──────────────────────────────────────────────────────────────────────
buildMindmap();
renderAll();
</script>

</Layout>
