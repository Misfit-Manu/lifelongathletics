// ── STATE ─────────────────────────────────────────────
// ══════════════════════════════════════════════════════
let theoryMCQ    = {};
let fibAnswers   = {};
let tfAnswers    = {};
let theoryGraded = false;

let caseAnswers  = {};
let caseGraded   = false;

// ══════════════════════════════════════════════════════
// ── THEORY QUIZ BUILD ─────────────────────────────────
// ══════════════════════════════════════════════════════
function buildTheoryQuiz() {
  const sec = document.getElementById('theory-mcq-section');
  sec.innerHTML = '';
  const letters = ['A','B','C','D'];
  THEORY.forEach((q, qi) => {
    const card = document.createElement('div');
    card.className = 'q-card';
    card.id = `tq-${qi}`;
    card.innerHTML = `
      <div class="q-num">Question ${qi + 1}</div>
      <div class="q-text">${q.q}</div>
      <div class="q-options">
        ${q.opts.map((o, oi) => `
          <div class="q-option" onclick="pickTheory(${qi},${oi},this)">
            <span class="opt-letter">${letters[oi]}</span>
            <span>${o}</span>
          </div>`).join('')}
      </div>
      <div class="q-exp" id="texp-${qi}"><strong>Explanation</strong>${q.exp}</div>
    `;
    sec.appendChild(card);
  });
}

function buildFIB() {
  const sec = document.getElementById('theory-fib-section');
  sec.innerHTML = '';
  FILLIN.forEach((f, fi) => {
    const card = document.createElement('div');
    card.className = 'fib-card';
    card.innerHTML = `
      <div class="q-num">Fill-in ${fi + 1}</div>
      <div class="fib-q">${f.q}</div>
      <div class="fib-input-wrap">
        <input class="q-input" id="tfib-${fi}" type="text" placeholder="Your answer…" oninput="trackFIB(${fi})">
        <span class="fib-feedback" id="tfib-fb-${fi}"></span>
      </div>
      <div class="fib-hint" id="tfib-hint-${fi}">Hint: ${f.hint}</div>
    `;
    sec.appendChild(card);
  });
}

function buildTF() {
  const sec = document.getElementById('theory-tf-section');
  sec.innerHTML = '';
  TRUEF.forEach((t, ti) => {
    const card = document.createElement('div');
    card.className = 'tf-card';
    card.innerHTML = `
      <div class="q-num">True / False ${ti + 1}</div>
      <div class="tf-q">${t.q}</div>
      <div class="q-tf">
        <button class="q-tf-btn" id="ttf-${ti}-T" onclick="pickTF(${ti},true)">TRUE</button>
        <button class="q-tf-btn" id="ttf-${ti}-F" onclick="pickTF(${ti},false)">FALSE</button>
      </div>
      <div class="tf-exp" id="ttf-exp-${ti}"><strong>Explanation</strong>${t.exp}</div>
    `;
    sec.appendChild(card);
  });
}

function pickTheory(qi, oi, el) {
  if (theoryGraded) return;
  const opts = el.closest('.q-options').querySelectorAll('.q-option');
  opts.forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  theoryMCQ[qi] = oi;
  updateTheoryProgress();
}

function trackFIB(fi) {
  fibAnswers[fi] = document.getElementById(`tfib-${fi}`).value.trim();
  updateTheoryProgress();
}

function pickTF(ti, val) {
  if (theoryGraded) return;
  tfAnswers[ti] = val;
  document.getElementById(`ttf-${ti}-T`).className = 'q-tf-btn' + (val === true  ? ' selected' : '');
  document.getElementById(`ttf-${ti}-F`).className = 'q-tf-btn' + (val === false ? ' selected' : '');
  updateTheoryProgress();
}

function updateTheoryProgress() {
  const mcqDone = Object.keys(theoryMCQ).length;
  const fibDone = Object.values(fibAnswers).filter(v => v.length > 0).length;
  const tfDone  = Object.keys(tfAnswers).length;
  const total   = mcqDone + fibDone + tfDone;
  const pct = Math.round((total / 30) * 100);
  document.getElementById('theory-progress-text').textContent = `${total} of 30 answered`;
  document.getElementById('theory-progress-pct').textContent  = `${pct}%`;
  document.getElementById('theory-prog-bar').style.width       = `${pct}%`;
}

function submitTheory() {
  if (theoryGraded) return;
  theoryGraded = true;
  document.getElementById('theory-submit-btn').disabled = true;

  let mcqC = 0, fibC = 0, tfC = 0;

  THEORY.forEach((q, qi) => {
    const sel  = theoryMCQ[qi];
    const opts = document.querySelectorAll(`#tq-${qi} .q-option`);
    opts.forEach(o => { o.style.pointerEvents = 'none'; });
    if (sel === undefined) {
      opts[q.c].classList.add('reveal-correct');
    } else if (sel === q.c) {
      opts[sel].classList.add('correct-ans');
      mcqC++;
    } else {
      opts[sel].classList.add('wrong-ans');
      opts[q.c].classList.add('reveal-correct');
    }
    document.getElementById(`texp-${qi}`).classList.add('show');
  });

  FILLIN.forEach((f, fi) => {
    const inp = document.getElementById(`tfib-${fi}`);
    inp.disabled = true;
    const val = (fibAnswers[fi] || '').toLowerCase().trim();
    const ans = f.a.toLowerCase();
    const ok  = val === ans || ans.includes(val) || val.includes(ans.split(' ')[0]);
    if (val === '') {
      document.getElementById(`tfib-hint-${fi}`).classList.add('show');
    } else if (ok) {
      inp.classList.add('fib-correct');
      document.getElementById(`tfib-fb-${fi}`).className = 'fib-feedback ok';
      document.getElementById(`tfib-fb-${fi}`).textContent = '✓';
      fibC++;
    } else {
      inp.classList.add('fib-wrong');
      document.getElementById(`tfib-fb-${fi}`).className = 'fib-feedback bad';
      document.getElementById(`tfib-fb-${fi}`).textContent = `✗ ${f.hint}`;
      document.getElementById(`tfib-hint-${fi}`).classList.add('show');
    }
  });

  TRUEF.forEach((t, ti) => {
    const tBtn = document.getElementById(`ttf-${ti}-T`);
    const fBtn = document.getElementById(`ttf-${ti}-F`);
    tBtn.disabled = true; fBtn.disabled = true;
    const sel = tfAnswers[ti];
    if (sel === undefined) {
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
    } else if (sel === t.a) {
      (sel ? tBtn : fBtn).classList.add('tf-correct');
      tfC++;
    } else {
      (sel ? tBtn : fBtn).classList.add('tf-wrong');
      (!sel ? tBtn : fBtn).classList.add('tf-reveal');
    }
    document.getElementById(`ttf-exp-${ti}`).classList.add('show');
  });

  const total = mcqC + fibC + tfC;
  const pct   = Math.round((total / 30) * 100);
  document.getElementById('theory-score-num').textContent = total;
  document.getElementById('theory-score-pct').textContent = pct + '%';
  document.getElementById('theory-rb-mcq').innerHTML = `Theory MCQ <span>${mcqC}/20</span>`;
  document.getElementById('theory-rb-fi').innerHTML  = `Fill-in <span>${fibC}/5</span>`;
  document.getElementById('theory-rb-tf').innerHTML  = `T/F <span>${tfC}/5</span>`;
  const resultEl = document.getElementById('theory-result');
  resultEl.style.display = 'block';
  resultEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function resetTheory() {
  theoryMCQ = {}; fibAnswers = {}; tfAnswers = {};
  theoryGraded = false;
  document.getElementById('theory-submit-btn').disabled = false;
  document.getElementById('theory-result').style.display = 'none';
  buildTheoryQuiz();
  buildFIB();
  buildTF();
  updateTheoryProgress();
  document.getElementById('tab-quiz').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

