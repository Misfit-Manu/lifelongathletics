      { q:"Priya feels dizzy and short of breath before exertion. You should:", opts:["Push through the workout","Stop the session and have her consult her physician","Increase the intensity","Place her supine to rest"], ans:1, exp:"Dizziness and dyspnea before exertion are warning signs; the session should be postponed and the condition discussed with her physician." },
      { q:"She mentions calf pain and swelling. This is:", opts:["A normal training response to ignore","A listed warning sign to stop and seek medical advice","A reason to add more cardio","Only relevant postpartum"], ans:1, exp:"Calf pain or swelling is a recognized ACOG warning sign to discontinue exercise and consult a physician." },
      { q:"If Priya had poorly controlled hypertension, exercise during pregnancy would be:", opts:["Encouraged at high intensity","A contraindication requiring physician management","Unrelated to exercise safety","Only a concern after delivery"], ans:1, exp:"Poorly controlled hypertension (with anemia, seizure disorder, hyperthyroidism) is a contraindication to activity during pregnancy." },
      { q:"For a previously inactive pregnant client, you should:", opts:["Start with 60-minute vigorous sessions","Begin with shorter durations, possibly under 10 minutes, and progress gradually","Begin with maximal lifts","Avoid all exercise entirely"], ans:1, exp:"Previously inactive women should gradually progress to moderate exercise, sometimes in shorter (<10-minute) or intermittent bouts." }
    ]
  },
  { num:5, topic:"Postpartum Return — Dana", scenario:"Dana delivered six weeks ago via C-section and has physician clearance. She is fatigued, breastfeeding, and short on time. She wants to rebuild her fitness.",
    qs:[
      { q:"What is the appropriate progression for Dana's return to exercise?", opts:["Resume pre-pregnancy intensity immediately","Begin slowly and increase duration, then frequency, then intensity","Start with maximal lifts","Avoid exercise for a year"], ans:1, exp:"Begin slowly and gradually increase duration, frequency, and then intensity, toward at least 150 minutes/week." },
      { q:"Given her limited time, a practical format is:", opts:["Single 90-minute sessions","10-minute time blocks, including walking with the baby","Only gym-based 60-minute sessions","No structured activity"], ans:1, exp:"Simple programs in 10-minute blocks and walking (child can come along) help around childcare and schedule limits." },
      { q:"Which consideration is specific to her C-section?", opts:["No extra recovery is needed","Additional recovery time and a physician return-to-activity protocol","Immediate maximal core work","Avoiding all upper-body work permanently"], ans:1, exp:"C-section is highly invasive; healing time varies and the physician should provide a return-to-activity protocol." },
      { q:"To reduce diastasis recti risk, you should include:", opts:["Heavy ballistic crunches","Transverse abdominis and pelvic-floor isometrics with postural work","Maximal Valsalva lifts","Only cardio"], ans:1, exp:"TA and pelvic-floor isometrics plus postural/abdominal strength exercises help reduce diastasis recti." },
      { q:"A realistic expectation for returning to pre-pregnancy intensity is over the next:", opts:["2 weeks","9 to 12 months","2 years","1 month"], ans:1, exp:"A realistic timeframe to return to pre-pregnancy exercise-intensity levels is the subsequent 9 to 12 months." }
    ]
  },
  { num:6, topic:"Older Adult Balance — Harold", scenario:"Harold is 72 with knee arthritis and some balance decline. He wants to stay independent and avoid falls. You set up assessments and a program.",
    qs:[
      { q:"Before the movement assessment, you should begin with:", opts:["Maximal strength testing","Posture and flexibility assessments","A timed sprint","A 1-RM bench press"], ans:1, exp:"Because arthritis is prevalent (49.6% over 65), begin with posture and flexibility assessments before progressing to movement." },
      { q:"For Harold's knee arthritis, instead of a body-weight squat you might assess with:", opts:["A maximal jump","A chair sit-to-stand","A barbell back squat","A sprint test"], ans:1, exp:"A chair sit-to-stand evaluates form and strength while mitigating knee pain." },
      { q:"Which balance test is more prudent to start with for Harold?", opts:["Y balance test","Unipedal stance test near a wall","Maximal single-leg hop","Beam walking blindfolded"], ans:1, exp:"Begin with a unipedal stance test near an external stabilizer rather than starting with the Y balance test." },
      { q:"How often should Harold perform muscular training?", opts:["Never","At least twice each week","Only once per month","Every day with maximal loads"], ans:1, exp:"Older adults should do muscular training at least twice/week to maintain or increase strength and endurance." },
      { q:"Where in the session should balance exercises be placed?", opts:["At the very end when fatigued","Early, when strength and mental focus are highest","Omitted entirely","Only during cool-down"], ans:1, exp:"Balance exercises should be introduced early in the session when the client has the highest strength and focus, reducing injury risk." }
    ]
  },
  { num:7, topic:"Older Adult Cardio & Cognition — Eleanor", scenario:"Eleanor is 68, recently widowed, and worried about memory and mood. She has no major orthopedic issues. You build a program targeting health and well-being.",
    qs:[
      { q:"What moderate cardio target fits Eleanor per HHS guidelines?", opts:["60 to 90 min/week","150 to 300 min/week","300 to 600 min/week","30 min/week"], ans:1, exp:"HHS (2018): older adults should do 150 to 300 min/week moderate or 75 to 150 min/week vigorous activity." },
      { q:"What does the evidence say about exercise and cognition for Eleanor?", opts:["Exercise worsens cognition after 50","Physical activity improves cognitive function in people over 50","Only medication helps cognition","Cognition is unaffected by activity"], ans:1, exp:"Northey et al. (2018) found physical activity improves cognitive function in people over 50, regardless of cognitive status at onset." },
      { q:"Beyond physical benefits, exercise can help Eleanor's mood by:", opts:["Isolating her from others","Providing regular social interaction and human connection","Eliminating all rest","Replacing all medical care"], ans:1, exp:"Exercise settings provide social interaction that helps counter the rise in depression/anxiety and social loss with age." },
      { q:"Which aerobic modality best suits an older adult avoiding orthopedic stress?", opts:["High-impact plyometrics","Walking, aquatic, or stationary-cycle exercise","Maximal sprinting","Heavy box jumps"], ans:1, exp:"Aerobic type should be any modality that does not impose excessive orthopedic stress, such as walking, aquatic, or stationary cycling." },
      { q:"A thorough warm-up is increasingly important for Eleanor because aging brings:", opts:["Increased collagen and elasticity","Decreased collagen content and reduced connective-tissue elasticity","No change in tissues","Faster healing"], ans:1, exp:"Decreased collagen content and reduced elasticity make a thorough warm-up important to reduce injury risk." }
    ]
  }
];

// ── STATE ─────────────────────────────────────────────────────────────────────
let theoryMCQ   = {};
let fibAnswers  = {};
let tfAnswers   = {};
let theoryGraded = false;

let caseAnswers = {};
let caseGraded  = false;

// ── THEORY FUNCTIONS ──────────────────────────────────────────────────────────
function buildTheoryQuiz() {
  const sec = document.getElementById('t-mcq-section');
  sec.innerHTML = '';
  THEORY_MCQ.forEach((q, qi) => {
    const opts = q.opts.map((o, oi) =>
      `<div class="q-option" data-key="tq-${qi}" data-idx="${oi}" onclick="pickTheory(${qi},${oi})">
        <div class="opt-letter">${['A','B','C','D'][oi]}</div>${o}
      </div>`
    ).join('');
    sec.insertAdjacentHTML('beforeend', `
      <div class="q-card" id="tcard-${qi}">
        <div class="q-num">Q${qi + 1}</div>
        <div class="q-text">${q.q}</div>
        <div class="q-options">${opts}</div>
        <div class="q-exp" id="texp-${qi}"><strong>Explanation</strong>${q.exp}</div>
      </div>
    `);
  });
}

function buildFIB() {
  const sec = document.getElementById('t-fib-section');
  sec.innerHTML = '';
  FILLIN.forEach((f, fi) => {
    sec.insertAdjacentHTML('beforeend', `
      <div class="fib-card" id="tfib-card-${fi}">
        <div class="q-num">Q${21 + fi}</div>
        <div class="fib-q">${f.q}</div>
        <div class="fib-input-wrap">
          <input class="q-input" id="tfib-${fi}" type="text" placeholder="Type your answer…"
            oninput="fibAnswers[${fi}]=this.value;updateTheoryProgress()" autocomplete="off"/>
          <span class="fib-feedback" id="tfib-fb-${fi}"></span>
        </div>
        <div class="fib-hint" id="tfib-hint-${fi}"><em>Hint:</em> ${f.hint}</div>
      </div>
    `);
  });
}

function buildTF() {
  const sec = document.getElementById('t-tf-section');
  sec.innerHTML = '';
  TRUEF.forEach((t, ti) => {
    sec.insertAdjacentHTML('beforeend', `
      <div class="tf-card" id="ttf-card-${ti}">
        <div class="q-num">Q${26 + ti}</div>
        <div class="tf-q">${t.q}</div>
        <div class="q-tf">
          <button class="q-tf-btn" id="ttf-${ti}-T" onclick="pickTF(${ti},true)">True</button>
          <button class="q-tf-btn" id="ttf-${ti}-F" onclick="pickTF(${ti},false)">False</button>
        </div>
        <div class="tf-exp" id="ttf-exp-${ti}"><strong>Explanation</strong>${t.exp}</div>
      </div>
    `);
  });
}

function pickTheory(qi, oi) {
  if (theoryGraded) return;
  theoryMCQ[qi] = oi;
  document.querySelectorAll(`[data-key="tq-${qi}"]`).forEach((el, i) => {
    el.classList.toggle('selected', i === oi);
    el.querySelector('.opt-letter').style.background  = (i === oi) ? 'var(--accent)' : '';
    el.querySelector('.opt-letter').style.color       = (i === oi) ? '#000' : '';
    el.querySelector('.opt-letter').style.borderColor = (i === oi) ? 'var(--accent)' : '';
  });
  updateTheoryProgress();
}

function pickTF(ti, val) {
  if (theoryGraded) return;
  tfAnswers[ti] = val;
  document.getElementById(`ttf-${ti}-T`).classList.toggle('selected', val === true);
  document.getElementById(`ttf-${ti}-F`).classList.toggle('selected', val === false);
  updateTheoryProgress();
}

function updateTheoryProgress() {
  let n = Object.keys(theoryMCQ).length;
  FILLIN.forEach((_, fi) => { if (fibAnswers[fi] && fibAnswers[fi].trim()) n++; });
  TRUEF.forEach((_, ti)  => { if (tfAnswers[ti] !== undefined) n++; });
  document.getElementById('t-progress-text').textContent = `${n} of 30 answered`;
  document.getElementById('t-progress-pct').textContent  = `${Math.round(n/30*100)}%`;
  document.getElementById('t-prog-bar').style.width      = `${n/30*100}%`;
}

function submitTheory() {
  if (theoryGraded) return;
  theoryGraded = true;
  document.getElementById('t-submit-btn').disabled = true;

  let mcqC = 0, fibC = 0, tfC = 0;

  THEORY_MCQ.forEach((q, qi) => {
    const sel  = theoryMCQ[qi];
    const opts = document.querySelectorAll(`[data-key="tq-${qi}"]`);
    opts.forEach(el => { el.style.pointerEvents = 'none'; el.classList.remove('selected'); });
    if (sel === undefined) {
      opts[q.c].classList.add('reveal-correct');
    } else if (sel === q.c) {
      mcqC++;
      opts[sel].classList.add('correct-ans');
    } else {
      opts[sel].classList.add('wrong-ans');
      opts[q.c].classList.add('reveal-correct');
    }
    document.getElementById(`texp-${qi}`).classList.add('show');
  });

  FILLIN.forEach((f, fi) => {
    const inp = document.getElementById(`tfib-${fi}`);
    inp.disabled = true;
    const val = (fibAnswers[fi] || '').trim().toLowerCase();
    const ans = f.a.toLowerCase();
    const fb  = document.getElementById(`tfib-fb-${fi}`);
    if (!val) {
      inp.classList.add('fib-wrong');
      fb.textContent = `Answer: ${f.a.toUpperCase()}`;
      fb.className = 'fib-feedback bad';
    } else if (val === ans || ans.includes(val) || val.includes(ans.split(' ')[0])) {
      fibC++;
      inp.classList.add('fib-correct');
      fb.textContent = '✓';
      fb.className = 'fib-feedback ok';
    } else {
      inp.classList.add('fib-wrong');
      fb.textContent = `Answer: ${f.a.toUpperCase()}`;
      fb.className = 'fib-feedback bad';
    }
    document.getElementById(`tfib-hint-${fi}`).classList.add('show');
  });

  TRUEF.forEach((t, ti) => {
    const tBtn = document.getElementById(`ttf-${ti}-T`);
    const fBtn = document.getElementById(`ttf-${ti}-F`);
    [tBtn, fBtn].forEach(b => { b.disabled = true; b.classList.remove('selected'); });
    const sel = tfAnswers[ti];
    if (sel === undefined) {
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
    } else if (sel === t.a) {
      tfC++;
      (sel ? tBtn : fBtn).classList.add('tf-correct');
    } else {
      (sel ? tBtn : fBtn).classList.add('tf-wrong');
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
    }
    document.getElementById(`ttf-exp-${ti}`).classList.add('show');
  });

  const total = mcqC + fibC + tfC;
  document.getElementById('t-score-num').textContent = total;
  document.getElementById('t-rb-mcq').textContent    = `${mcqC}/20`;
  document.getElementById('t-rb-fi').textContent     = `${fibC}/5`;
  document.getElementById('t-rb-tf').textContent     = `${tfC}/5`;
  const result = document.getElementById('theory-result');
  result.classList.add('show');
  result.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function resetTheory() {
  theoryMCQ = {}; fibAnswers = {}; tfAnswers = {}; theoryGraded = false;
  document.getElementById('t-submit-btn').disabled = false;
  document.getElementById('theory-result').classList.remove('show');
  buildTheoryQuiz();
  buildFIB();
  buildTF();
  updateTheoryProgress();
}

// ── CASE FUNCTIONS ────────────────────────────────────────────────────────────
function buildCases() {
  const sec = document.getElementById('c-mcq-section');
  sec.innerHTML = '';
  CASES.forEach((cs, ci) => {
    const block = document.createElement('div');
    block.className = 'case-block';
    block.innerHTML = `
      <div class="case-header">
        <div class="case-num-badge">${cs.num}</div>
        <div class="case-topic-label">${cs.topic}</div>
      </div>
      <div class="scenario-box">${cs.scenario}</div>
    `;
    cs.qs.forEach((q, qi) => {
      const key  = `${ci}-${qi}`;
      const opts = q.opts.map((o, oi) =>
        `<div class="q-option" data-key="cq-${key}" data-idx="${oi}" onclick="pickCase('${key}',${oi})">
          <div class="opt-letter">${['A','B','C','D'][oi]}</div>${o}
        </div>`
      ).join('');
      block.insertAdjacentHTML('beforeend', `
        <div class="q-card" id="ccard-${key}">
          <div class="q-num">Q${ci * 5 + qi + 1}</div>
          <div class="q-text">${q.q}</div>
          <div class="q-options">${opts}</div>
          <div class="q-exp" id="cexp-${key}"><strong>Explanation</strong>${q.exp}</div>
        </div>
      `);
    });
    sec.appendChild(block);
  });
}

function pickCase(key, oi) {
  if (caseGraded) return;
  caseAnswers[key] = oi;
  document.querySelectorAll(`[data-key="cq-${key}"]`).forEach((el, i) => {
    el.classList.toggle('selected', i === oi);
    el.querySelector('.opt-letter').style.background  = (i === oi) ? 'var(--accent)' : '';
    el.querySelector('.opt-letter').style.color       = (i === oi) ? '#000' : '';
    el.querySelector('.opt-letter').style.borderColor = (i === oi) ? 'var(--accent)' : '';
  });
  updateCaseProgress();
}

function updateCaseProgress() {
  const n = Object.keys(caseAnswers).length;
  document.getElementById('c-progress-text').textContent = `${n} of 35 answered`;
  document.getElementById('c-progress-pct').textContent  = `${Math.round(n/35*100)}%`;
  document.getElementById('c-prog-bar').style.width      = `${n/35*100}%`;
}

function submitCases() {
  if (caseGraded) return;
  caseGraded = true;
  document.getElementById('c-submit-btn').disabled = true;

  let correct = 0, wrong = 0, skip = 0;

  CASES.forEach((cs, ci) => {
    cs.qs.forEach((q, qi) => {
      const key  = `${ci}-${qi}`;
      const sel  = caseAnswers[key];
      const opts = document.querySelectorAll(`[data-key="cq-${key}"]`);
      opts.forEach(el => { el.style.pointerEvents = 'none'; el.classList.remove('selected'); });
      if (sel === undefined) {
        skip++;
        opts[q.ans].classList.add('reveal-correct');
      } else if (sel === q.ans) {
        correct++;
        opts[sel].classList.add('correct-ans');
      } else {
        wrong++;
        opts[sel].classList.add('wrong-ans');
        opts[q.ans].classList.add('reveal-correct');
      }
      document.getElementById(`cexp-${key}`).classList.add('show');
    });
  });

  setTimeout(() => showModal(correct, wrong, skip), 350);
}

function retakeCases() {
  caseAnswers = {};
  caseGraded  = false;
  document.getElementById('result-modal').classList.remove('open');
  document.getElementById('c-submit-btn').disabled = false;
  buildCases();
  updateCaseProgress();
}

function showModal(correct, wrong, skip) {
  const pct   = Math.round(correct / 35 * 100);
  const grade = pct >= 90 ? 'A' : pct >= 80 ? 'B' : pct >= 70 ? 'C' : 'D';
  const bands = {
    A: 'Outstanding! Strong command of lifespan programming — youth, pregnancy, postpartum, and older adults.',
    B: 'Great work. Review any wrong answers — check the FITT tables and pregnancy safety rules.',
    C: 'Passing, but worth another review — especially youth bone safety, the supine rule, and older-adult balance.',
    D: 'Needs more study. Re-read the chapter and use the Theory Guide before retaking.'
  };
  const titles = { A:'Excellent Work!', B:'Good Effort!', C:'Keep Going!', D:'Keep Studying!' };

  const ring = document.getElementById('modal-ring');
  ring.textContent = grade;
  ring.className   = `modal-grade-ring grade-${grade}`;
  document.getElementById('modal-title').textContent   = titles[grade];
  document.getElementById('modal-correct').textContent = correct;
  document.getElementById('modal-wrong').textContent   = wrong;
  document.getElementById('modal-skip').textContent    = skip;
  document.getElementById('modal-pct').textContent     = `${pct}%`;
  document.getElementById('modal-band').textContent    = bands[grade];
  document.getElementById('result-modal').classList.add('open');
}

function closeModal() { document.getElementById('result-modal').classList.remove('open'); }

// ── SHARED ────────────────────────────────────────────────────────────────────
function switchTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}

function buildMindmap() {
  const grid = document.getElementById('mm-grid');
  MINDMAP.branches.forEach(branch => {
    const el = document.createElement('div');
    el.className = 'mm-branch';
    el.innerHTML = `
      <div class="mm-branch-header" onclick="toggleBranch(this.parentElement)">
        <div class="mm-branch-dot" style="background:${branch.color}"></div>
        <div class="mm-branch-name">${branch.name}</div>
        <div class="mm-branch-arrow">▶</div>
      </div>
      <div class="mm-branch-body">
        <div class="mm-subs">
          ${branch.subs.map(s => `
            <div class="mm-sub">
              <div class="mm-sub-name">${s.name}</div>
              <ul class="mm-sub-points">
                ${s.points.map(p => `<li>${p}</li>`).join('')}
              </ul>
            </div>
          `).join('')}
        </div>
      </div>
    `;
    grid.appendChild(el);
  });
}

function toggleBranch(branch) { branch.classList.toggle('open'); }

// ── INIT ──────────────────────────────────────────────────────────────────────
buildMindmap();
buildTheoryQuiz();
buildFIB();
buildTF();
buildCases();
</script>

