    <text x="100" y="18" text-anchor="middle" fill="#9fb0c0" font-size="11">muscle shortens · accelerates</text>
    <rect x="40" y="40" width="120" height="26" rx="13" fill="rgba(40,194,160,.25)" stroke="#28c2a0"/>
    <line x1="40" y1="90" x2="160" y2="90" stroke="#46586a"/>
    <path d="M 70 105 L 130 105" stroke="#28c2a0" stroke-width="3" marker-end="url(#ac)" marker-start="url(#ac)"/>
