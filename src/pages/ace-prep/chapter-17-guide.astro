    <text x="100" y="18" text-anchor="middle" fill="#9fb0c0" font-size="11">muscle lengthens · decelerates</text>
    <rect x="20" y="40" width="160" height="26" rx="13" fill="rgba(91,157,255,.22)" stroke="#5b9dff"/>
    <path d="M 100 95 L 30 95 M 100 95 L 170 95" stroke="#5b9dff" stroke-width="3" marker-end="url(#ae)"/>
    <defs><marker id="ae" markerWidth="9" markerHeight="9" refX="5" refY="3" orient="auto"><path d="M0,0 L7,3 L0,6 Z" fill="#5b9dff"/></marker></defs>
    <text x="100" y="118" text-anchor="middle" fill="#8fc0ff" font-size="11">lengthens</text>
  </g>
  <!-- isometric -->
  <g transform="translate(480,40)">
    <text x="100" y="0" text-anchor="middle" fill="#e6c659" font-size="15" font-weight="700">Isometric</text>
