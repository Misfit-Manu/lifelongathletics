---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Chapter 17 — Anatomy & Human Movement | ACE Prep · Lifelong Athletics">

<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>

<style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080808;--bg2:#111;--bg3:#181818;--border:#222;--border2:#2e2e2e;
  --text:#ededec;--muted:#777;--accent:#c5f135;--accent-dim:#9bbf28;
  --correct:#4ade80;--incorrect:#f87171;--warn:#fbbf24;--blue:#60a5fa;--purple:#a78bfa;
  --teal:#22d3ee;--orange:#fb923c;--red:#f87171;
  --font-head:'Playfair Display',Georgia,serif;--font-body:'DM Sans',sans-serif;
  --r:10px;--r2:6px;--trans:0.2s ease;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:15px;line-height:1.7;-webkit-font-smoothing:antialiased}

.hero{max-width:1100px;margin:0 auto;padding:56px 28px 36px}
.breadcrumb{display:flex;gap:8px;align-items:center;font-size:12px;color:var(--muted);margin-bottom:20px}
.breadcrumb a{color:var(--muted);text-decoration:none}.breadcrumb a:hover{color:var(--accent)}.breadcrumb span{color:var(--border2)}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border2);border-radius:20px;padding:5px 14px;font-size:12px;color:var(--muted);margin-bottom:22px}
.hero-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}
.hero h1{font-family:var(--font-head);font-size:clamp(28px,5vw,50px);font-weight:700;line-height:1.1;letter-spacing:-1px;max-width:740px;margin-bottom:16px}
.hero h1 em{font-style:italic;color:var(--accent)}
.hero p{color:var(--muted);max-width:580px;font-size:15px;margin-bottom:28px}
.hero-stats{display:flex;gap:16px;flex-wrap:wrap}
.stat-chip{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 18px}
.stat-chip strong{display:block;font-size:22px;font-weight:600;color:var(--text);font-family:var(--font-head);letter-spacing:-.5px}
.stat-chip span{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px}

.tab-bar{max-width:1100px;margin:0 auto;padding:0 28px;border-bottom:1px solid var(--border)}
.tabs{display:flex;gap:0}
.tab-btn{background:none;border:none;color:var(--muted);font-family:var(--font-body);font-size:13px;font-weight:500;padding:14px 22px;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:var(--trans);display:flex;align-items:center;gap:7px}
.tab-btn:hover{color:var(--text)}.tab-btn.active{color:var(--text);border-bottom-color:var(--accent)}

.content{max-width:1100px;margin:0 auto;padding:36px 28px 80px}
.tab-panel{display:none}.tab-panel.active{display:block}

/* MINDMAP */
.mm-title{font-family:var(--font-head);font-size:13px;font-style:italic;color:var(--muted);margin-bottom:24px}
.mm-center{width:fit-content;margin:0 auto 40px;text-align:center}
.mm-center-node{background:var(--accent);color:#000;font-family:var(--font-head);font-size:16px;font-weight:700;padding:18px 36px;border-radius:50px;display:inline-block;letter-spacing:-.3px}
.mm-center-sub{color:var(--muted);font-size:12px;margin-top:8px}
.mm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px}
.mm-branch{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:var(--trans)}
.mm-branch:hover{border-color:var(--border2)}
.mm-branch-header{padding:16px 20px;display:flex;align-items:center;gap:14px}
.mm-branch-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.mm-branch-name{font-weight:600;font-size:14px;letter-spacing:-.2px;flex:1}
.mm-branch-arrow{color:var(--muted);font-size:12px;transition:transform .25s ease;flex-shrink:0}
.mm-branch.open .mm-branch-arrow{transform:rotate(90deg)}
.mm-branch-body{display:none;padding:0 20px 16px;border-top:1px solid var(--border)}
.mm-branch.open .mm-branch-body{display:block}
.mm-subs{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding-top:14px}
.mm-sub{background:var(--bg3);border-radius:var(--r2);padding:12px}
.mm-sub-name{font-size:12px;font-weight:600;color:var(--accent);margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px}
.mm-sub-points{list-style:none;display:flex;flex-direction:column;gap:4px}
.mm-sub-points li{font-size:12px;color:var(--muted);padding-left:12px;position:relative}
.mm-sub-points li::before{content:'›';position:absolute;left:0;color:var(--border2)}

/* QUIZ SHARED */
.quiz-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:28px}
.quiz-header h2{font-family:var(--font-head);font-size:24px}
.quiz-header h2 em{font-style:italic;color:var(--accent)}
.progress-label{font-size:12px;color:var(--muted);margin-bottom:8px;display:flex;justify-content:space-between}
.progress-bar-wrap{background:var(--bg3);border-radius:20px;height:4px;margin-bottom:28px;overflow:hidden}
.progress-bar{background:var(--accent);height:100%;border-radius:20px;transition:width .5s ease;width:0%}
.section-label{display:flex;align-items:center;gap:10px;margin:36px 0 18px}
.section-label-badge{background:var(--bg3);border:1px solid var(--border2);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--muted)}
.section-label-line{flex:1;height:1px;background:var(--border)}
.section-label-count{font-size:12px;color:var(--muted)}

.case-block{margin-bottom:36px}
.case-header{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.case-num-badge{width:26px;height:26px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#000;flex-shrink:0}
.case-topic-label{font-size:12px;font-weight:700;color:var(--accent);letter-spacing:.05em;text-transform:uppercase}
.scenario-box{background:var(--bg2);border-left:3px solid var(--accent);border-radius:0 var(--r2) var(--r2) 0;padding:14px 18px;color:var(--muted);font-size:13px;line-height:1.7;margin-bottom:18px;font-style:italic}

.q-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px;margin-bottom:12px;transition:var(--trans)}
.q-card:hover{border-color:var(--border2)}
.q-num{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px}
.q-text{font-size:14px;font-weight:500;color:var(--text);margin-bottom:16px;line-height:1.6}
.q-options{display:flex;flex-direction:column;gap:8px}
.q-option{display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-radius:var(--r2);border:1px solid var(--border);background:var(--bg3);cursor:pointer;transition:var(--trans);font-size:13px;color:var(--muted)}
.q-option:hover{border-color:var(--border2);color:var(--text)}
.q-option.selected{border-color:var(--accent);background:rgba(197,241,53,.07);color:var(--text)}
.opt-letter{width:22px;height:22px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;flex-shrink:0;transition:var(--trans)}
.q-option.selected .opt-letter{background:var(--accent);border-color:var(--accent);color:#000}
.q-option.correct-ans{border-color:var(--correct)!important;background:rgba(74,222,128,.08)!important;color:var(--text)!important}
.q-option.wrong-ans{border-color:var(--incorrect)!important;background:rgba(248,113,113,.07)!important}
.q-option.correct-ans .opt-letter{background:var(--correct);border-color:var(--correct);color:#000}
.q-option.wrong-ans .opt-letter{background:var(--incorrect);border-color:var(--incorrect);color:#000}
.q-option.reveal-correct{border-color:rgba(197,241,53,.4)!important;background:rgba(197,241,53,.04)!important}
.q-option.reveal-correct .opt-letter{border-color:rgba(197,241,53,.5)}

.q-exp{display:none;background:rgba(197,241,53,.05);border:1px solid rgba(197,241,53,.15);border-radius:var(--r2);padding:10px 14px;margin-top:10px;font-size:12px;color:var(--accent);line-height:1.55}
.q-exp.show{display:block}
.q-exp strong{color:var(--accent-dim);font-size:11px;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:3px}

.fib-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px;margin-bottom:12px}
.fib-q{font-size:14px;font-weight:500;color:var(--text);line-height:1.65;margin-bottom:12px}
.fib-input-wrap{display:flex;align-items:center;gap:10px}
.q-input{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:14px;outline:none;transition:var(--trans);width:100%;max-width:480px}
.q-input:focus{border-color:var(--border2)}.q-input::placeholder{color:var(--muted)}
.q-input.fib-correct{border-color:var(--correct);background:rgba(74,222,128,.07)}
.q-input.fib-wrong{border-color:var(--incorrect);background:rgba(248,113,113,.06)}
.fib-feedback{font-size:13px;font-weight:700}
.fib-feedback.ok{color:var(--correct)}.fib-feedback.bad{color:var(--incorrect)}
.fib-hint{display:none;font-size:12px;color:var(--muted);margin-top:8px;font-style:italic}
.fib-hint.show{display:block}

.tf-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px;margin-bottom:12px}
.tf-q{font-size:14px;font-weight:500;color:var(--text);line-height:1.55;margin-bottom:14px}
.q-tf{display:flex;gap:10px}
.q-tf-btn{flex:1;max-width:110px;padding:10px;border-radius:var(--r2);border:1px solid var(--border);background:var(--bg3);cursor:pointer;font-family:var(--font-body);font-size:14px;font-weight:600;color:var(--muted);transition:var(--trans);text-align:center}
.q-tf-btn:hover{border-color:var(--border2);color:var(--text)}
.q-tf-btn.selected{border-color:var(--accent);background:rgba(197,241,53,.07);color:var(--text)}
.q-tf-btn.tf-correct{border-color:var(--correct)!important;background:rgba(74,222,128,.08)!important;color:var(--correct)!important}
.q-tf-btn.tf-wrong{border-color:var(--incorrect)!important;background:rgba(248,113,113,.07)!important;color:var(--incorrect)!important}
.q-tf-btn.tf-reveal{border-color:rgba(197,241,53,.4)!important;color:var(--accent)!important;background:rgba(197,241,53,.04)!important}
.tf-exp{display:none;background:rgba(197,241,53,.05);border:1px solid rgba(197,241,53,.15);border-radius:var(--r2);padding:10px 14px;margin-top:10px;font-size:12px;color:var(--accent);line-height:1.55}
.tf-exp.show{display:block}
.tf-exp strong{color:var(--accent-dim);font-size:11px;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:3px}

.quiz-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-top:36px;padding-top:28px;border-top:1px solid var(--border)}
.submit-btn{background:var(--accent);color:#000;border:none;border-radius:30px;padding:14px 36px;font-family:var(--font-body);font-size:14px;font-weight:700;cursor:pointer;transition:var(--trans)}
.submit-btn:hover{background:var(--accent-dim);transform:translateY(-1px)}
.submit-btn:disabled{background:var(--border2);color:var(--muted);cursor:not-allowed;transform:none}
.reset-btn{background:none;border:1px solid var(--border2);color:var(--muted);border-radius:30px;padding:13px 24px;font-family:var(--font-body);font-size:13px;cursor:pointer;transition:var(--trans)}
.reset-btn:hover{border-color:var(--incorrect);color:var(--incorrect)}

/* INLINE THEORY RESULT */
.result-hero{background:var(--bg2);border:1px solid var(--border2);border-radius:var(--r);padding:32px;text-align:center;margin-bottom:32px;display:none}
.result-hero.show{display:block}
.score-display{font-family:var(--font-head);margin-bottom:8px}
.score-num{font-size:64px;font-weight:700;color:var(--accent);line-height:1}
.score-denom{font-size:28px;color:var(--muted)}
.rb-row{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:12px}
.rb-mcq,.rb-fi,.rb-tf{background:var(--bg3);border-radius:var(--r2);padding:8px 14px;font-size:12px;text-align:center;min-width:80px}
.rb-mcq strong,.rb-fi strong,.rb-tf strong{display:block;font-size:18px;font-weight:700;font-family:var(--font-head)}

/* CASE STUDIES MODAL */
#result-modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);backdrop-filter:blur(6px);z-index:200;align-items:center;justify-content:center}
#result-modal.open{display:flex}
.modal-box{background:var(--bg2);border:1px solid var(--border2);border-radius:14px;padding:40px 48px;max-width:480px;width:90%;text-align:center}
.modal-grade-ring{width:96px;height:96px;border-radius:50%;margin:0 auto 20px;display:flex;align-items:center;justify-content:center;font-size:30px;font-weight:900;border:4px solid}
.grade-A{border-color:var(--accent);color:var(--accent);background:rgba(197,241,53,.1)}
.grade-B{border-color:var(--blue);color:var(--blue);background:rgba(96,165,250,.1)}
.grade-C{border-color:var(--warn);color:var(--warn);background:rgba(251,191,36,.1)}
.grade-D{border-color:var(--incorrect);color:var(--incorrect);background:rgba(248,113,113,.1)}
.modal-title{font-family:var(--font-head);font-size:22px;font-weight:700;margin-bottom:6px}
.modal-subtitle{color:var(--muted);font-size:13px;margin-bottom:22px}
.modal-stats{display:flex;justify-content:center;gap:20px;margin-bottom:24px}
.modal-stat .val{font-family:var(--font-head);font-size:28px;font-weight:700}
.modal-stat .lbl{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
.modal-band{background:var(--bg3);border-radius:var(--r2);padding:12px 16px;font-size:13px;color:var(--text);margin-bottom:22px;line-height:1.5}
.modal-actions{display:flex;gap:12px;justify-content:center}
.modal-btn-primary{background:var(--accent);color:#000;border:none;border-radius:30px;padding:12px 28px;font-family:var(--font-body);font-size:13px;font-weight:700;cursor:pointer;transition:var(--trans)}
.modal-btn-primary:hover{background:var(--accent-dim)}
.modal-btn-secondary{background:none;border:1px solid var(--border2);color:var(--muted);border-radius:30px;padding:11px 22px;font-family:var(--font-body);font-size:13px;cursor:pointer;transition:var(--trans)}
.modal-btn-secondary:hover{border-color:var(--incorrect);color:var(--incorrect)}

/* QUICK REFERENCE */
.ref-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-bottom:32px}
.ref-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px}
.ref-card h3{font-family:var(--font-head);font-size:16px;font-weight:600;margin-bottom:14px}
.ref-card h3 em{font-style:italic;color:var(--accent)}
.ref-table{width:100%;border-collapse:collapse;font-size:12px}
.ref-table th{text-align:left;padding:8px 10px;background:var(--bg3);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.ref-table td{padding:9px 10px;border-top:1px solid var(--border);color:var(--text);vertical-align:top;font-size:12px}
.ref-table tr:hover td{background:rgba(255,255,255,.015)}
.key-term{background:var(--bg3);border-radius:var(--r2);padding:12px;margin-bottom:8px}
.key-term strong{font-size:13px;color:var(--accent);display:block;margin-bottom:3px}
.key-term span{font-size:12px;color:var(--muted)}
.tag-up{color:var(--incorrect);font-weight:700}
.tag-dn{color:var(--correct);font-weight:700}
.tag-flat{color:var(--muted)}
.tag-var{color:var(--orange);font-style:italic}

footer{border-top:1px solid var(--border);padding:32px 36px;text-align:center;font-size:12px;color:var(--muted)}

@keyframes breathe{
  0%,100%{transform:scale(1);   box-shadow:0 4px 16px rgba(197,241,53,0.22)}
  50%    {transform:scale(1.03);box-shadow:0 6px 32px rgba(197,241,53,0.52),0 0 48px rgba(197,241,53,0.12)}
}
@keyframes tab-pulse{
  0%,100%{box-shadow:none}
  50%    {box-shadow:inset 0 -2px 0 rgba(197,241,53,0.7),0 2px 10px rgba(197,241,53,0.18)}
}
a.mm-center-node{text-decoration:none;color:#000;cursor:pointer;transform-origin:center;animation:breathe 3s ease-in-out infinite}
a.mm-center-node:hover{animation-play-state:paused;transform:scale(1.05)}
.tab-btn.glow:not(.active){animation:tab-pulse 2.6s ease-in-out 0.5s infinite}

@media(max-width:640px){
  .hero{padding:36px 20px 24px}.content{padding:24px 20px 60px}
  .tab-bar{padding:0 20px}.tab-btn{padding:12px 14px;font-size:12px}
  .mm-subs{grid-template-columns:1fr}
  .modal-box{padding:28px 20px}.modal-stats{gap:12px}
}
</style>

<!-- RESULT MODAL (Case Studies) -->
<div id="result-modal">
  <div class="modal-box">
    <div id="modal-ring" class="modal-grade-ring grade-A">A</div>
    <div class="modal-title" id="modal-title">Excellent Work!</div>
    <div class="modal-subtitle">Chapter 17 — Case Studies (35 MCQ)</div>
    <div class="modal-stats">
      <div class="modal-stat">
        <div class="val" id="modal-correct" style="color:var(--correct)">0</div>
        <div class="lbl">Correct</div>
      </div>
      <div class="modal-stat">
        <div class="val" id="modal-wrong" style="color:var(--incorrect)">0</div>
        <div class="lbl">Wrong</div>
      </div>
      <div class="modal-stat">
        <div class="val" id="modal-skip" style="color:var(--muted)">0</div>
        <div class="lbl">Skipped</div>
      </div>
      <div class="modal-stat">
        <div class="val" id="modal-pct" style="color:var(--accent)">0%</div>
        <div class="lbl">Score</div>
      </div>
    </div>
    <div class="modal-band" id="modal-band"></div>
    <div class="modal-actions">
      <button class="modal-btn-primary" onclick="closeModal()">Review Answers</button>
      <button class="modal-btn-secondary" onclick="retakeCases()">↺ Retake</button>
    </div>
  </div>
</div>

<div class="hero">
  <div class="breadcrumb">
    <a href="/exam-prep">Exam Prep</a><span>›</span>
    <a href="/ace-prep">ACE Hub</a><span>›</span>
    <span>Chapter 17</span>
  </div>
  <div class="hero-badge"><span class="dot"></span>ACE-CPT · Chapter 17</div>
  <h1>Anatomy &amp; <em>Human Movement</em></h1>
  <p>How the human movement system produces motion — planes &amp; axes, joint actions, muscle actions and roles, length-tension, force-couples, levers, and the full muscle reference.</p>
  <div class="hero-stats">
    <div class="stat-chip"><strong>30</strong><span>Theory Quiz</span></div>
    <div class="stat-chip"><strong>35</strong><span>Case Studies</span></div>
    <div class="stat-chip"><strong>65</strong><span>Total Q's</span></div>
  </div>
</div>

<div class="tab-bar">
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('mindmap',this)">📑 Contents</button>
    <button class="tab-btn glow" onclick="switchTab('theory',this)">📝 Quiz (Theory)</button>
    <button class="tab-btn" onclick="switchTab('cases',this)">🩺 Case Studies</button>
    <button class="tab-btn" onclick="switchTab('reference',this)">📋 Quick Reference</button>
  </div>
</div>

<div class="content">

<!-- MIND MAP -->
<div class="tab-panel active" id="tab-mindmap">
  <p class="mm-title">Click any branch to expand. All Chapter 17 concepts mapped.</p>
  <div class="mm-center">
    <a href="/ace-prep/chapter-17-guide" class="mm-center-node">📖 Theory Guide →</a>
    <div class="mm-center-sub">HMS · Planes &amp; Axes · Joint Actions · Muscle Actions · Roles · Length-Tension · Force-Couples · Levers · Muscle Reference</div>
  </div>
  <div class="mm-grid" id="mm-grid"></div>
</div>

<!-- THEORY QUIZ -->
<div class="tab-panel" id="tab-theory">
  <div class="quiz-header">
    <h2>Chapter 17 <em>Theory Quiz</em></h2>
    <button class="reset-btn" onclick="resetTheory()">↺ Reset</button>
  </div>
  <div class="progress-label">
    <span id="t-progress-text">0 of 30 answered</span>
    <span id="t-progress-pct">0%</span>
  </div>
  <div class="progress-bar-wrap"><div class="progress-bar" id="t-prog-bar"></div></div>

  <div class="result-hero" id="theory-result">
    <div class="score-display">
      <span class="score-num" id="t-score-num">0</span><span class="score-denom"> / 30</span>
    </div>
    <div class="rb-row">
      <div class="rb-mcq"><strong id="t-rb-mcq">—</strong>MCQ (20)</div>
      <div class="rb-fi"><strong id="t-rb-fi">—</strong>Fill-In (5)</div>
      <div class="rb-tf"><strong id="t-rb-tf">—</strong>T/F (5)</div>
    </div>
