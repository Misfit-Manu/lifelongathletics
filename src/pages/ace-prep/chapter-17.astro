      { q:"Pronation (the loading phase) occurs with which muscle function?", opts:["Concentric — producing force","Eccentric — decelerating and absorbing force","Isometric — pure stabilization","Reflexive only"], ans:1, exp:"Pronation occurs with eccentric muscle function as the body loads and decelerates multi-segmental motion." },
      { q:"At mid-stance moving into push-off, the subtalar joint:", opts:["Pronates with internal rotation","Supinates with external rotation","Remains pronated","Everts further"], ans:1, exp:"At mid-stance the subtalar joint supinates, with obligatory external rotation of the tibia and femur, to produce push-off force." },
      { q:"Pronation and supination are best described as:", opts:["Single-plane (sagittal) motions","Tri-planar (multiplanar) motions","Frontal-plane-only motions","Non-functional motions"], ans:1, exp:"Both are tri-planar (multiplanar), synchronized joint motions occurring in all three planes simultaneously." }
    ]
  },
  {
    num: 4,
    topic: "Scapular Force-Couple — Overhead Press",
    scenario: "A client is learning the overhead dumbbell press. The trainer cues proper shoulder-blade movement and explains why several muscles must coordinate for the arms to travel safely overhead.",
    qs: [
      { q:"Raising the arms overhead requires upward rotation of the:", opts:["Clavicle only","Scapula","Humerus only","Sternum"], ans:1, exp:"Reaching overhead requires the scapula to upwardly rotate so the glenoid can track the moving humerus." },
      { q:"Which force-couple produces scapular upward rotation?", opts:["Pectoralis major, deltoid, biceps","Upper trapezius, lower trapezius, serratus anterior","Rhomboids, levator scapulae, latissimus","Supraspinatus, infraspinatus, subscapularis"], ans:1, exp:"The upper trapezius, lower trapezius, and serratus anterior form the force-couple that upwardly rotates the scapula." },
      { q:"A force-couple is best defined as:", opts:["A single muscle producing all the force","Two or more muscles pulling in different directions to produce rotation","Two muscles that always oppose each other","A muscle and its tendon working together"], ans:1, exp:"A force-couple is two or more muscles pulling in different directions to rotate a joint — like two hands turning a steering wheel." },
      { q:"Weakness of the serratus anterior would most directly impair:", opts:["Elbow flexion","Upward rotation of the scapula during overhead reaching","Hip extension","Ankle dorsiflexion"], ans:1, exp:"The serratus anterior is part of the scapular upward-rotation couple; weakness disrupts overhead reaching and scapular control." },
      { q:"Pressing the dumbbells straight overhead is predominantly motion in which plane?", opts:["Transverse","Sagittal","Frontal","Horizontal"], ans:1, exp:"Pressing straight overhead is shoulder flexion, a predominantly sagittal-plane motion." }
    ]
  },
  {
    num: 5,
    topic: "Muscle Roles — Hip Extension",
    scenario: "A trainer uses a glute bridge / hip-hinge pattern to teach a client which muscles drive, oppose, assist, and stabilize hip extension.",
    qs: [
      { q:"The prime mover (agonist) for hip extension is the:", opts:["Psoas","Gluteus maximus","Rectus femoris","Adductor longus"], ans:1, exp:"The gluteus maximus is the prime mover for hip extension (and external rotation)." },
      { q:"The hip flexors (e.g., psoas) act as the ________ during hip extension.", opts:["Agonist","Synergist","Antagonist","Stabilizer"], ans:2, exp:"The hip flexors oppose hip extension, making them the antagonists in this pattern." },
      { q:"The hamstrings assisting the gluteus maximus during hip extension act as:", opts:["Antagonists","Synergists","Stabilizers","Prime movers"], ans:1, exp:"The hamstrings assist hip extension, so they act as synergists to the gluteus maximus." },
      { q:"The transversus abdominis and multifidus holding the lumbo-pelvic-hip complex steady act as:", opts:["Agonists","Antagonists","Synergists","Stabilizers"], ans:3, exp:"These deep muscles stabilize the LPHC while the movers and synergists produce hip extension." },
      { q:"The concentric (isolated) action of the gluteus maximus is:", opts:["Hip flexion and internal rotation","Hip extension and external rotation","Knee extension","Ankle plantarflexion"], ans:1, exp:"Concentrically the gluteus maximus accelerates hip extension and external rotation; eccentrically it decelerates hip flexion and internal rotation." }
    ]
  },
  {
    num: 6,
    topic: "Length-Tension & Posture",
    scenario: "A desk-bound client presents with rounded shoulders — chronically shortened chest muscles and a chronically lengthened, weak mid-back. The trainer explains how this affects force production and joint control.",
    qs: [
      { q:"A muscle held chronically lengthened or shortened will:", opts:["Produce more force than normal","Produce less force due to an altered length-tension relationship","Be unaffected","Permanently lose all function"], ans:1, exp:"The length-tension relationship means force drops when a muscle sits chronically away from its optimal length." },
      { q:"The principle relating a muscle's force output to its length is the:", opts:["Force-couple relationship","Length-tension relationship","All-or-none principle","Size principle"], ans:1, exp:"The length-tension relationship describes how a muscle's force depends on its length, peaking at the optimal (resting) length." },
      { q:"A muscle produces its greatest force at:", opts:["Its shortest length","Its longest length","Its optimal (resting) length","Any length equally"], ans:2, exp:"Peak cross-bridge availability — and therefore peak force — occurs at the optimal (resting) length." },
      { q:"Chronically shortened pectorals and a lengthened mid-back can disrupt the normal ________ that rotates the scapula.", opts:["lever system","force-couple","reflex arc","tendon sheath"], ans:1, exp:"Altered length-tension disrupts the scapular force-couple, impairing normal scapular motion and shoulder mechanics." },
      { q:"Restoring normal length-tension relationships and force-couples gives a joint:", opts:["Reduced range of motion","Optimal neuromuscular control","Permanent hypermobility","No measurable change"], ans:1, exp:"Normal length-tension and proper force-couples are what provide a joint with optimal neuromuscular control." }
    ]
  },
  {
    num: 7,
    topic: "Levers & Leverage",
    scenario: "A trainer explains how the body uses leverage to move loads, using a standing calf raise and other examples to illustrate the lever system.",
    qs: [
      { q:"In the human movement system, the bones act as:", opts:["Fulcrums","Levers","The force","The resistance"], ans:1, exp:"Bones act as levers, joints as fulcrums, muscles supply the force, and the body part/weight is the resistance." },
      { q:"The joints act as the:", opts:["Lever","Fulcrum","Force","Load"], ans:1, exp:"Joints serve as the fulcrums (pivot points) around which the bony levers rotate." },
      { q:"Torque — the rotational force around a joint — is equal to:", opts:["Force ÷ distance from the fulcrum","Force × distance from the fulcrum","Mass × acceleration","Force × velocity"], ans:1, exp:"Torque = force × the distance from the fulcrum (the moment arm)." },
      { q:"A standing calf raise — where the ball of the foot is the fulcrum and body weight sits between the fulcrum and the muscle's effort — is an example of a:", opts:["First-class lever","Second-class lever","Third-class lever","Non-lever"], ans:1, exp:"A calf raise is a classic second-class lever: the resistance (body weight) lies between the fulcrum (ball of the foot) and the effort (calf muscles via the Achilles)." },
      { q:"How many classes of levers exist in the human body?", opts:["Two","Three","Four","Five"], ans:1, exp:"There are three classes of levers, defined by the arrangement of fulcrum, effort/force, and load/resistance." }
    ]
  }
];

// ── STATE ─────────────────────────────────────────────────────────────────────
let theoryMCQ   = {};
let fibAnswers  = {};
let tfAnswers   = {};
let theoryGraded = false;

let caseAnswers = {};
let caseGraded  = false;

// ── THEORY FUNCTIONS ──────────────────────────────────────────────────────────
function buildTheoryQuiz() {
  const sec = document.getElementById('t-mcq-section');
  sec.innerHTML = '';
  THEORY_MCQ.forEach((q, qi) => {
    const opts = q.opts.map((o, oi) =>
      `<div class="q-option" data-key="tq-${qi}" data-idx="${oi}" onclick="pickTheory(${qi},${oi})">
        <div class="opt-letter">${['A','B','C','D'][oi]}</div>${o}
      </div>`
    ).join('');
    sec.insertAdjacentHTML('beforeend', `
      <div class="q-card" id="tcard-${qi}">
        <div class="q-num">Q${qi + 1}</div>
        <div class="q-text">${q.q}</div>
        <div class="q-options">${opts}</div>
        <div class="q-exp" id="texp-${qi}"><strong>Explanation</strong>${q.exp}</div>
      </div>
    `);
  });
}

function buildFIB() {
  const sec = document.getElementById('t-fib-section');
  sec.innerHTML = '';
  FILLIN.forEach((f, fi) => {
    sec.insertAdjacentHTML('beforeend', `
      <div class="fib-card" id="tfib-card-${fi}">
        <div class="q-num">Q${21 + fi}</div>
        <div class="fib-q">${f.q}</div>
        <div class="fib-input-wrap">
          <input class="q-input" id="tfib-${fi}" type="text" placeholder="Type your answer…"
            oninput="fibAnswers[${fi}]=this.value;updateTheoryProgress()" autocomplete="off"/>
          <span class="fib-feedback" id="tfib-fb-${fi}"></span>
        </div>
        <div class="fib-hint" id="tfib-hint-${fi}"><em>Hint:</em> ${f.hint}</div>
      </div>
    `);
  });
}

function buildTF() {
  const sec = document.getElementById('t-tf-section');
  sec.innerHTML = '';
  TRUEF.forEach((t, ti) => {
    sec.insertAdjacentHTML('beforeend', `
      <div class="tf-card" id="ttf-card-${ti}">
        <div class="q-num">Q${26 + ti}</div>
        <div class="tf-q">${t.q}</div>
        <div class="q-tf">
          <button class="q-tf-btn" id="ttf-${ti}-T" onclick="pickTF(${ti},true)">True</button>
          <button class="q-tf-btn" id="ttf-${ti}-F" onclick="pickTF(${ti},false)">False</button>
        </div>
        <div class="tf-exp" id="ttf-exp-${ti}"><strong>Explanation</strong>${t.exp}</div>
      </div>
    `);
  });
}

function pickTheory(qi, oi) {
  if (theoryGraded) return;
  theoryMCQ[qi] = oi;
  document.querySelectorAll(`[data-key="tq-${qi}"]`).forEach((el, i) => {
    el.classList.toggle('selected', i === oi);
    el.querySelector('.opt-letter').style.background  = (i === oi) ? 'var(--accent)' : '';
    el.querySelector('.opt-letter').style.color       = (i === oi) ? '#000' : '';
    el.querySelector('.opt-letter').style.borderColor = (i === oi) ? 'var(--accent)' : '';
  });
  updateTheoryProgress();
}

function pickTF(ti, val) {
  if (theoryGraded) return;
  tfAnswers[ti] = val;
  document.getElementById(`ttf-${ti}-T`).classList.toggle('selected', val === true);
  document.getElementById(`ttf-${ti}-F`).classList.toggle('selected', val === false);
  updateTheoryProgress();
}

function updateTheoryProgress() {
  let n = Object.keys(theoryMCQ).length;
  FILLIN.forEach((_, fi) => { if (fibAnswers[fi] && fibAnswers[fi].trim()) n++; });
  TRUEF.forEach((_, ti)  => { if (tfAnswers[ti] !== undefined) n++; });
  document.getElementById('t-progress-text').textContent = `${n} of 30 answered`;
  document.getElementById('t-progress-pct').textContent  = `${Math.round(n/30*100)}%`;
  document.getElementById('t-prog-bar').style.width      = `${n/30*100}%`;
}

function submitTheory() {
  if (theoryGraded) return;
  theoryGraded = true;
  document.getElementById('t-submit-btn').disabled = true;

  let mcqC = 0, fibC = 0, tfC = 0;

  THEORY_MCQ.forEach((q, qi) => {
    const sel  = theoryMCQ[qi];
    const opts = document.querySelectorAll(`[data-key="tq-${qi}"]`);
    opts.forEach(el => { el.style.pointerEvents = 'none'; el.classList.remove('selected'); });
    if (sel === undefined) {
      opts[q.c].classList.add('reveal-correct');
    } else if (sel === q.c) {
      mcqC++;
      opts[sel].classList.add('correct-ans');
    } else {
      opts[sel].classList.add('wrong-ans');
      opts[q.c].classList.add('reveal-correct');
    }
    document.getElementById(`texp-${qi}`).classList.add('show');
  });

  FILLIN.forEach((f, fi) => {
    const inp = document.getElementById(`tfib-${fi}`);
    inp.disabled = true;
    const val = (fibAnswers[fi] || '').trim().toLowerCase();
    const ans = f.a.toLowerCase();
    const fb  = document.getElementById(`tfib-fb-${fi}`);
    if (!val) {
      inp.classList.add('fib-wrong');
      fb.textContent = `Answer: ${f.a.toUpperCase()}`;
      fb.className = 'fib-feedback bad';
    } else if (val === ans || ans.includes(val) || val.includes(ans.split(' ')[0])) {
      fibC++;
      inp.classList.add('fib-correct');
      fb.textContent = '✓';
      fb.className = 'fib-feedback ok';
    } else {
      inp.classList.add('fib-wrong');
      fb.textContent = `Answer: ${f.a.toUpperCase()}`;
      fb.className = 'fib-feedback bad';
    }
    document.getElementById(`tfib-hint-${fi}`).classList.add('show');
  });

  TRUEF.forEach((t, ti) => {
    const tBtn = document.getElementById(`ttf-${ti}-T`);
    const fBtn = document.getElementById(`ttf-${ti}-F`);
    [tBtn, fBtn].forEach(b => { b.disabled = true; b.classList.remove('selected'); });
    const sel = tfAnswers[ti];
    if (sel === undefined) {
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
    } else if (sel === t.a) {
      tfC++;
      (sel ? tBtn : fBtn).classList.add('tf-correct');
    } else {
      (sel ? tBtn : fBtn).classList.add('tf-wrong');
      (t.a ? tBtn : fBtn).classList.add('tf-reveal');
    }
    document.getElementById(`ttf-exp-${ti}`).classList.add('show');
  });

  const total = mcqC + fibC + tfC;
  document.getElementById('t-score-num').textContent = total;
  document.getElementById('t-rb-mcq').textContent    = `${mcqC}/20`;
  document.getElementById('t-rb-fi').textContent     = `${fibC}/5`;
  document.getElementById('t-rb-tf').textContent     = `${tfC}/5`;
  const result = document.getElementById('theory-result');
  result.classList.add('show');
  result.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function resetTheory() {
  theoryMCQ = {}; fibAnswers = {}; tfAnswers = {}; theoryGraded = false;
  document.getElementById('t-submit-btn').disabled = false;
  document.getElementById('theory-result').classList.remove('show');
  buildTheoryQuiz();
  buildFIB();
  buildTF();
  updateTheoryProgress();
}

// ── CASE FUNCTIONS ────────────────────────────────────────────────────────────
function buildCases() {
  const sec = document.getElementById('c-mcq-section');
  sec.innerHTML = '';
  CASES.forEach((cs, ci) => {
    const block = document.createElement('div');
    block.className = 'case-block';
    block.innerHTML = `
      <div class="case-header">
        <div class="case-num-badge">${cs.num}</div>
        <div class="case-topic-label">${cs.topic}</div>
      </div>
      <div class="scenario-box">${cs.scenario}</div>
    `;
    cs.qs.forEach((q, qi) => {
      const key  = `${ci}-${qi}`;
      const opts = q.opts.map((o, oi) =>
        `<div class="q-option" data-key="cq-${key}" data-idx="${oi}" onclick="pickCase('${key}',${oi})">
          <div class="opt-letter">${['A','B','C','D'][oi]}</div>${o}
        </div>`
      ).join('');
      block.insertAdjacentHTML('beforeend', `
        <div class="q-card" id="ccard-${key}">
          <div class="q-num">Q${ci * 5 + qi + 1}</div>
          <div class="q-text">${q.q}</div>
          <div class="q-options">${opts}</div>
          <div class="q-exp" id="cexp-${key}"><strong>Explanation</strong>${q.exp}</div>
        </div>
      `);
    });
    sec.appendChild(block);
  });
}

function pickCase(key, oi) {
  if (caseGraded) return;
  caseAnswers[key] = oi;
  document.querySelectorAll(`[data-key="cq-${key}"]`).forEach((el, i) => {
    el.classList.toggle('selected', i === oi);
    el.querySelector('.opt-letter').style.background  = (i === oi) ? 'var(--accent)' : '';
    el.querySelector('.opt-letter').style.color       = (i === oi) ? '#000' : '';
    el.querySelector('.opt-letter').style.borderColor = (i === oi) ? 'var(--accent)' : '';
  });
  updateCaseProgress();
}

function updateCaseProgress() {
  const n = Object.keys(caseAnswers).length;
  document.getElementById('c-progress-text').textContent = `${n} of 35 answered`;
  document.getElementById('c-progress-pct').textContent  = `${Math.round(n/35*100)}%`;
  document.getElementById('c-prog-bar').style.width      = `${n/35*100}%`;
}

function submitCases() {
  if (caseGraded) return;
  caseGraded = true;
  document.getElementById('c-submit-btn').disabled = true;

  let correct = 0, wrong = 0, skip = 0;

  CASES.forEach((cs, ci) => {
    cs.qs.forEach((q, qi) => {
      const key  = `${ci}-${qi}`;
      const sel  = caseAnswers[key];
      const opts = document.querySelectorAll(`[data-key="cq-${key}"]`);
      opts.forEach(el => { el.style.pointerEvents = 'none'; el.classList.remove('selected'); });
      if (sel === undefined) {
        skip++;
        opts[q.ans].classList.add('reveal-correct');
      } else if (sel === q.ans) {
        correct++;
        opts[sel].classList.add('correct-ans');
      } else {
        wrong++;
        opts[sel].classList.add('wrong-ans');
        opts[q.ans].classList.add('reveal-correct');
      }
      document.getElementById(`cexp-${key}`).classList.add('show');
    });
  });

  setTimeout(() => showModal(correct, wrong, skip), 350);
}

function retakeCases() {
  caseAnswers = {};
  caseGraded  = false;
  document.getElementById('result-modal').classList.remove('open');
  document.getElementById('c-submit-btn').disabled = false;
  buildCases();
  updateCaseProgress();
}

function showModal(correct, wrong, skip) {
  const pct   = Math.round(correct / 35 * 100);
  const grade = pct >= 90 ? 'A' : pct >= 80 ? 'B' : pct >= 70 ? 'C' : 'D';
  const bands = {
    A: 'Outstanding! Strong command of planes, joint actions, muscle actions, roles, and leverage.',
    B: 'Great work. Review any wrong answers — revisit muscle actions (concentric/eccentric) and the pronation/supination chain.',
    C: 'Passing, but worth another review — especially planes & axes, muscle roles, and force-couples.',
    D: 'Needs more study. Re-read the chapter and use the Theory Guide before retaking.'
  };
  const titles = { A:'Excellent Work!', B:'Good Effort!', C:'Keep Going!', D:'Keep Studying!' };

  const ring = document.getElementById('modal-ring');
  ring.textContent = grade;
  ring.className   = `modal-grade-ring grade-${grade}`;
  document.getElementById('modal-title').textContent   = titles[grade];
  document.getElementById('modal-correct').textContent = correct;
  document.getElementById('modal-wrong').textContent   = wrong;
  document.getElementById('modal-skip').textContent    = skip;
  document.getElementById('modal-pct').textContent     = `${pct}%`;
  document.getElementById('modal-band').textContent    = bands[grade];
  document.getElementById('result-modal').classList.add('open');
}

function closeModal() { document.getElementById('result-modal').classList.remove('open'); }

// ── SHARED ────────────────────────────────────────────────────────────────────
function switchTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}

function buildMindmap() {
  const grid = document.getElementById('mm-grid');
  MINDMAP.branches.forEach(branch => {
    const el = document.createElement('div');
    el.className = 'mm-branch';
    el.innerHTML = `
      <div class="mm-branch-header" onclick="toggleBranch(this.parentElement)">
        <div class="mm-branch-dot" style="background:${branch.color}"></div>
        <div class="mm-branch-name">${branch.name}</div>
        <div class="mm-branch-arrow">▶</div>
      </div>
      <div class="mm-branch-body">
        <div class="mm-subs">
          ${branch.subs.map(s => `
            <div class="mm-sub">
              <div class="mm-sub-name">${s.name}</div>
              <ul class="mm-sub-points">
                ${s.points.map(p => `<li>${p}</li>`).join('')}
              </ul>
            </div>
          `).join('')}
        </div>
      </div>
    `;
    grid.appendChild(el);
  });
}

function toggleBranch(branch) { branch.classList.toggle('open'); }

// ── INIT ──────────────────────────────────────────────────────────────────────
buildMindmap();
buildTheoryQuiz();
buildFIB();
buildTF();
buildCases();
</script>

</Layout>
