];

let mcqA=new Array(MCQ.length).fill(null);
let fiA=new Array(FILLIN.length).fill('');
let tfA=new Array(TF.length).fill(null);
let submitted=false;

function switchTab(id,btn){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  btn.classList.add('active');
}

function buildMM(){
  document.getElementById('mm-grid').innerHTML=MINDMAP.branches.map((b,i)=>`
    <div class="mm-branch" id="mmb-${i}" onclick="toggleB(${i})">
      <div class="mm-branch-header">
        <div class="mm-branch-dot" style="background:${b.color}"></div>
        <div class="mm-branch-name">${b.name}</div>
        <div class="mm-branch-arrow">›</div>
      </div>
      <div class="mm-branch-body">
        <div class="mm-subs">${b.subs.map(s=>`
          <div class="mm-sub">
            <div class="mm-sub-name">${s.name}</div>
            <ul class="mm-sub-points">${s.points.map(p=>`<li>${p}</li>`).join('')}</ul>
          </div>`).join('')}
        </div>
      </div>
    </div>`).join('');
}
function toggleB(i){document.getElementById('mmb-'+i).classList.toggle('open')}

function buildQuiz(){
  document.getElementById('mcq-container').innerHTML=MCQ.map((q,i)=>`
    <div class="q-card" id="mcq-${i}">
      <div class="q-num">Q${i+1} of 25 — MCQ</div>
      <div class="q-text">${q.q}</div>
      <div class="q-options">${q.opts.map((o,j)=>`
        <div class="q-option" id="mcq-${i}-${j}" onclick="selMCQ(${i},${j})">
          <div class="opt-letter">${['A','B','C','D'][j]}</div><span>${o}</span>
        </div>`).join('')}
      </div>
      <div class="explanation" id="mcq-exp-${i}">
        <div class="explanation-label">Explanation</div>
        <div class="explanation-text">${q.exp}</div>
      </div>
    </div>`).join('');

  document.getElementById('fillin-container').innerHTML=FILLIN.map((q,i)=>`
    <div class="q-card" id="fi-${i}">
      <div class="q-num">Q${i+1} of 15 — Fill in the Blank</div>
      <div class="q-text">${q.q}</div>
      <input class="q-input" type="text" placeholder="Type your answer…" oninput="fiA[${i}]=this.value;updProg()" id="fi-input-${i}"/>
      <div class="answer-reveal" id="fi-ans-${i}"><div class="answer-reveal-label">✓ Correct Answer</div><div class="answer-reveal-text">${q.a}</div></div>
      <div class="explanation" id="fi-exp-${i}"><div class="explanation-label">Explanation</div><div class="explanation-text">${q.exp}</div></div>
    </div>`).join('');

  document.getElementById('tf-container').innerHTML=TF.map((q,i)=>`
    <div class="q-card" id="tf-${i}">
      <div class="q-num">Q${i+1} of 10 — True / False</div>
      <div class="q-text">${q.q}</div>
      <div class="q-tf">
        <button class="q-tf-btn" id="tf-${i}-true" onclick="selTF(${i},true)">True</button>
        <button class="q-tf-btn" id="tf-${i}-false" onclick="selTF(${i},false)">False</button>
      </div>
      <div class="explanation" id="tf-exp-${i}"><div class="explanation-label">Explanation</div><div class="explanation-text">${q.exp}</div></div>
    </div>`).join('');
}

function buildCases(){
  document.getElementById('cases-container').innerHTML=CASES.map((c,i)=>`
    <div class="case-card">
      <div class="case-header">
        <div class="case-tag">📋 ACE Case Study ${i+1}</div>
        <div class="case-title">${c.title} <em>— ${c.subtitle}</em></div>
      </div>
      <div class="case-body">
        <div class="case-scenario">
          <div class="case-scenario-label">📄 Client Scenario</div>
          <div class="case-scenario-text">${c.scenario}</div>
        </div>
        <div class="case-questions-label">❓ Questions</div>
        <div class="case-questions-text">${c.questions}</div>
        <div class="case-answer-label">Your Answer:</div>
        <textarea class="q-input" rows="7" placeholder="Apply Chapter 9 concepts to this client…" id="case-inp-${i}"></textarea>
        <button class="reveal-btn" id="case-btn-${i}" onclick="toggleAns(${i})">👁 Reveal Model Answer</button>
        <div class="case-model-answer" id="case-ans-${i}">
          <div class="case-model-label">📘 Model Answer</div>
          <div class="case-model-text">${c.answer}</div>
        </div>
      </div>
    </div>`).join('');
}

function toggleAns(i){
  const el=document.getElementById('case-ans-'+i);
  const btn=document.getElementById('case-btn-'+i);
  el.classList.toggle('show');
  btn.textContent=el.classList.contains('show')?'▲ Hide Answer':'👁 Reveal Model Answer';
}

function selMCQ(qi,oi){
  if(submitted)return;
  mcqA[qi]=oi;
  document.querySelectorAll(`#mcq-${qi} .q-option`).forEach((el,j)=>el.classList.toggle('selected',j===oi));
  updProg();
}
function selTF(qi,val){
  if(submitted)return;
  tfA[qi]=val;
  document.getElementById(`tf-${qi}-true`).classList.toggle('selected',val===true);
  document.getElementById(`tf-${qi}-false`).classList.toggle('selected',val===false);
  updProg();
}
function updProg(){
  const tot=mcqA.filter(a=>a!==null).length+fiA.filter(a=>a.trim()!=='').length+tfA.filter(a=>a!==null).length;
  const pct=Math.round((tot/50)*100);
  document.getElementById('progress-text').textContent=`${tot} of 50 answered`;
  document.getElementById('progress-pct').textContent=`${pct}%`;
  document.getElementById('prog-bar').style.width=pct+'%';
}
function submitQuiz(){
  submitted=true;
  let ms=0,fs=0,ts=0;
  MCQ.forEach((q,i)=>{
    const u=mcqA[i];
    document.querySelectorAll(`#mcq-${i} .q-option`).forEach((el,j)=>{
      if(j===q.c)el.classList.add('correct-ans');
      if(u!==null&&j===u&&j!==q.c)el.classList.add('wrong-ans');
    });
    if(u===q.c)ms++;
    document.getElementById(`mcq-exp-${i}`).classList.add('show');
  });
  FILLIN.forEach((q,i)=>{
    const u=(fiA[i]||'').toLowerCase().trim();
    const kws=q.a.toLowerCase().replace(/[();]/g,'').split(/[\s\/,]+/).filter(w=>w.length>3);
    const ok=kws.some(kw=>u.includes(kw));
    if(ok)fs++;
    document.getElementById(`fi-ans-${i}`).classList.add('show');
    document.getElementById(`fi-exp-${i}`).classList.add('show');
    const inp=document.getElementById(`fi-input-${i}`);
    inp.style.borderColor=ok?'var(--correct)':'var(--incorrect)';
    inp.disabled=true;
  });
  TF.forEach((q,i)=>{
    const u=tfA[i];
    const tB=document.getElementById(`tf-${i}-true`);
    const fB=document.getElementById(`tf-${i}-false`);
    (q.a===true?tB:fB).classList.add('correct-ans');
    if(u!==null&&u!==q.a)(u===true?tB:fB).classList.add('wrong-ans');
    if(u===q.a)ts++;
    document.getElementById(`tf-exp-${i}`).classList.add('show');
  });
  const auto=ms+fs+ts;
  const pct=Math.round((auto/50)*100);
  document.getElementById('score-display').textContent=`${auto}/50`;
  document.getElementById('score-label').textContent=`${pct}% — Auto-graded sections`;
  const g=document.getElementById('score-grade');
  if(pct>=80){g.textContent='🏆 Excellent — Exam Ready';g.className='result-grade grade-a';}
  else if(pct>=60){g.textContent='📚 Good — Review Weak Areas';g.className='result-grade grade-b';}
  else{g.textContent='🔄 Needs Work — Re-study Chapter';g.className='result-grade grade-c';}
  document.getElementById('rb-mcq').textContent=`${ms}/25`;
  document.getElementById('rb-fi').textContent=`${fs}/15`;
  document.getElementById('rb-tf').textContent=`${ts}/10`;
  document.getElementById('results').style.display='block';
  document.getElementById('results').scrollIntoView({behavior:'smooth'});
}
function resetQuiz(){
  submitted=false;
  mcqA=new Array(MCQ.length).fill(null);
  fiA=new Array(FILLIN.length).fill('');
  tfA=new Array(TF.length).fill(null);
  buildQuiz();updProg();
  document.getElementById('results').style.display='none';
}
buildMM();buildQuiz();buildCases();updProg();
</script>

</Layout>
