      { q:"ACSM links weight maintenance to roughly how much daily moderate activity?", opts:["~10 minutes/day","~60 minutes/day","~120 minutes/day","~5 minutes/day"], ans:1, exp:"ACSM states weight maintenance is likely associated with about 60 minutes/day of moderate activity (4-5 mph walking)." },
      { q:"A 5% change in body weight for a 200-lb (90.1-kg) person equals about:", opts:["2 lb (0.9 kg)","10 lb (4.5 kg)","20 lb (9.1 kg)","30 lb (13.6 kg)"], ans:1, exp:"5% of 200 lb is a 10-lb (4.5-kg) change, the threshold for clinically significant change." },
      { q:"Which additional training helps preserve lean mass during weight loss?", opts:["Only steady-state cardio","Muscular (resistance) training","Complete rest","Stretching alone"], ans:1, exp:"Muscular training may help maintain lean body mass during periods of weight loss." },
      { q:"Which NWCR habit is most strongly associated with successful maintenance?", opts:["Watching TV more than 10 hr/week","Skipping breakfast","Exercising on average about 1 hour/day","Avoiding all self-weighing"], ans:2, exp:"NWCR members averaged about 1 hour/day of exercise; 78% ate breakfast daily and 75% weighed weekly." }
