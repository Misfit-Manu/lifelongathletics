<header class="hero">
  <div class="hero-badge">Chapter 10 &nbsp;&#183;&nbsp; Muscular Training Assessments</div>
  <h1>The Complete Guide to <em>Muscular Assessments</em></h1>
  <p class="hero-sub">From static posture and balance to 1-RM strength, movement screening, and power — everything you need to evaluate, interpret, and program for real results.</p>
  <div class="hero-meta">
    <span>&#128203; <strong>By Lifelong Athletics</strong></span>
    <span>&#128337; <strong>55 min</strong> read</span>
    <span>&#127919; <strong>10 assessment categories</strong></span>
    <span>&#128200; <strong>Full normative data</strong></span>
  </div>
</header>

<!-- ── STAT STRIP ── -->
<section class="stat-strip">
  <div class="stat-grid">
    <div class="stat-card">
      <div class="stat-number blue">5</div>
      <div class="stat-label">Movement Pattern Categories</div>
    </div>
    <div class="stat-card">
      <div class="stat-number gold">45 sec</div>
      <div class="stat-label">Max Unipedal Stance Duration</div>
    </div>
    <div class="stat-card">
      <div class="stat-number purple">3</div>
      <div class="stat-label">McGill Core Endurance Tests</div>
    </div>
    <div class="stat-card">
      <div class="stat-number green">10</div>
      <div class="stat-label">Max Reps for Submaximal 1-RM</div>
    </div>
    <div class="stat-card">
      <div class="stat-number red">1.9</div>
      <div class="stat-label">Max Flexion:Extension Ratio (Core)</div>
    </div>
  </div>
</section>

