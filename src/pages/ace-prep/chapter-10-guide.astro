---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="The Complete Guide to Muscular Training Assessments | Lifelong Athletics" description="Static posture, movement screens, core endurance, and kinetic-chain compensations — how to assess movement quality before programming.">

<style is:global>
  :root {
    --bg: #0b1120;
    --panel: #0f172a;
    --blue: #14b8a6;
    --gold: #f59e0b;
    --purple: #8b5cf6;
    --green: #10b981;
    --red: #ef4444;
    --text: #e2e8f0;
    --muted: #94a3b8;
    --border: #1e3a5f;
    --panel2: #1a2540;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.8;
    font-size: 1rem;
  }

  /* ── NAV ── */
  .sticky-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11,17,32,0.97);
    border-bottom: 1px solid rgba(20,184,166,0.2);
    padding: 0 24px;
    backdrop-filter: blur(8px);
  }
  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav-inner::-webkit-scrollbar { display: none; }
  .nav-brand {
    font-weight: 800;
    color: var(--blue);
    font-size: 0.95rem;
    letter-spacing: 1px;
    white-space: nowrap;
    padding: 14px 20px 14px 0;
    border-right: 1px solid rgba(255,255,255,0.1);
    margin-right: 16px;
    flex-shrink: 0;
  }
  .nav-inner a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.78rem;
    letter-spacing: 0.5px;
    white-space: nowrap;
    padding: 14px 12px;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .nav-inner a:hover { color: var(--blue); }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, #060c1a 0%, #0a1535 45%, #12082a 100%);
    padding: 110px 24px 90px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid var(--blue);
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 25% 50%, rgba(20,184,166,0.12) 0%, transparent 55%),
      radial-gradient(ellipse at 75% 30%, rgba(139,92,246,0.10) 0%, transparent 55%);
  }
  .hero-badge {
    display: inline-block;
    background: rgba(20,184,166,0.12);
    border: 1px solid rgba(20,184,166,0.4);
    color: var(--blue);
    font-size: 0.72rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 7px 20px;
    border-radius: 100px;
    margin-bottom: 28px;
    position: relative;
  }
  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.9rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    max-width: 820px;
    margin: 0 auto 24px;
    position: relative;
  }
  .hero h1 em { color: var(--blue); font-style: normal; }
  .hero-sub {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 640px;
    margin: 0 auto 44px;
    position: relative;
  }
  .hero-meta {
    display: flex;
    justify-content: center;
    gap: 36px;
    flex-wrap: wrap;
    position: relative;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .hero-meta span { display: flex; align-items: center; gap: 7px; }
  .hero-meta strong { color: var(--gold); }

  /* ── STAT STRIP ── */
  .stat-strip {
    background: var(--panel);
    border-bottom: 1px solid rgba(20,184,166,0.15);
    padding: 36px 24px;
  }
  .stat-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 24px;
  }
  .stat-card {
    text-align: center;
    padding: 20px 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
  }
  .stat-number {
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-label {
    font-size: 0.78rem;
    color: var(--muted);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .blue { color: var(--blue); }
  .gold { color: var(--gold); }
  .purple { color: var(--purple); }
  .green { color: var(--green); }
  .red { color: var(--red); }

  /* ── LAYOUT ── */
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .wide-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── TOC ── */
  .toc-wrap {
    background: var(--panel);
    border: 1px solid rgba(20,184,166,0.2);
    border-radius: 16px;
    padding: 36px 40px;
    margin: 52px auto;
    max-width: 860px;
  }
  .toc-wrap h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--blue);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .toc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 32px;
  }
  @media (max-width: 600px) { .toc-grid { grid-template-columns: 1fr; } }
  .toc-grid a {
    color: var(--text);
    text-decoration: none;
    font-size: 0.92rem;
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    gap: 10px;
    transition: color 0.2s;
  }
  .toc-grid a:hover { color: var(--blue); }
  .toc-num {
    color: var(--blue);
    font-weight: 700;
    font-size: 0.78rem;
    min-width: 24px;
  }

  /* ── SECTIONS ── */
  .section {
    padding: 64px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .section-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }
  .section-bar {
    width: 5px;
    height: 48px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .bar-blue { background: var(--blue); }
  .bar-gold { background: var(--gold); }
  .bar-purple { background: var(--purple); }
  .bar-green { background: var(--green); }
  .bar-red { background: var(--red); }
  .section h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
  }
  .section h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin: 36px 0 14px;
  }
  .section h4 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--blue);
    margin: 28px 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .section p {
    margin-bottom: 18px;
    color: var(--text);
  }
  .section ul, .section ol {
    margin: 0 0 18px 24px;
    color: var(--text);
  }
  .section li { margin-bottom: 8px; }

  /* ── CALLOUT BOXES ── */
  .callout {
    border-radius: 12px;
    padding: 24px 28px;
    margin: 32px 0;
    border-left: 4px solid;
  }
  .callout-blue {
    background: rgba(20,184,166,0.08);
    border-color: var(--blue);
  }
  .callout-purple {
    background: rgba(139,92,246,0.08);
    border-color: var(--purple);
  }
  .callout-red {
    background: rgba(239,68,68,0.08);
    border-color: var(--red);
  }
  .callout-green {
    background: rgba(16,185,129,0.08);
    border-color: var(--green);
  }
  .callout-gold {
    background: rgba(245,158,11,0.08);
    border-color: var(--gold);
  }
  .callout-label {
    font-size: 0.72rem;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .callout-blue .callout-label { color: var(--blue); }
  .callout-purple .callout-label { color: var(--purple); }
  .callout-red .callout-label { color: var(--red); }
  .callout-green .callout-label { color: var(--green); }
  .callout-gold .callout-label { color: var(--gold); }
  .callout p { margin-bottom: 0; }
  .callout p + p { margin-top: 10px; }

  /* ── IMG PLACEHOLDER ── */
  .img-placeholder {
    background: linear-gradient(135deg, #0f172a 0%, #1a2540 100%);
    border: 2px dashed rgba(20,184,166,0.3);
    border-radius: 12px;
    padding: 40px 28px;
    text-align: center;
    margin: 32px 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .img-placeholder .img-icon {
    font-size: 2.8rem;
    margin-bottom: 12px;
    display: block;
    opacity: 0.5;
  }
  .img-placeholder strong {
    display: block;
    color: var(--blue);
    font-size: 0.82rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  /* ── STAT CARDS (inline) ── */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
    margin: 28px 0;
  }
  .stat-mini {
    background: var(--panel);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 18px 16px;
    text-align: center;
  }
  .stat-mini .num {
    font-size: 1.9rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-mini .lbl {
    font-size: 0.76rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* ── TABLES ── */
  .table-wrap {
    overflow-x: auto;
    margin: 28px 0;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.07);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  thead th {
    background: rgba(20,184,166,0.12);
    color: var(--blue);
    font-size: 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid rgba(20,184,166,0.2);
  }
  tbody tr:nth-child(even) { background: rgba(255,255,255,0.02); }
  tbody td {
    padding: 11px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    color: var(--text);
    vertical-align: top;
  }
  tbody tr:last-child td { border-bottom: none; }

  /* ── STEP BLOCK ── */
  .steps {
    counter-reset: step;
    margin: 24px 0;
  }
  .step {
    display: flex;
    gap: 16px;
    margin-bottom: 18px;
    counter-increment: step;
  }
  .step-num {
    width: 32px;
    height: 32px;
    background: var(--blue);
    color: #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .step-body { flex: 1; }
  .step-body strong { display: block; color: #fff; margin-bottom: 4px; }

  /* ── RATIO TABLE ── */
  .ratio-row {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .ratio-label { flex: 1; font-size: 0.9rem; }
  .ratio-val {
    background: rgba(20,184,166,0.1);
    color: var(--blue);
    padding: 4px 12px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  /* ── TAKEAWAYS ── */
  .takeaways {
    background: var(--panel);
    border-top: 3px solid var(--gold);
    padding: 72px 24px;
  }
  .takeaways h2 {
    font-size: 2rem;
    font-weight: 900;
    color: #fff;
    margin-bottom: 12px;
    text-align: center;
  }
  .takeaways .sub {
    color: var(--muted);
    text-align: center;
    margin-bottom: 48px;
  }
  .takeaway-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .takeaway-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px;
    padding: 28px 24px;
  }
  .takeaway-num {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
  }
  .takeaway-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 10px;
  }
  .takeaway-card p { font-size: 0.9rem; color: var(--muted); margin: 0; }

  /* ── FOOTER ── */
  footer {
    background: #060b18;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 40px 24px;
    text-align: center;
    color: var(--muted);
    font-size: 0.85rem;
  }
  footer strong { color: var(--blue); }
  footer .footer-links { margin-top: 12px; }
  footer .footer-links a {
    color: var(--muted);
    text-decoration: none;
    margin: 0 12px;
    font-size: 0.82rem;
  }
  footer .footer-links a:hover { color: var(--blue); }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    .hero { padding: 72px 20px 60px; }
    .section { padding: 44px 0; }
    .toc-wrap { padding: 24px 20px; }
  }

/* === Site-integration fixes (theme preserved) === */
.blog-container { padding: 100px 24px 140px !important; }
@media (max-width: 600px) { .blog-container { padding: 90px 16px 120px !important; } }
h2[id], .section[id], .hero, .takeaways, section[id] { scroll-margin-top: 90px; }

/* Hide source-internal nav + TOC (site Nav provided by Layout) */
.site-nav, .sticky-nav, .toc, .toc-wrap { display: none !important; }

/* Cross-link banner at bottom — uses source palette */
.crosslink-bottom { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-left: 4px solid #c9a84c; border-radius: 12px; padding: 32px 36px; margin: 56px auto 0; max-width: 860px; text-align: center; }
.crosslink-bottom h3 { color: #c9a84c; font-size: 1.2rem; font-weight: 700; margin: 0 0 8px; }
.crosslink-bottom p { color: #94a3b8; font-size: 14px; margin: 0 0 18px; line-height: 1.6; }
.crosslink-bottom a { display: inline-block; background: #c9a84c; color: #0b1120; padding: 12px 28px; border-radius: 24px; font-size: 14px; font-weight: 700; text-decoration: none; transition: background 0.2s, transform 0.2s; }
.crosslink-bottom a:hover { background: #d4b65a; transform: translateY(-2px); }
@media (max-width: 600px) { .crosslink-bottom { padding: 24px 20px; } .crosslink-bottom h3 { font-size: 1.05rem; } }
</style>

