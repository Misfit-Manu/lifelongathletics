---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Chapter 10 — Muscular Training Assessments | ACE Prep · Lifelong Athletics">

<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>

<style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#080808;--bg2:#111;--bg3:#181818;--border:#222;--border2:#2e2e2e;--text:#ededec;--muted:#777;--accent:#c5f135;--accent-dim:#9bbf28;--correct:#4ade80;--incorrect:#f87171;--warn:#fbbf24;--blue:#60a5fa;--purple:#a78bfa;--font-head:'Playfair Display',Georgia,serif;--font-body:'DM Sans',sans-serif;--r:10px;--r2:6px;--trans:0.2s ease}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:15px;line-height:1.7;-webkit-font-smoothing:antialiased}
.hero{max-width:1100px;margin:0 auto;padding:56px 28px 36px}
.breadcrumb{display:flex;gap:8px;align-items:center;font-size:12px;color:var(--muted);margin-bottom:20px}
.breadcrumb a{color:var(--muted);text-decoration:none}.breadcrumb a:hover{color:var(--accent)}.breadcrumb span{color:var(--border2)}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border2);border-radius:20px;padding:5px 14px;font-size:12px;color:var(--muted);margin-bottom:22px}
.hero-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}
.hero h1{font-family:var(--font-head);font-size:clamp(30px,5vw,52px);font-weight:700;line-height:1.1;letter-spacing:-1px;max-width:720px;margin-bottom:16px}
.hero h1 em{font-style:italic;color:var(--accent)}
.hero p{color:var(--muted);max-width:580px;font-size:15px;margin-bottom:28px}
.hero-stats{display:flex;gap:16px;flex-wrap:wrap}
.stat-chip{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 18px}
.stat-chip strong{display:block;font-size:22px;font-weight:600;color:var(--text);font-family:var(--font-head);letter-spacing:-.5px}
.stat-chip span{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px}
.tab-bar{max-width:1100px;margin:0 auto;padding:0 28px;border-bottom:1px solid var(--border)}
.tabs{display:flex}
.tab-btn{background:none;border:none;color:var(--muted);font-family:var(--font-body);font-size:13px;font-weight:500;padding:14px 22px;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:var(--trans);display:flex;align-items:center;gap:7px}
.tab-btn:hover{color:var(--text)}.tab-btn.active{color:var(--text);border-bottom-color:var(--accent)}
.content{max-width:1100px;margin:0 auto;padding:36px 28px 80px}
.tab-panel{display:none}.tab-panel.active{display:block}
.mm-title{font-family:var(--font-head);font-size:13px;font-style:italic;color:var(--muted);margin-bottom:24px}
.mm-center{width:fit-content;margin:0 auto 40px;text-align:center}
.mm-center-node{background:var(--accent);color:#000;font-family:var(--font-head);font-size:16px;font-weight:700;padding:18px 36px;border-radius:50px;display:inline-block;letter-spacing:-.3px}
.mm-center-sub{color:var(--muted);font-size:12px;margin-top:8px}
.mm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px}
.mm-branch{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:var(--trans)}
.mm-branch:hover{border-color:var(--border2)}
.mm-branch-header{padding:16px 20px;display:flex;align-items:center;gap:14px}
.mm-branch-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.mm-branch-name{font-weight:600;font-size:14px;letter-spacing:-.2px;flex:1}
.mm-branch-arrow{color:var(--muted);font-size:12px;transition:transform .25s ease;flex-shrink:0}
.mm-branch.open .mm-branch-arrow{transform:rotate(90deg)}
.mm-branch-body{display:none;padding:0 20px 16px;border-top:1px solid var(--border)}
.mm-branch.open .mm-branch-body{display:block}
.mm-subs{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding-top:14px}
.mm-sub{background:var(--bg3);border-radius:var(--r2);padding:12px}
.mm-sub-name{font-size:12px;font-weight:600;color:var(--accent);margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px}
.mm-sub-points{list-style:none;display:flex;flex-direction:column;gap:4px}
.mm-sub-points li{font-size:12px;color:var(--muted);padding-left:12px;position:relative}
.mm-sub-points li::before{content:"›";position:absolute;left:0;color:var(--border2)}
.quiz-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:28px}
.quiz-header h2{font-family:var(--font-head);font-size:24px}
.quiz-header h2 em{font-style:italic;color:var(--accent)}
.progress-label{font-size:12px;color:var(--muted);margin-bottom:8px;display:flex;justify-content:space-between}
.progress-bar-wrap{background:var(--bg3);border-radius:20px;height:4px;margin-bottom:28px;overflow:hidden}
.progress-bar{background:var(--accent);height:100%;border-radius:20px;transition:width .5s ease;width:0%}
.section-label{display:flex;align-items:center;gap:10px;margin:36px 0 18px}
.section-label-badge{background:var(--bg3);border:1px solid var(--border2);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--muted)}
.section-label-line{flex:1;height:1px;background:var(--border)}
.section-label-count{font-size:12px;color:var(--muted)}
.q-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px;margin-bottom:12px;transition:var(--trans)}
.q-card:hover{border-color:var(--border2)}
.q-num{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px}
.q-text{font-size:14px;font-weight:500;color:var(--text);margin-bottom:16px;line-height:1.6}
.q-options{display:flex;flex-direction:column;gap:8px}
.q-option{display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-radius:var(--r2);border:1px solid var(--border);background:var(--bg3);cursor:pointer;transition:var(--trans);font-size:13px;color:var(--muted)}
.q-option:hover{border-color:var(--border2);color:var(--text)}
.q-option.selected{border-color:var(--accent);background:rgba(197,241,53,.07);color:var(--text)}
.opt-letter{width:22px;height:22px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;flex-shrink:0;transition:var(--trans)}
.q-option.selected .opt-letter{background:var(--accent);border-color:var(--accent);color:#000}
.q-option.correct-ans{border-color:var(--correct)!important;background:rgba(74,222,128,.08)!important;color:var(--text)!important}
.q-option.wrong-ans{border-color:var(--incorrect)!important;background:rgba(248,113,113,.07)!important}
.q-option.correct-ans .opt-letter{background:var(--correct);border-color:var(--correct);color:#000}
.q-option.wrong-ans .opt-letter{background:var(--incorrect);border-color:var(--incorrect);color:#000}
.q-tf{display:flex;gap:10px}
.q-tf-btn{flex:1;padding:12px;border-radius:var(--r2);border:1px solid var(--border);background:var(--bg3);cursor:pointer;font-family:var(--font-body);font-size:14px;font-weight:500;color:var(--muted);transition:var(--trans);text-align:center}
.q-tf-btn:hover{border-color:var(--border2);color:var(--text)}
.q-tf-btn.selected{border-color:var(--accent);background:rgba(197,241,53,.07);color:var(--text)}
.q-tf-btn.correct-ans{border-color:var(--correct)!important;background:rgba(74,222,128,.08)!important;color:var(--correct)!important}
.q-tf-btn.wrong-ans{border-color:var(--incorrect)!important;background:rgba(248,113,113,.07)!important;color:var(--incorrect)!important}
.q-input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:14px;resize:vertical;transition:var(--trans);outline:none}
.q-input:focus{border-color:var(--border2)}.q-input::placeholder{color:var(--muted)}
.explanation{background:var(--bg3);border-left:3px solid var(--accent);border-radius:0 var(--r2) var(--r2) 0;padding:12px 14px;margin-top:12px;display:none}
.explanation.show{display:block}
.explanation-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--accent);margin-bottom:5px}
.explanation-text{font-size:13px;color:var(--muted);line-height:1.6}
.answer-reveal{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r2);padding:11px 14px;margin-top:10px;display:none}
.answer-reveal.show{display:block}
.answer-reveal-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--correct);margin-bottom:4px}
.answer-reveal-text{font-size:13px;color:var(--text)}
.case-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);margin-bottom:20px;overflow:hidden}
.case-header{padding:20px 24px;border-bottom:1px solid var(--border)}
.case-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.3);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:600;color:var(--purple);text-transform:uppercase;letter-spacing:.6px;margin-bottom:12px}
.case-title{font-family:var(--font-head);font-size:18px;font-weight:700}
.case-title em{font-style:italic;color:var(--accent)}
.case-body{padding:24px}
.case-scenario{background:var(--bg3);border-radius:var(--r2);padding:18px;margin-bottom:20px;border-left:3px solid var(--purple)}
.case-scenario-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--purple);margin-bottom:8px}
.case-scenario-text{font-size:13px;color:var(--muted);line-height:1.7;white-space:pre-wrap}
.case-questions-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--warn);margin-bottom:10px}
.case-questions-text{font-size:13px;color:var(--text);line-height:1.8;white-space:pre-wrap;margin-bottom:16px}
.case-answer-label{font-size:12px;color:var(--muted);margin-bottom:8px}
.case-model-answer{background:var(--bg3);border:1px solid rgba(74,222,128,.2);border-radius:var(--r2);padding:18px;margin-top:14px;display:none}
.case-model-answer.show{display:block}
.case-model-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--correct);margin-bottom:10px}
.case-model-text{font-size:13px;color:var(--text);line-height:1.8;white-space:pre-wrap}
.reveal-btn{margin-top:12px;background:none;border:1px solid var(--border2);color:var(--muted);padding:10px 20px;border-radius:20px;cursor:pointer;font-size:13px;font-family:var(--font-body);transition:var(--trans)}
.reveal-btn:hover{border-color:var(--correct);color:var(--correct)}
.quiz-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-top:36px;padding-top:28px;border-top:1px solid var(--border)}
.submit-btn{background:var(--accent);color:#000;border:none;border-radius:30px;padding:14px 36px;font-family:var(--font-body);font-size:14px;font-weight:700;cursor:pointer;transition:var(--trans)}
.submit-btn:hover{background:var(--accent-dim);transform:translateY(-1px)}
.reset-btn{background:none;border:1px solid var(--border2);color:var(--muted);border-radius:30px;padding:13px 24px;font-family:var(--font-body);font-size:13px;cursor:pointer;transition:var(--trans)}
.reset-btn:hover{border-color:var(--incorrect);color:var(--incorrect)}
#results{display:none;margin-top:36px}
.result-hero{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:36px;text-align:center;margin-bottom:28px}
.result-score{font-family:var(--font-head);font-size:clamp(52px,8vw,80px);font-weight:700;color:var(--accent);letter-spacing:-2px;line-height:1}
.result-label{color:var(--muted);font-size:14px;margin-top:8px}
.result-grade{display:inline-block;padding:6px 18px;border-radius:20px;font-size:13px;font-weight:600;margin-top:14px}
.grade-a{background:rgba(74,222,128,.15);color:var(--correct);border:1px solid rgba(74,222,128,.3)}
.grade-b{background:rgba(251,191,36,.15);color:var(--warn);border:1px solid rgba(251,191,36,.3)}
.grade-c{background:rgba(248,113,113,.15);color:var(--incorrect);border:1px solid rgba(248,113,113,.3)}
.result-breakdown{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;margin-bottom:28px}
.rb-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:16px;text-align:center}
.rb-score{font-family:var(--font-head);font-size:26px;font-weight:700}
.rb-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:4px}
.ref-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.ref-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px}
.ref-card h3{font-family:var(--font-head);font-size:16px;font-weight:600;margin-bottom:14px}
.ref-card h3 em{font-style:italic;color:var(--accent)}
.ref-table{width:100%;border-collapse:collapse;font-size:12px}
.ref-table th{text-align:left;padding:8px 10px;background:var(--bg3);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.ref-table td{padding:9px 10px;border-top:1px solid var(--border);color:var(--text);vertical-align:top}
.ref-table tr:hover td{background:rgba(255,255,255,.015)}
.key-term{background:var(--bg3);border-radius:var(--r2);padding:12px;margin-bottom:8px}
.key-term strong{font-size:13px;color:var(--accent);display:block;margin-bottom:3px}
.key-term span{font-size:12px;color:var(--muted)}
footer{border-top:1px solid var(--border);padding:32px 36px;text-align:center;font-size:12px;color:var(--muted)}
/* ELEGANT ANIMATIONS */
@keyframes breathe{
  0%,100%{transform:scale(1);   box-shadow:0 4px 16px rgba(197,241,53,0.22)}
  50%    {transform:scale(1.03);box-shadow:0 6px 32px rgba(197,241,53,0.52),0 0 48px rgba(197,241,53,0.12)}
}
@keyframes tab-pulse{
  0%,100%{box-shadow:none}
  50%    {box-shadow:inset 0 -2px 0 rgba(197,241,53,0.7),0 2px 10px rgba(197,241,53,0.18)}
}
a.mm-center-node{text-decoration:none;color:#000;cursor:pointer;transform-origin:center;animation:breathe 3s ease-in-out infinite}
a.mm-center-node:hover{animation-play-state:paused;transform:scale(1.05)}
.tab-btn.glow:not(.active){animation:tab-pulse 2.6s ease-in-out 0.5s infinite}
@media(max-width:640px){
  .hero{padding:36px 20px 24px}.content{padding:24px 20px 60px}
  .tab-bar{padding:0 20px}.tab-btn{padding:12px 12px;font-size:11px}
  .mm-subs{grid-template-columns:1fr}
}
</style>

<div class="hero">
  <div class="breadcrumb"><a href="/exam-prep">Exam Prep</a><span>›</span><a href="/ace-prep">ACE Hub</a><span>›</span><span>Chapter 10</span></div>
  <div class="hero-badge"><span class="dot"></span>ACE-CPT · Chapter 10</div>
  <h1>Muscular Training <em>Assessments</em></h1>
  <p>Static Posture, Movement Screens, Core Endurance Tests, Kinetic Chain Compensations & ACE Exam Case Studies.</p>
  <div class="hero-stats">
    <div class="stat-chip"><strong>25</strong><span>MCQ</span></div>
    <div class="stat-chip"><strong>15</strong><span>Fill-in</span></div>
    <div class="stat-chip"><strong>10</strong><span>True / False</span></div>
    <div class="stat-chip"><strong>5</strong><span>Case Studies</span></div>
    <div class="stat-chip"><strong>55</strong><span>Total</span></div>
  </div>
</div>
<div class="tab-bar">
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('mindmap',this)">📑 Contents</button>
    <button class="tab-btn glow" onclick="switchTab('quiz',this)">📝 Quiz</button>
    <button class="tab-btn glow" onclick="switchTab('cases',this)">🩺 Case Studies</button>
    <button class="tab-btn" onclick="switchTab('reference',this)">📋 Quick Reference</button>
  </div>
</div>
<div class="content">
<div class="tab-panel active" id="tab-mindmap">
  <p class="mm-title">Click any branch to expand. All Chapter 10 assessment concepts mapped.</p>
  <div class="mm-center">
    <a href="/ace-prep/chapter-10-guide" class="mm-center-node">📖 Theory Guide →</a>
    <div class="mm-center-sub">Static Posture · Movement Screens · Core Endurance · Kinetic Chain</div>
  </div>
  <div class="mm-grid" id="mm-grid"></div>
</div>
<div class="tab-panel" id="tab-quiz">
  <div class="quiz-header">
    <h2>Chapter 10 <em>Quiz</em></h2>
    <button class="reset-btn" onclick="resetQuiz()">↺ Reset</button>
  </div>
  <div class="progress-label"><span id="progress-text">0 of 50 answered</span><span id="progress-pct">0%</span></div>
  <div class="progress-bar-wrap"><div class="progress-bar" id="prog-bar"></div></div>
  <div class="section-label"><div class="section-label-badge">Part A — Multiple Choice</div><div class="section-label-line"></div><div class="section-label-count">25 Questions · 1 pt each</div></div>
  <div id="mcq-container"></div>
  <div class="section-label"><div class="section-label-badge">Part B — Fill in the Blank</div><div class="section-label-line"></div><div class="section-label-count">15 Questions · 1 pt each</div></div>
  <div id="fillin-container"></div>
  <div class="section-label"><div class="section-label-badge">Part C — True / False</div><div class="section-label-line"></div><div class="section-label-count">10 Questions · 1 pt each</div></div>
  <div id="tf-container"></div>
  <div class="quiz-footer">
    <div style="font-size:13px;color:var(--muted)">Submit to see score + explanations.</div>
    <button class="submit-btn" onclick="submitQuiz()">Submit Quiz →</button>
  </div>
  <div id="results">
    <div class="result-hero">
      <div style="font-size:13px;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px">Your Score</div>
      <div class="result-score" id="score-display">—</div>
      <div class="result-label" id="score-label"></div>
      <div class="result-grade" id="score-grade"></div>
    </div>
    <div class="result-breakdown">
      <div class="rb-card"><div class="rb-score" id="rb-mcq" style="color:var(--blue)">—</div><div class="rb-label">MCQ</div></div>
      <div class="rb-card"><div class="rb-score" id="rb-fi" style="color:var(--warn)">—</div><div class="rb-label">Fill-in</div></div>
      <div class="rb-card"><div class="rb-score" id="rb-tf" style="color:var(--correct)">—</div><div class="rb-label">True / False</div></div>
    </div>
  </div>
</div>
<div class="tab-panel" id="tab-cases">
  <div style="margin-bottom:28px">
    <h2 style="font-family:var(--font-head);font-size:24px;margin-bottom:8px">ACE Exam-Style <em style="font-style:italic;color:var(--accent)">Case Studies</em></h2>
    <p style="color:var(--muted);font-size:13px">Apply Chapter 10 assessment knowledge to real client scenarios. Write first, then reveal.</p>
  </div>
  <div id="cases-container"></div>
</div>
<div class="tab-panel" id="tab-reference">
  <div class="ref-grid">
    <div class="ref-card" style="grid-column:1/-1">
      <h3>Single-Leg Squat — <em>5 Rep Protocol</em></h3>
      <table class="ref-table">
        <tr><th>Rep</th><th>Observe</th><th>If Compensated</th><th>Likely Cause</th></tr>
        <tr><td>1st</td><td>Foot stability</td><td>Pronation / supination</td><td>Tight gastroc/soleus; weak tibialis anterior</td></tr>
        <tr><td>2nd</td><td>Knee position</td><td>Valgus &gt;2 inches</td><td>Weak glute med; tight TFL/adductors</td></tr>
        <tr><td>3rd</td><td>Hip lateral tilt</td><td>Contralateral hip drops</td><td>Weak glute med/min on stance leg</td></tr>
        <tr><td>4th</td><td>Torso stability</td><td>Trunk lean to stance side</td><td>Compensation for weak hip abductors</td></tr>
        <tr><td>5th</td><td>Ankle</td><td>Restricted dorsiflexion</td><td>Tight gastroc/soleus</td></tr>
      </table>
    </div>
    <div class="ref-card">
      <h3>Pelvic Tilt <em>Muscle Imbalances</em></h3>
      <table class="ref-table">
        <tr><th>Tilt</th><th>Overactive (Tight)</th><th>Underactive (Weak)</th></tr>
        <tr><td>Anterior</td><td>Hip flexors, erector spinae</td><td>Hamstrings, rectus abdominis</td></tr>
        <tr><td>Posterior</td><td>Hamstrings, rectus abdominis</td><td>Hip flexors, erector spinae</td></tr>
      </table>
    </div>
    <div class="ref-card">
      <h3>Core Endurance <em>Tests</em></h3>
      <div class="key-term"><strong>Trunk Flexor</strong><span>Timed isometric. Tests: rectus abdominis, obliques, transverse abdominis.</span></div>
      <div class="key-term"><strong>Side-Bridge (Lateral)</strong><span>Timed isometric, each side. Tests: TA, obliques, QL, erector spinae. Contraindicated: shoulder pain, acute LBP.</span></div>
      <div class="key-term"><strong>Trunk Extensor</strong><span>Timed isometric. Tests: erector spinae + multifidi. Not for: recent back surgery, major strength deficit.</span></div>
      <div class="key-term"><strong>Key Ratios</strong><span>Right:left side-bridge ≈ 1.0. Side-bridge:extension ratio. Asymmetry &gt;15% = clinically significant.</span></div>
    </div>
    <div class="ref-card">
      <h3>Kinetic Chain <em>Pronation Sequence</em></h3>
      <div class="key-term"><strong>Step 1</strong><span>Tight gastroc/soleus → limited dorsiflexion → calcaneal eversion</span></div>
      <div class="key-term"><strong>Step 2</strong><span>Calcaneal eversion → subtalar pronation → internal tibial rotation</span></div>
      <div class="key-term"><strong>Step 3</strong><span>Internal tibial rotation → internal femoral rotation → knee valgus</span></div>
      <div class="key-term"><strong>Step 4</strong><span>Internal femoral rotation → anterior pelvic tilt → increased lumbar lordosis</span></div>
    </div>
    <div class="ref-card">
      <h3>Assessment <em>Selection Rules</em></h3>
      <div class="key-term"><strong>Thomas Test</strong><span>Contraindicated: low-back pain (unless physician-cleared). Assesses hip flexor length.</span></div>
      <div class="key-term"><strong>Power Assessments</strong><span>Load/Speed Training phase ONLY. Not for general fitness or deconditioned clients.</span></div>
      <div class="key-term"><strong>Squat-to-Stand</strong><span>NOT for deconditioned or frail clients. Lower extremity endurance.</span></div>
      <div class="key-term"><strong>Push-Up Test</strong><span>Men: standard. Women: modified. Upper-body endurance (pec, triceps, ant. delt).</span></div>
    </div>
    <div class="ref-card">
      <h3>Lateral View <em>Plumb Line</em></h3>
      <div class="key-term"><strong>Ankle</strong><span>Slightly anterior to lateral malleolus</span></div>
      <div class="key-term"><strong>Knee</strong><span>Anterior third of knee</span></div>
      <div class="key-term"><strong>Hip</strong><span>Greater trochanter of femur</span></div>
      <div class="key-term"><strong>Shoulder</strong><span>Acromioclavicular (AC) joint</span></div>
      <div class="key-term"><strong>Head</strong><span>Slightly anterior to mastoid process (ear lobe level)</span></div>
    </div>
  </div>
</div>
</div>

