};

const MCQ = [
  { q:"What is the primary focus of Functional Training?", opts:["Building maximum muscular strength","Establishing or reestablishing postural stability and kinetic chain mobility","Improving cardiovascular endurance","Developing athletic speed"], c:1, exp:"Functional Training focuses on establishing or reestablishing postural stability and kinetic chain mobility (neuromotor and flexibility outcomes) through exercise programs that improve joint function." },
  { q:"Which muscle group is the primary focus for functional training exercise selection?", opts:["Large power-generating muscles","Core and balance muscles responsible for stabilizing the spine","Muscles of the extremities only","Cardiovascular system"], c:1, exp:"Exercise selection for Functional Training focuses on core and balance exercises that improve strength and function of muscles responsible for stabilizing the spine." },
  { q:"In functional training program design, which region should be stabilized first?", opts:["The shoulder complex","The knee joint","The lumbar region","The ankle"], c:2, exp:"Programming should begin by promoting stability of the lumbar region through the action and function of the core before progressing to more distal segments." },
  { q:"What tissue property allows tissue to return to its original shape when an applied force is removed?", opts:["Plasticity","Viscoelasticity","Elasticity","Brittleness"], c:2, exp:"Elasticity is the mechanical property that allows tissue to return to its original shape or size when an applied force is removed — often defined as 'temporary deformation'." },
  { q:"The critical point where tissue stretched beyond which it cannot return to normal length is called the:", opts:["Yield point","Breaking point","Plastic limit","Stress point"], c:0, exp:"When tissue is stretched beyond the elastic limit, the yield point is reached. Beyond this point, permanent deformation or 'plastic stretch' occurs." },
  { q:"Which stretching technique does NOT elicit the stretch reflex?", opts:["Ballistic stretching","Static stretching","Bouncing movements","Rapid stretching"], c:1, exp:"Static stretching does not elicit the stretch reflex, reducing the likelihood of injury — one of its key advantages." },
  { q:"What is autogenic inhibition in the context of stretching?", opts:["Reciprocal muscle contraction","Activation of GTO inhibits muscle spindle response","Reduction in blood flow","Prevention of muscle soreness"], c:1, exp:"Autogenic inhibition states that activation of a Golgi tendon organ (GTO) inhibits muscle spindle response, allowing further muscle stretching." },
  { q:"How long should a low-force static stretch be held before GTO activation occurs?", opts:["3–5 seconds","7–10 seconds","15–20 seconds","30+ seconds"], c:1, exp:"After 7–10 seconds of a low-force stretch, the increase in muscle tension activates a GTO response and autogenic inhibition begins." },
  { q:"What is reciprocal inhibition?", opts:["Two muscles contracting simultaneously","Activation of agonist coincides with neural inhibition of antagonist","Prevention of muscle fatigue","Reduction of pain signals"], c:1, exp:"Reciprocal inhibition states that activation of a muscle on one side of a joint (agonist) coincides with neural inhibition of the opposing muscle (antagonist)." },
  { q:"Which stretching technique mimics movement patterns used in upcoming workouts?", opts:["Static stretching","PNF stretching","Dynamic stretching","Ballistic stretching"], c:2, exp:"Dynamic stretching mimics movement patterns to be used in the upcoming workout or sporting event and helps prepare athletes for competition." },
  { q:"What is the recommended frequency for flexibility training per week?", opts:["1 day per week","2–3 days per week with daily being most effective","Only before competition","Once monthly"], c:1, exp:"Evidence-based recommendations suggest 2–3 days per week with daily being most effective for flexibility training." },
  { q:"How long should a static stretch be held for most adults?", opts:["1–5 seconds","10–30 seconds","40–50 seconds","60+ seconds"], c:1, exp:"Holding a static stretch for 10–30 seconds is recommended for most adults. Older individuals may benefit from 30–60 seconds." },
  { q:"What is the primary concern with ballistic stretching in warm-up routines?", opts:["It is too effective","Bouncing movements trigger stretch reflex and may increase injury risk","It is too time-consuming","It only works for elite athletes"], c:1, exp:"Ballistic stretching incorporates bouncing-type movements that usually trigger the stretch reflex and may be associated with increased risk of injury." },
  { q:"Research shows that static stretching in warm-up routines results in:", opts:["Increased muscular strength","No ergogenic benefits and potentially detrimental effects on performance","Improved balance","Faster reaction time"], c:1, exp:"Present research findings suggest no ergogenic benefits and potentially detrimental effects including decreased strength, impaired balance, and diminished reaction time from pre-workout static stretching." },
  { q:"What percentage of maximal force is suggested for the contraction in reciprocal inhibition?", opts:["10–20%","30–50%","Less than 50% of maximal force","75–100%"], c:2, exp:"When a contraction in an agonist is performed at less than 50% of maximal force for more than 6 seconds, the antagonist becomes inhibited." },
  { q:"In an active stretch, who provides the added force?", opts:["A personal trainer","An assistive device","The individual performing the stretch","Gravity only"], c:2, exp:"In an active stretch, the individual applies added force to increase stretch intensity — they are 'actively' involved in the exercise." },
  { q:"What tissue property combines both elastic and plastic behaviors?", opts:["Only elasticity","Only plasticity","Viscoelasticity","Brittleness"], c:2, exp:"Viscoelasticity allows tissues to exhibit both plastic and elastic behaviors — elastic under low loads and plastic under higher loads." },
  { q:"What term describes permanent elongation of stretched tissue?", opts:["Elastic stretch","Plastic stretch or permanent set","Temporary deformation","Stress relaxation"], c:1, exp:"The new state of permanent elongation after stretching tissue beyond its elastic limit is called plastic stretch, permanent set, or permanent deformation." },
  { q:"Which major areas should flexibility programming target?", opts:["Only the hamstrings","Only the quadriceps","Ankles, legs, chest, hips, lower back, neck, shoulders, and trunk","Upper extremities only"], c:2, exp:"Flexibility programming should focus on major tendon units including ankles, anterior and posterior legs, chest, hips, lower back, neck, shoulder girdle, and trunk." },
  { q:"What is 'creep' in the context of stretching?", opts:["Stress relaxation response","Lengthening that occurs when stretch force is applied — collagen remodeling","Elastic deformation","Yield point transition"], c:1, exp:"Creep is the lengthening that occurs when stretch force is applied beyond 10 seconds, with collagen fibers remodeling as they pull apart (plastic deformation)." },
  { q:"How quickly does the muscle spindle reestablish its stretch threshold after stretching ends?", opts:["Immediately","~70% recovery within the first 5 seconds","After 30 seconds","After several minutes"], c:1, exp:"After terminating the stretch, the muscle spindle quickly reestablishes its stretch threshold — approximately 70% recovery within the first 5 seconds." },
  { q:"For PNF stretching, what is the recommended contraction duration?", opts:["1–2 seconds","3–6 seconds","10–15 seconds","30+ seconds"], c:1, exp:"For PNF stretching, a 3–6 second light-to-moderate contraction (20–75% of maximum voluntary contraction) followed by a 10–30 second assisted stretch is desirable." },
  { q:"What is the stress-relaxation response in stretching?", opts:["Immediate muscle tension increase","Progressive decrease in muscle response due to desensitization of muscle spindle","Permanent lengthening","Muscle contraction reflex"], c:1, exp:"Stress-relaxation is the progressive decrease in muscle response due to gradual desensitization of muscle spindle activity as the duration of stretch progresses." },
  { q:"What happens when tissue is stretched beyond its yield point repeatedly over time?", opts:["Tissue returns to normal","Tissue becomes stronger","Chronic tissues become less stable and less efficient — microtrauma accumulates","Muscle hypertrophy occurs"], c:2, exp:"Repetitive microtrauma leads to tissues that are less stable and less efficient. An example is postural changes from prolonged sitting that create chronic tissue deformation." },
  { q:"Where should flexibility exercises be sequenced in a training session?", opts:["Before all other training","Before strength training","After cardiorespiratory and muscular training components","During rest intervals"], c:2, exp:"Research supports sequencing the workout so that flexibility follows cardiorespiratory and muscular training components to avoid detrimental effects on performance." }
];

const FILLIN = [
  { q:"Functional Training focuses on establishing __________ and kinetic chain mobility through exercise programs.", a:"postural stability", exp:"The chapter defines functional training as establishing or reestablishing postural stability and kinetic chain mobility." },
  { q:"The three key tissue properties personal trainers should understand are elasticity, plasticity, and __________.", a:"viscoelasticity", exp:"These three properties determine how tissues respond to stretching and mechanical stress." },
  { q:"__________ is the mechanical property that allows tissue to return to its original shape when force is removed.", a:"elasticity", exp:"Elasticity enables temporary deformation where tissue returns to normal upon force removal." },
  { q:"The point where tissue can no longer return to its normal length after being stretched is called the __________.", a:"elastic limit or yield point", exp:"Beyond the elastic limit, permanent deformation or plastic stretch occurs in the tissue." },
  { q:"__________ is defined as permanent elongation or deformation of stretched tissue.", a:"plastic stretch or permanent set", exp:"This occurs when tissue is stretched beyond its elastic limit and maintains a new resting length." },
  { q:"A __________ is performed by moving joints to place target muscles in an end-range position and holding.", a:"static stretch", exp:"Static stretches are held for up to 30 seconds and are the most commonly practiced flexibility technique." },
  { q:"__________ stretching mimics movement patterns to be used in upcoming workouts or sporting events.", a:"dynamic", exp:"Dynamic stretching is commonly used to prepare athletes by increasing sport-specific flexibility." },
  { q:"In __________ stretching, a partner or assistive device provides the added force for the stretch.", a:"passive", exp:"Passive stretches contrast with active stretches, where the individual provides the force." },
  { q:"The principle stating that activation of GTO inhibits muscle spindle response is called __________.", a:"autogenic inhibition", exp:"This neurological principle allows muscles to relax further during stretching after 7–10 seconds." },
  { q:"__________ inhibition is the principle where contraction of an agonist muscle inhibits the opposing antagonist.", a:"reciprocal", exp:"This allows the antagonist to be stretched more effectively during active movements." },
  { q:"The recommended frequency for flexibility training is __________ days per week, with daily being most effective.", a:"2-3", exp:"Evidence-based recommendations support 2–3 days per week minimum for flexibility training." },
  { q:"For most adults, a static stretch should be held for __________.", a:"10-30 seconds", exp:"Older individuals may benefit from holding for 30–60 seconds for greater benefit." },
  { q:"The lengthening that occurs when stretch force is applied beyond 10 seconds is called __________.", a:"creep", exp:"Creep results from collagen fibers remodeling as they pull apart under sustained tension." },
  { q:"For PNF stretching, a __________ second contraction should be followed by an assisted stretch.", a:"3-6", exp:"The contraction should be at 20–75% of maximum voluntary contraction strength." },
  { q:"__________ stretching incorporates bouncing-type movements and can trigger the stretch reflex.", a:"ballistic", exp:"Due to increased injury risk, ballistic stretching has not been widely advocated in modern training." }
];

const TF = [
  { q:"Functional Training should be discontinued once clients progress to Movement Training and Load/Speed Training.", a:false, exp:"It is important to still include Functional Training exercises in workouts as clients progress — in warm-up, cool-down, or as progressive challenge." },
  { q:"Elasticity describes the property that allows permanent tissue deformation.", a:false, exp:"Elasticity allows tissue to return to original shape (temporary deformation). Plasticity describes permanent deformation." },
  { q:"Static stretching can be performed either actively or passively.", a:true, exp:"Active stretches use force applied by the individual; passive stretches use external force from a partner or device." },
  { q:"The stretch reflex is NOT elicited during static stretching when performed correctly.", a:true, exp:"This is a major advantage of static stretching — it reduces the likelihood of injury." },
  { q:"Autogenic inhibition begins immediately when a stretch is applied.", a:false, exp:"GTO activation and autogenic inhibition occur after 7–10 seconds of low-force stretching, not immediately." },
  { q:"Dynamic stretching is recommended as part of warm-up before athletic competition.", a:true, exp:"Dynamic stretching mimics movement patterns and helps prepare tissues for upcoming physical exertion." },
  { q:"Static stretching in warm-up routines has shown to improve muscular strength and power.", a:false, exp:"Research shows static stretching in warm-up produces no ergogenic benefits and potentially detrimental effects on strength and power." },
  { q:"Most body tissues exhibit purely elastic OR purely plastic behavior, never both.", a:false, exp:"Most structures in the body exhibit viscoelasticity — combining both elastic and plastic properties." },
  { q:"PNF stretching utilizes both reciprocal and autogenic inhibition principles.", a:true, exp:"PNF technique takes advantage of both neurological principles, making it highly effective for flexibility gains." },
  { q:"Flexibility exercises should ideally be performed BEFORE cardiovascular and muscular training.", a:false, exp:"Research supports flexibility exercises following cardiorespiratory and muscular training — not before — to avoid performance decrements." }
];

const SUBJ = [
  { q:"Explain the progression of functional training from the lumbar region to distal extremities. Why is this sequence critical?", a:"Functional training must begin by establishing stability of the lumbar region through core function. Once the individual demonstrates ability to stabilize this region, the program progresses distally: first to hips and thoracic spine (both primarily mobile), then to the scapulothoracic region, then to lumbopelvic/shoulder regions, and finally to distal extremities. This proximal-to-distal progression is critical because attempting to improve mobility in distal joints WITHOUT developing proximal stability compromises movement efficiency and increases injury risk. Proximal stability provides the foundation for safe, effective distal mobility." },
  { q:"Compare and contrast static and dynamic stretching in terms of mechanism, application, and evidence-based outcomes.", a:"Static stretching holds an end-range position for 10–30 seconds. It activates GTO for autogenic inhibition after 7–10 seconds, allowing deeper stretching through plastic deformation. It doesn't elicit the stretch reflex. However, research shows detrimental effects (decreased strength, impaired balance) when used pre-workout. Dynamic stretching mimics upcoming movement patterns, activates neuromuscular patterns through reciprocal inhibition, and is recommended for warm-up. Dynamic is evidence-preferred pre-activity; static is best post-workout for chronic ROM improvements." },
  { q:"Describe the relationship between tissue elasticity, plasticity, and viscoelasticity in the context of flexibility training.", a:"Elasticity allows tissue to return to its original shape when force is removed (temporary deformation). Plasticity describes permanent deformation that remains after force removal. Viscoelasticity combines both — tissues exhibit elastic behavior under low loads and plastic behavior under higher or prolonged loads. In flexibility training, initial stretching activates elastic properties (stress-relaxation), while sustained stretching beyond 7–10 seconds engages plastic deformation (creep and collagen remodeling). Understanding these properties allows trainers to design protocols that produce acute improvements and chronic ROM adaptations." },
  { q:"Explain the neurophysiological mechanisms of autogenic and reciprocal inhibition and how each is applied in specific stretching techniques.", a:"Autogenic inhibition occurs when GTO activation after 7–10 seconds of low-force stretch inhibits muscle spindle activity, temporarily reducing muscle tension and allowing deeper stretching (creep). This is central to static stretching. Reciprocal inhibition works by having an agonist contract at <50% maximum force for 6–15 seconds, neurally inhibiting the opposing antagonist — allowing it to be stretched. PNF combines both: a 3–6 second contraction uses reciprocal inhibition, and the subsequent assisted stretch triggers autogenic inhibition. Dynamic stretching primarily uses reciprocal inhibition through active movement patterns." },
  { q:"Design a complete flexibility program for an adult client using the FITT-VP principle, based on the evidence-based recommendations in this chapter.", a:"Frequency: 2–3 days/week minimum (daily for best results). Intensity: Stretch to point of tightness or slight discomfort — never pain. Time: 10–30 sec per static stretch (30–60 sec for older adults); PNF = 3–6 sec contraction + 10–30 sec assisted stretch; target 60 total seconds per exercise; 2–4 reps per exercise. Type: Combination of static, dynamic, and PNF for all major muscle-tendon units. Volume: 60 sec total per exercise with 2–4 repetitions. Pattern: AFTER cardiorespiratory and muscular training — never as a pre-workout warm-up. Warm muscles first through light aerobic activity or external heat." }
];

let mcqAnswers  = new Array(MCQ.length).fill(null);
let fiAnswers   = new Array(FILLIN.length).fill('');
let tfAnswers   = new Array(TF.length).fill(null);
let subjAnswers = new Array(SUBJ.length).fill('');
let submitted   = false;

function switchTab(id, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + id).classList.add('active');
  btn.classList.add('active');
}

function buildMindmap() {
  const grid = document.getElementById('mm-grid');
  grid.innerHTML = MINDMAP.branches.map((b,i) => `
    <div class="mm-branch" id="mmb-${i}" onclick="toggleBranch(${i})">
      <div class="mm-branch-header">
        <div class="mm-branch-dot" style="background:${b.color}"></div>
        <div class="mm-branch-name">${b.name}</div>
        <div class="mm-branch-arrow">›</div>
      </div>
      <div class="mm-branch-body">
        <div class="mm-subs">
          ${b.subs.map(s => `
            <div class="mm-sub">
              <div class="mm-sub-name">${s.name}</div>
              <ul class="mm-sub-points">${s.points.map(p => `<li>${p}</li>`).join('')}</ul>
            </div>
          `).join('')}
        </div>
      </div>
    </div>
  `).join('');
}

function toggleBranch(i) {
  document.getElementById('mmb-' + i).classList.toggle('open');
}

function buildQuiz() {
  document.getElementById('mcq-container').innerHTML = MCQ.map((q,i) => `
    <div class="q-card" id="mcq-${i}">
      <div class="q-num">Question ${i+1} of 25 — MCQ</div>
      <div class="q-text">${q.q}</div>
      <div class="q-options">
        ${q.opts.map((o,j) => `
          <div class="q-option" id="mcq-${i}-${j}" onclick="selectMCQ(${i},${j})">
            <div class="opt-letter">${['A','B','C','D'][j]}</div>
            <span>${o}</span>
          </div>
        `).join('')}
      </div>
      <div class="explanation" id="mcq-exp-${i}">
        <div class="explanation-label">Explanation</div>
        <div class="explanation-text">${q.exp}</div>
      </div>
    </div>
  `).join('');

  document.getElementById('fillin-container').innerHTML = FILLIN.map((q,i) => `
    <div class="q-card" id="fi-${i}">
      <div class="q-num">Question ${i+1} of 15 — Fill in the Blank</div>
      <div class="q-text">${q.q}</div>
      <input class="q-input" type="text" placeholder="Type your answer…"
        oninput="fiAnswers[${i}]=this.value;updateProgress()" id="fi-input-${i}"/>
      <div class="answer-reveal" id="fi-ans-${i}">
        <div class="answer-reveal-label">✓ Correct Answer</div>
        <div class="answer-reveal-text">${q.a}</div>
      </div>
      <div class="explanation" id="fi-exp-${i}">
        <div class="explanation-label">Explanation</div>
        <div class="explanation-text">${q.exp}</div>
      </div>
    </div>
  `).join('');

  document.getElementById('tf-container').innerHTML = TF.map((q,i) => `
    <div class="q-card" id="tf-${i}">
      <div class="q-num">Question ${i+1} of 10 — True / False</div>
      <div class="q-text">${q.q}</div>
      <div class="q-tf">
        <button class="q-tf-btn" id="tf-${i}-true" onclick="selectTF(${i},true)">True</button>
        <button class="q-tf-btn" id="tf-${i}-false" onclick="selectTF(${i},false)">False</button>
      </div>
      <div class="explanation" id="tf-exp-${i}">
        <div class="explanation-label">Explanation</div>
        <div class="explanation-text">${q.exp}</div>
      </div>
    </div>
  `).join('');

  document.getElementById('subj-container').innerHTML = SUBJ.map((q,i) => `
    <div class="q-card" id="subj-${i}">
      <div class="q-num">Question ${i+1} of 5 — Subjective</div>
      <div class="q-text">${q.q}</div>
      <textarea class="q-input" rows="5" placeholder="Write your answer. Model answer revealed on submit…"
        oninput="subjAnswers[${i}]=this.value;updateProgress()" id="subj-input-${i}"></textarea>
      <div class="answer-reveal" id="subj-ans-${i}">
        <div class="answer-reveal-label">📘 Model Answer</div>
        <div class="answer-reveal-text" style="white-space:pre-wrap">${q.a}</div>
      </div>
    </div>
  `).join('');
}

function selectMCQ(qi, oi) {
  if (submitted) return;
  mcqAnswers[qi] = oi;
  document.querySelectorAll(`#mcq-${qi} .q-option`).forEach((el,j) => el.classList.toggle('selected', j===oi));
  updateProgress();
}

function selectTF(qi, val) {
  if (submitted) return;
  tfAnswers[qi] = val;
  document.getElementById(`tf-${qi}-true`).classList.toggle('selected', val===true);
  document.getElementById(`tf-${qi}-false`).classList.toggle('selected', val===false);
  updateProgress();
}

function updateProgress() {
  const total = mcqAnswers.filter(a=>a!==null).length + fiAnswers.filter(a=>a.trim()!=='').length + tfAnswers.filter(a=>a!==null).length + subjAnswers.filter(a=>a.trim()!=='').length;
  const pct = Math.round((total/55)*100);
  document.getElementById('progress-text').textContent = `${total} of 55 answered`;
  document.getElementById('progress-pct').textContent = `${pct}%`;
  document.getElementById('prog-bar').style.width = pct + '%';
}

function submitQuiz() {
  submitted = true;
  let mcqScore=0, fiScore=0, tfScore=0;

  MCQ.forEach((q,i) => {
    const u = mcqAnswers[i];
    document.querySelectorAll(`#mcq-${i} .q-option`).forEach((el,j) => {
      if (j===q.c) el.classList.add('correct-ans');
      if (u!==null && j===u && j!==q.c) el.classList.add('wrong-ans');
    });
    if (u===q.c) mcqScore++;
    document.getElementById(`mcq-exp-${i}`).classList.add('show');
  });

  FILLIN.forEach((q,i) => {
    const u = (fiAnswers[i]||'').toLowerCase().trim();
    const kws = q.a.toLowerCase().replace(/[()]/g,'').split(/[\s\/,]+/).filter(w=>w.length>3);
    const ok = kws.some(kw=>u.includes(kw));
    if (ok) fiScore++;
    document.getElementById(`fi-ans-${i}`).classList.add('show');
    document.getElementById(`fi-exp-${i}`).classList.add('show');
    const inp = document.getElementById(`fi-input-${i}`);
    inp.style.borderColor = ok ? 'var(--correct)' : 'var(--incorrect)';
    inp.disabled = true;
  });

  TF.forEach((q,i) => {
    const u = tfAnswers[i];
    const tB = document.getElementById(`tf-${i}-true`);
    const fB = document.getElementById(`tf-${i}-false`);
    (q.a===true ? tB : fB).classList.add('correct-ans');
    if (u!==null && u!==q.a) (u===true ? tB : fB).classList.add('wrong-ans');
    if (u===q.a) tfScore++;
    document.getElementById(`tf-exp-${i}`).classList.add('show');
  });

  SUBJ.forEach((_,i) => {
    document.getElementById(`subj-ans-${i}`).classList.add('show');
    document.getElementById(`subj-input-${i}`).disabled = true;
  });

  const auto = mcqScore + fiScore + tfScore;
  const pct  = Math.round((auto/50)*100);
  document.getElementById('score-display').textContent = `${auto}/50`;
  document.getElementById('score-label').textContent = `${pct}% auto-graded · Review subjective answers manually`;
  const g = document.getElementById('score-grade');
  if (pct>=80){ g.textContent='🏆 Excellent — Exam Ready'; g.className='result-grade grade-a'; }
  else if (pct>=60){ g.textContent='📚 Good — Review Weak Areas'; g.className='result-grade grade-b'; }
  else { g.textContent='🔄 Needs Work — Re-study Chapter'; g.className='result-grade grade-c'; }
  document.getElementById('rb-mcq').textContent = `${mcqScore}/25`;
  document.getElementById('rb-fi').textContent  = `${fiScore}/15`;
  document.getElementById('rb-tf').textContent  = `${tfScore}/10`;
  document.getElementById('results').style.display = 'block';
  document.getElementById('results').scrollIntoView({behavior:'smooth'});
}

function resetQuiz() {
  submitted=false;
  mcqAnswers=new Array(MCQ.length).fill(null);
  fiAnswers=new Array(FILLIN.length).fill('');
  tfAnswers=new Array(TF.length).fill(null);
  subjAnswers=new Array(SUBJ.length).fill('');
  buildQuiz(); updateProgress();
  document.getElementById('results').style.display='none';
}

buildMindmap(); buildQuiz(); updateProgress();
</script>

</Layout>
