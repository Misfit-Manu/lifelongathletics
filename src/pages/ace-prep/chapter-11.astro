        { name:"Time & Volume", points:["10–30 sec static","30–60 sec for older adults","60 sec total per exercise","2–4 reps per exercise"] },
        { name:"Timing (Critical!)", points:["AFTER cardio/strength training","Static BEFORE = harms performance","Dynamic OK for warm-up","Warm muscles first"] },
        { name:"Target Areas", points:["Ankles, legs (ant. & post.)","Chest, hips, lower back","Neck, shoulder girdle, trunk","All major tendon units"] }
