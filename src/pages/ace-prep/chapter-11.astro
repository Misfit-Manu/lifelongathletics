      subs:[
        { name:"Definition & Purpose", points:["Establish postural stability","Kinetic chain mobility","Improve joint function","Neuromotor & flexibility outcomes"] },
        { name:"Training Focus", points:["Core stability exercises","Balance exercises","Stabilize spine muscles","Include in ALL training phases"] },
        { name:"Program Design", points:["Body weight/segment resistance","Progress proximal → distal","Lumbar region first","Address posture/flexibility deviations"] },
