---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Chapter 11 — Integrated Exercise Programming | ACE Prep · Lifelong Athletics">

<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>

<style is:global>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#080808;
  --bg2:#111;
  --bg3:#181818;
  --border:#222;
  --border2:#2e2e2e;
  --text:#ededec;
  --muted:#777;
  --accent:#d4a843;
  --accent-dim:#a07c2a;
  --correct:#4ade80;
  --incorrect:#f87171;
  --warn:#fbbf24;
  --blue:#60a5fa;
  --font-head:'Playfair Display',Georgia,serif;
  --font-body:'DM Sans',sans-serif;
  --r:10px;
  --r2:6px;
  --trans:0.2s ease;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:15px;line-height:1.7;-webkit-font-smoothing:antialiased}

/* ── HERO ── */
.hero{max-width:1100px;margin:0 auto;padding:56px 28px 36px}
.breadcrumb{display:flex;gap:8px;align-items:center;font-size:12px;color:var(--muted);margin-bottom:20px}
.breadcrumb a{color:var(--muted);text-decoration:none}
.breadcrumb a:hover{color:var(--accent)}
.breadcrumb span{color:var(--border2)}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:var(--bg3);border:1px solid var(--border2);border-radius:20px;padding:5px 14px;font-size:12px;color:var(--muted);margin-bottom:22px}
.hero-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}
.hero h1{font-family:var(--font-head);font-size:clamp(32px,5vw,52px);font-weight:700;line-height:1.1;letter-spacing:-1px;max-width:720px;margin-bottom:16px}
.hero h1 em{font-style:italic;color:var(--accent)}
.hero p{color:var(--muted);max-width:560px;font-size:15px;margin-bottom:28px}
.hero-stats{display:flex;gap:20px;flex-wrap:wrap}
.stat-chip{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:10px 18px;font-size:13px}
.stat-chip strong{display:block;font-size:22px;font-weight:600;color:var(--text);font-family:var(--font-head);letter-spacing:-0.5px}
.stat-chip span{color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px}

/* ── TABS ── */
.tab-bar{max-width:1100px;margin:0 auto;padding:0 28px 0;border-bottom:1px solid var(--border)}
.tabs{display:flex;gap:0}
.tab-btn{background:none;border:none;color:var(--muted);font-family:var(--font-body);font-size:13px;font-weight:500;padding:14px 22px;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:var(--trans);display:flex;align-items:center;gap:7px}
.tab-btn:hover{color:var(--text)}
.tab-btn.active{color:var(--text);border-bottom-color:var(--accent)}
.tab-icon{font-size:15px}

/* ── CONTENT ── */
.content{max-width:1100px;margin:0 auto;padding:36px 28px 80px}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* ── MINDMAP ── */
.mm-title{font-family:var(--font-head);font-size:13px;font-style:italic;color:var(--muted);margin-bottom:24px}
.mm-center{width:fit-content;margin:0 auto 40px;text-align:center}
.mm-center-node{background:var(--accent);color:#000;font-family:var(--font-head);font-size:16px;font-weight:700;padding:18px 36px;border-radius:50px;display:inline-block;letter-spacing:-0.3px}
.mm-center-sub{color:var(--muted);font-size:12px;margin-top:8px}
.mm-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px}
.mm-branch{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:var(--trans)}
.mm-branch:hover{border-color:var(--border2)}
.mm-branch-header{padding:16px 20px;display:flex;align-items:center;gap:14px}
.mm-branch-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.mm-branch-name{font-weight:600;font-size:14px;letter-spacing:-.2px;flex:1}
.mm-branch-arrow{color:var(--muted);font-size:12px;transition:transform 0.25s ease;flex-shrink:0}
.mm-branch.open .mm-branch-arrow{transform:rotate(90deg)}
.mm-branch-body{display:none;padding:0 20px 16px;border-top:1px solid var(--border)}
.mm-branch.open .mm-branch-body{display:block}
.mm-subs{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding-top:14px}
.mm-sub{background:var(--bg3);border-radius:var(--r2);padding:12px}
.mm-sub-name{font-size:12px;font-weight:600;color:var(--accent);margin-bottom:8px;text-transform:uppercase;letter-spacing:.5px}
.mm-sub-points{list-style:none;display:flex;flex-direction:column;gap:4px}
.mm-sub-points li{font-size:12px;color:var(--muted);padding-left:12px;position:relative}
.mm-sub-points li::before{content:'›';position:absolute;left:0;color:var(--border2)}

/* ── QUIZ ── */
.quiz-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:28px}
.quiz-header h2{font-family:var(--font-head);font-size:24px}
.quiz-header h2 em{font-style:italic;color:var(--accent)}
.progress-bar-wrap{background:var(--bg3);border-radius:20px;height:4px;margin-bottom:28px;overflow:hidden}
.progress-bar{background:var(--accent);height:100%;border-radius:20px;transition:width 0.5s ease;width:0%}
.progress-label{font-size:12px;color:var(--muted);margin-bottom:8px;display:flex;justify-content:space-between}
.section-label{display:flex;align-items:center;gap:10px;margin:36px 0 18px}
.section-label-badge{background:var(--bg3);border:1px solid var(--border2);border-radius:20px;padding:5px 14px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.8px;color:var(--muted)}
.section-label-line{flex:1;height:1px;background:var(--border)}
.section-label-count{font-size:12px;color:var(--muted)}
.q-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px;margin-bottom:12px;transition:var(--trans)}
.q-card:hover{border-color:var(--border2)}
.q-num{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px}
.q-text{font-size:14px;font-weight:500;color:var(--text);margin-bottom:16px;line-height:1.6}
.q-options{display:flex;flex-direction:column;gap:8px}
.q-option{display:flex;align-items:flex-start;gap:10px;padding:10px 14px;border-radius:var(--r2);border:1px solid var(--border);background:var(--bg3);cursor:pointer;transition:var(--trans);font-size:13px;color:var(--muted)}
.q-option:hover{border-color:var(--border2);color:var(--text)}
.q-option.selected{border-color:var(--accent);background:rgba(212,168,67,.07);color:var(--text)}
.opt-letter{width:22px;height:22px;border-radius:50%;border:1px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;flex-shrink:0;transition:var(--trans)}
.q-option.selected .opt-letter{background:var(--accent);border-color:var(--accent);color:#000}
.q-option.correct-ans{border-color:var(--correct)!important;background:rgba(74,222,128,.08)!important;color:var(--text)!important}
.q-option.wrong-ans{border-color:var(--incorrect)!important;background:rgba(248,113,113,.07)!important}
.q-option.correct-ans .opt-letter{background:var(--correct);border-color:var(--correct);color:#000}
.q-option.wrong-ans .opt-letter{background:var(--incorrect);border-color:var(--incorrect);color:#000}
.q-tf{display:flex;gap:10px}
.q-tf-btn{flex:1;padding:12px;border-radius:var(--r2);border:1px solid var(--border);background:var(--bg3);cursor:pointer;font-family:var(--font-body);font-size:14px;font-weight:500;color:var(--muted);transition:var(--trans);text-align:center}
.q-tf-btn:hover{border-color:var(--border2);color:var(--text)}
.q-tf-btn.selected{border-color:var(--accent);background:rgba(212,168,67,.07);color:var(--text)}
.q-tf-btn.correct-ans{border-color:var(--correct)!important;background:rgba(74,222,128,.08)!important;color:var(--correct)!important}
.q-tf-btn.wrong-ans{border-color:var(--incorrect)!important;background:rgba(248,113,113,.07)!important;color:var(--incorrect)!important}
.q-input{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r2);padding:11px 14px;color:var(--text);font-family:var(--font-body);font-size:14px;resize:none;transition:var(--trans);outline:none}
.q-input:focus{border-color:var(--border2)}
.q-input::placeholder{color:var(--muted)}
textarea.q-input{min-height:110px}
.explanation{background:var(--bg3);border-left:3px solid var(--accent);border-radius:0 var(--r2) var(--r2) 0;padding:12px 14px;margin-top:12px;display:none}
.explanation.show{display:block}
.explanation-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.6px;color:var(--accent);margin-bottom:5px}
.explanation-text{font-size:13px;color:var(--muted);line-height:1.6}
.answer-reveal{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r2);padding:11px 14px;margin-top:10px;display:none}
.answer-reveal.show{display:block}
.answer-reveal-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.5px;color:var(--correct);margin-bottom:4px}
.answer-reveal-text{font-size:13px;color:var(--text)}
.quiz-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-top:36px;padding-top:28px;border-top:1px solid var(--border)}
.submit-btn{background:var(--accent);color:#000;border:none;border-radius:30px;padding:14px 36px;font-family:var(--font-body);font-size:14px;font-weight:700;cursor:pointer;transition:var(--trans)}
.submit-btn:hover{background:var(--accent-dim);transform:translateY(-1px)}
.reset-btn{background:none;border:1px solid var(--border2);color:var(--muted);border-radius:30px;padding:13px 24px;font-family:var(--font-body);font-size:13px;cursor:pointer;transition:var(--trans)}
.reset-btn:hover{border-color:var(--incorrect);color:var(--incorrect)}

/* ── RESULTS ── */
#results{display:none;margin-top:36px}
.result-hero{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:36px;text-align:center;margin-bottom:28px}
.result-score{font-family:var(--font-head);font-size:clamp(52px,8vw,80px);font-weight:700;color:var(--accent);letter-spacing:-2px;line-height:1}
.result-label{color:var(--muted);font-size:14px;margin-top:8px}
.result-grade{display:inline-block;padding:6px 18px;border-radius:20px;font-size:13px;font-weight:600;margin-top:14px}
.grade-a{background:rgba(74,222,128,.15);color:var(--correct);border:1px solid rgba(74,222,128,.3)}
.grade-b{background:rgba(251,191,36,.15);color:var(--warn);border:1px solid rgba(251,191,36,.3)}
.grade-c{background:rgba(248,113,113,.15);color:var(--incorrect);border:1px solid rgba(248,113,113,.3)}
.result-breakdown{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:28px}
.rb-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:16px;text-align:center}
.rb-score{font-family:var(--font-head);font-size:26px;font-weight:700}
.rb-label{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:4px}
.result-review-title{font-family:var(--font-head);font-size:20px;margin-bottom:20px}
.result-review-title em{font-style:italic;color:var(--accent)}

/* ── REFERENCE ── */
.ref-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-bottom:32px}
.ref-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:22px}
.ref-card h3{font-family:var(--font-head);font-size:16px;font-weight:600;margin-bottom:14px}
.ref-card h3 em{font-style:italic;color:var(--accent)}
.ref-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:8px}
.ref-table th{text-align:left;padding:8px 10px;background:var(--bg3);color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px;font-weight:600}
.ref-table td{padding:9px 10px;border-top:1px solid var(--border);color:var(--text);vertical-align:top}
.ref-table tr:hover td{background:rgba(255,255,255,.015)}
.ref-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600}
.badge-elastic{background:rgba(96,165,250,.15);color:var(--blue)}
.badge-plastic{background:rgba(251,191,36,.15);color:var(--warn)}
.badge-visco{background:rgba(212,168,67,.15);color:var(--accent)}
.key-term{background:var(--bg3);border-radius:var(--r2);padding:12px;margin-bottom:8px}
.key-term strong{font-size:13px;color:var(--accent);display:block;margin-bottom:3px}
.key-term span{font-size:12px;color:var(--muted)}

@media(max-width:640px){
  .mm-subs{grid-template-columns:1fr}
  .hero{padding:36px 20px 24px}
  .content{padding:24px 20px 60px}
  .tab-bar{padding:0 20px}
  .tab-btn{padding:12px 14px;font-size:12px}
}
</style>

<!-- HERO -->
<div class="hero">
  <div class="breadcrumb">
    <a href="/exam-prep">Exam Prep</a>
    <span>›</span>
    <a href="/ace-prep">ACE Hub</a>
    <span>›</span>
    <span>Chapter 11</span>
  </div>
  <div class="hero-badge"><span class="dot"></span>ACE-CPT · Chapter 11</div>
  <h1>Integrated <em>Exercise</em> Programming</h1>
  <p>From Evidence to Practice — Functional Training, Flexibility, Tissue Properties & Neurological Mechanisms.</p>
  <div class="hero-stats">
    <div class="stat-chip"><strong>25</strong><span>MCQ</span></div>
    <div class="stat-chip"><strong>15</strong><span>Fill-in</span></div>
    <div class="stat-chip"><strong>10</strong><span>True / False</span></div>
    <div class="stat-chip"><strong>5</strong><span>Subjective</span></div>
    <div class="stat-chip"><strong>55</strong><span>Total Questions</span></div>
  </div>
  <a href="/ace-prep/chapter-11-guide" style="display:inline-flex;align-items:center;gap:8px;margin-top:24px;color:var(--accent);text-decoration:none;font-size:13px;font-weight:600;border:1px solid var(--accent);padding:9px 20px;border-radius:30px;transition:background 0.2s">📖 Read the Full Theory Guide →</a>
</div>

<!-- TABS -->
<div class="tab-bar">
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('mindmap',this)"><span class="tab-icon">📑</span> Contents</button>
    <button class="tab-btn" onclick="switchTab('quiz',this)"><span class="tab-icon">📝</span> Quiz</button>
    <button class="tab-btn" onclick="switchTab('reference',this)"><span class="tab-icon">📋</span> Quick Reference</button>
  </div>
</div>

<!-- CONTENT -->
<div class="content">

<!-- MIND MAP -->
<div class="tab-panel active" id="tab-mindmap">
  <p class="mm-title">Click any branch to expand. All key concepts mapped from Chapter 11.</p>
  <div class="mm-center">
    <div class="mm-center-node">Chapter 11: Functional Training & Flexibility</div>
    <div class="mm-center-sub">ACE Personal Trainer Certification</div>
  </div>
  <div class="mm-grid" id="mm-grid"></div>
</div>

<!-- QUIZ -->
<div class="tab-panel" id="tab-quiz">
  <div class="quiz-header">
    <h2>Chapter 11 <em>Quiz</em></h2>
    <button class="reset-btn" onclick="resetQuiz()">↺ Reset Quiz</button>
  </div>
  <div class="progress-label">
    <span id="progress-text">0 of 55 answered</span>
    <span id="progress-pct">0%</span>
  </div>
  <div class="progress-bar-wrap"><div class="progress-bar" id="prog-bar"></div></div>

  <div class="section-label">
    <div class="section-label-badge">Part A — Multiple Choice</div>
    <div class="section-label-line"></div>
    <div class="section-label-count">25 Questions · 1 pt each</div>
  </div>
  <div id="mcq-container"></div>

  <div class="section-label">
    <div class="section-label-badge">Part B — Fill in the Blank</div>
    <div class="section-label-line"></div>
    <div class="section-label-count">15 Questions · 1 pt each</div>
  </div>
  <div id="fillin-container"></div>

  <div class="section-label">
    <div class="section-label-badge">Part C — True / False</div>
    <div class="section-label-line"></div>
    <div class="section-label-count">10 Questions · 1 pt each</div>
  </div>
  <div id="tf-container"></div>

  <div class="section-label">
    <div class="section-label-badge">Part D — Subjective / Essay</div>
    <div class="section-label-line"></div>
    <div class="section-label-count">5 Questions · Model answers revealed on submit</div>
  </div>
  <div id="subj-container"></div>

  <div class="quiz-footer">
    <div style="font-size:13px;color:var(--muted)">Submit to see score + explanations.</div>
    <button class="submit-btn" onclick="submitQuiz()">Submit Quiz →</button>
  </div>

  <div id="results">
    <div class="result-hero">
      <div style="font-size:13px;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px">Your Score</div>
      <div class="result-score" id="score-display">—</div>
      <div class="result-label" id="score-label"></div>
      <div class="result-grade" id="score-grade"></div>
    </div>
    <div class="result-breakdown">
      <div class="rb-card"><div class="rb-score" id="rb-mcq" style="color:var(--blue)">—</div><div class="rb-label">MCQ</div></div>
      <div class="rb-card"><div class="rb-score" id="rb-fi" style="color:var(--warn)">—</div><div class="rb-label">Fill-in</div></div>
      <div class="rb-card"><div class="rb-score" id="rb-tf" style="color:var(--correct)">—</div><div class="rb-label">True / False</div></div>
      <div class="rb-card"><div class="rb-score" id="rb-subj" style="color:var(--accent)">Self-Check</div><div class="rb-label">Subjective</div></div>
    </div>
    <div class="result-review-title">Detailed <em>Review</em></div>
    <div id="review-container"></div>
  </div>
</div>

<!-- QUICK REFERENCE -->
<div class="tab-panel" id="tab-reference">
  <div class="ref-grid">
    <div class="ref-card" style="grid-column:1/-1">
      <h3>Flexibility FITT-VP <em>Guidelines</em></h3>
      <table class="ref-table">
        <tr><th>Component</th><th>Recommendation</th></tr>
        <tr><td><strong>Frequency</strong></td><td>≥2–3 days/week · Daily most effective</td></tr>
        <tr><td><strong>Intensity</strong></td><td>Stretch to tightness or slight discomfort — not pain</td></tr>
        <tr><td><strong>Time</strong></td><td>10–30 sec static (30–60 sec older adults) · PNF: 3–6 sec contraction + 10–30 sec assisted</td></tr>
        <tr><td><strong>Type</strong></td><td>Static (active/passive), Dynamic, Ballistic, PNF — all effective</td></tr>
        <tr><td><strong>Volume</strong></td><td>60 sec total per exercise · 2–4 reps per exercise</td></tr>
        <tr><td><strong>Pattern</strong></td><td>AFTER cardio/strength training — not before</td></tr>
        <tr><td><strong>Progression</strong></td><td>Warm muscle first · Heat packs beneficial</td></tr>
      </table>
    </div>
    <div class="ref-card">
      <h3>Tissue <em>Properties</em></h3>
      <table class="ref-table">
        <tr><th>Property</th><th>Behavior</th><th>Stretching Link</th></tr>
        <tr><td><span class="ref-badge badge-elastic">Elastic</span></td><td>Returns to original shape</td><td>Dynamic, Ballistic</td></tr>
        <tr><td><span class="ref-badge badge-plastic">Plastic</span></td><td>Permanent deformation</td><td>Static (sustained)</td></tr>
        <tr><td><span class="ref-badge badge-visco">Viscoelastic</span></td><td>Both elastic + plastic</td><td>All tissues</td></tr>
      </table>
    </div>
    <div class="ref-card">
      <h3>Neurological <em>Mechanisms</em></h3>
      <div class="key-term"><strong>Autogenic Inhibition</strong><span>GTO activation → inhibits muscle spindle. Occurs after 7–10 sec of low-force stretch. Enables deeper stretching.</span></div>
      <div class="key-term"><strong>Reciprocal Inhibition</strong><span>Agonist contraction (&lt;50% max) for 6–15 sec → inhibits antagonist. Allows antagonist to be stretched.</span></div>
      <div class="key-term"><strong>Stretch Reflex</strong><span>Rapid stretch → reflexive contraction. Triggered by ballistic moves. AVOIDED in static stretching.</span></div>
      <div class="key-term"><strong>Stress Relaxation</strong><span>Progressive decrease in muscle response as stretch duration increases → allows creep.</span></div>
    </div>
    <div class="ref-card">
      <h3>Stretching <em>Techniques</em></h3>
      <table class="ref-table">
        <tr><th>Type</th><th>Duration</th><th>Best For</th><th>Risk</th></tr>
        <tr><td><strong>Static</strong></td><td>10–30 sec</td><td>ROM improvement</td><td>Low</td></tr>
        <tr><td><strong>Dynamic</strong></td><td>Continuous</td><td>Warm-up</td><td>Low</td></tr>
        <tr><td><strong>PNF</strong></td><td>3–6 + 10–30 sec</td><td>Max flexibility</td><td>Low–Med</td></tr>
        <tr><td><strong>Ballistic</strong></td><td>Variable</td><td>Athletes only</td><td>Higher</td></tr>
      </table>
    </div>
    <div class="ref-card">
      <h3>Functional Training <em>Progression</em></h3>
      <table class="ref-table">
        <tr><th>Step</th><th>Region</th><th>Focus</th></tr>
        <tr><td>1</td><td>Lumbar / Core</td><td>Proximal stability — foundation</td></tr>
        <tr><td>2</td><td>Hips + Thoracic Spine</td><td>Adjacent mobility restoration</td></tr>
        <tr><td>3</td><td>Scapulothoracic</td><td>Stability of shoulder complex</td></tr>
        <tr><td>4</td><td>Lumbopelvic / Shoulder</td><td>Integrated stability</td></tr>
        <tr><td>5</td><td>Distal Extremities</td><td>Mobility with proximal base</td></tr>
      </table>
    </div>
    <div class="ref-card">
      <h3>Key <em>Terms</em></h3>
      <div class="key-term"><strong>Elastic Limit</strong><span>Point beyond which tissue cannot return to normal length.</span></div>
      <div class="key-term"><strong>Yield Point</strong><span>Transition from elastic to plastic behavior.</span></div>
      <div class="key-term"><strong>Permanent Set</strong><span>New resting length after plastic deformation.</span></div>
      <div class="key-term"><strong>Creep</strong><span>Lengthening under sustained load — collagen remodeling.</span></div>
      <div class="key-term"><strong>Kinetic Chain</strong><span>Interconnected joints — proximal stability enables distal mobility.</span></div>
    </div>
  </div>
</div>

</div><!-- /content -->

<script is:inline>
const MINDMAP = {
  branches: [
