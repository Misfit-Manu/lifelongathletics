        { name:"Creep & Deformation", points:["Sustained load → tissue lengthens","Collagen fibers remodel","Occurs beyond 10 seconds","Plastic deformation result"] },
        { name:"Static vs Dynamic Warm-up", points:["Static: NO ergogenic benefit","Static: Decreases strength/power","Dynamic: Improves sport readiness","Research: Dynamic preferred"] },
        { name:"ROM Adaptations", points:["Acute improvements (session)","Chronic adaptations (weeks)","Repeated stretches increase ROM","Gradual extensibility"] },
