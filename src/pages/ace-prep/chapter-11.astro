    { id:4, name:"NEUROLOGICAL MECHANISMS", color:"#F38181",
      subs:[
        { name:"Autogenic Inhibition", points:["GTO activation → inhibits spindle","Occurs at 7–10 seconds","Allows deeper stretch","Stress-relaxation response"] },
        { name:"Reciprocal Inhibition", points:["Agonist fires → antagonist inhibited","<50% maximal force","Duration: 6–15 seconds","Basis of PNF technique"] },
        { name:"Stretch Reflex", points:["Rapid stretch triggers reflex","Reflexive muscle contraction","Ballistic activates this","Static AVOIDS this"] },
        { name:"Spindle Recovery", points:["~70% recovery in 5 seconds","Repeat stretches increase ROM","Gradual extensibility gains","Finite repetitions protocol"] }
