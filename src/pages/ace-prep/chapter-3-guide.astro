<Layout title="Basics of Behavior Change — Theory Guide | ACE Prep · Lifelong Athletics" description="Complete theory guide covering Health Belief Model, Self-Determination Theory, Stages of Change, Self-Efficacy, Operant Conditioning, and Adherence Determinants for ACE-CPT Chapter 3.">

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
  font-size: 17px;
  line-height: 1.75;
  color: #1a1a2e;
  background: #f7f6f2;
}
.blog-container {
  max-width: 860px;
  margin: 0 auto;
  padding: 40px 24px 80px;
  background: #f7f6f2;
}

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, #0f2b1a 0%, #1a2e0d 50%, #0d1f35 100%);
  color: #fff;
  border-radius: 16px;
  padding: 56px 48px;
  margin-bottom: 48px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 280px; height: 280px;
  background: rgba(197,241,53,0.06);
  border-radius: 50%;
}
.hero-tag {
  display: inline-block;
  background: #c5f135;
  color: #000;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 20px;
  margin-bottom: 20px;
}
.hero h1 {
  font-size: 2.4rem;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 20px;
  color: #fff;
}
.hero h1 em { color: #c5f135; font-style: italic; }
.hero p {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.78);
  max-width: 620px;
  margin-bottom: 24px;
}
.hero-meta {
  display: flex;
  gap: 24px;
  flex-wrap: wrap;
  font-size: 13px;
  color: rgba(255,255,255,0.55);
}
.hero-meta span { display: flex; align-items: center; gap: 6px; }

/* ── STICKY TOC ── */
.toc-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(247,246,242,0.98);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid #dddbd6;
  padding: 10px 0;
  margin-bottom: 36px;
}
.toc-inner {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.toc-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: #999;
  white-space: nowrap;
}
.toc-links { display: flex; gap: 6px; flex-wrap: wrap; }
.toc-links a {
  font-size: 12px;
  color: #666;
  text-decoration: none;
  padding: 3px 10px;
  border-radius: 20px;
  border: 1px solid #e0e0e0;
  transition: all .2s;
}
.toc-links a:hover {
  color: #000;
  border-color: #c5f135;
  background: rgba(197,241,53,0.1);
}

/* ── TYPOGRAPHY ── */
h2 {
  font-size: 1.5rem;
  font-weight: 800;
  color: #0d1f35;
  margin: 48px 0 16px;
  padding-bottom: 10px;
  border-bottom: 3px solid #c5f135;
  display: flex;
  align-items: center;
  gap: 10px;
}
h2 .icon { font-size: 1.2rem; }
h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: #1a2e0d;
  margin: 28px 0 10px;
}
h4 {
  font-size: 0.9rem;
  font-weight: 700;
  color: #0d6636;
  margin: 18px 0 6px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
p { color: #2d2d2d; margin-bottom: 14px; font-size: 0.97rem; }
strong { color: #0d1f35; }
em { color: #0d6636; }
hr { border: none; border-top: 1px solid #ebebeb; margin: 36px 0; }

/* ── INTRO BOX ── */
.intro-box {
  background: linear-gradient(135deg, rgba(197,241,53,0.1), rgba(5,150,105,0.06));
  border: 1px solid rgba(197,241,53,0.4);
  border-radius: 12px;
  padding: 20px 24px;
  margin-bottom: 36px;
}
.intro-box p { color: #1a1a2e; font-size: 1.02rem; line-height: 1.8; margin: 0; }

/* ── CARD GRID ── */
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
  gap: 14px;
  margin: 16px 0 20px;
}
.card {
  background: #ffffff;
  border: 1px solid #e8e8e8;
  border-radius: 10px;
  padding: 16px;
}
.card.green  { border-top: 3px solid #4ade80; }
.card.blue   { border-top: 3px solid #60a5fa; }
.card.orange { border-top: 3px solid #fb923c; }
.card.purple { border-top: 3px solid #a78bfa; }
.card.teal   { border-top: 3px solid #2dd4bf; }
.card.lime   { border-top: 3px solid #c5f135; }
.card h4 { font-size: 0.85rem; margin-top: 0; letter-spacing: 0; }
.card.green h4  { color: #16a34a; }
.card.blue h4   { color: #2563eb; }
.card.orange h4 { color: #ea580c; }
.card.purple h4 { color: #7c3aed; }
.card.teal h4   { color: #0d9488; }
.card.lime h4   { color: #65a30d; }
.card p { font-size: 0.87rem; color: #555; margin: 0; }

/* ── STAGES FLOW ── */
.stages-flow {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 16px 0 20px;
}
.stage-pill {
  flex: 1;
  min-width: 130px;
  padding: 12px 14px;
  border-radius: 10px;
  text-align: center;
  border: 1px solid #e0e0e0;
}
.stage-pill .stage-name { font-weight: 700; font-size: 0.88rem; }
.stage-pill .stage-desc { font-size: 0.78rem; color: #777; margin-top: 6px; line-height: 1.4; }
.stage-pill:nth-child(1) { background: rgba(167,139,250,0.1); border-color: rgba(167,139,250,0.35); }
.stage-pill:nth-child(1) .stage-name { color: #7c3aed; }
.stage-pill:nth-child(2) { background: rgba(96,165,250,0.1); border-color: rgba(96,165,250,0.35); }
.stage-pill:nth-child(2) .stage-name { color: #2563eb; }
.stage-pill:nth-child(3) { background: rgba(45,212,191,0.1); border-color: rgba(45,212,191,0.35); }
.stage-pill:nth-child(3) .stage-name { color: #0d9488; }
.stage-pill:nth-child(4) { background: rgba(251,146,60,0.1); border-color: rgba(251,146,60,0.35); }
.stage-pill:nth-child(4) .stage-name { color: #ea580c; }
.stage-pill:nth-child(5) { background: rgba(74,222,128,0.1); border-color: rgba(74,222,128,0.35); }
.stage-pill:nth-child(5) .stage-name { color: #16a34a; }

/* ── PROCESS TABLE ── */
.proc-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 0.88rem; }
.proc-table th {
  background: #eeece9;
  color: #555;
  text-transform: uppercase;
  letter-spacing: .06em;
  font-size: 0.76rem;
  padding: 8px 12px;
  text-align: left;
  border-bottom: 2px solid #e0e0e0;
}
.proc-table td {
  padding: 9px 12px;
  border-bottom: 1px solid #f0f0f0;
  vertical-align: top;
  font-size: 0.87rem;
}
.proc-table td:first-child { font-weight: 600; color: #1a1a2e; white-space: nowrap; }
.proc-table tr:hover td { background: rgba(197,241,53,0.05); }
.tag-cog { display:inline-block; background:rgba(96,165,250,.15); color:#2563eb; font-size:.7rem; font-weight:700; padding:2px 7px; border-radius:4px; text-transform:uppercase; letter-spacing:.06em; }
.tag-beh { display:inline-block; background:rgba(74,222,128,.15); color:#16a34a; font-size:.7rem; font-weight:700; padding:2px 7px; border-radius:4px; text-transform:uppercase; letter-spacing:.06em; }

/* ── CONSEQUENCE TABLE ── */
.cons-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 0.87rem; }
.cons-table th { background: #eeece9; color: #555; font-size: .76rem; text-transform:uppercase; letter-spacing:.06em; padding:8px 12px; text-align:left; border-bottom:2px solid #e0e0e0; }
.cons-table td { padding:9px 12px; border-bottom:1px solid #f0f0f0; vertical-align:top; }
.cons-table td:first-child { font-weight:600; color:#1a1a2e; }
.tag-up { display:inline-block; background:rgba(74,222,128,.15); color:#16a34a; font-size:.7rem; font-weight:700; padding:2px 7px; border-radius:4px; }
.tag-dn { display:inline-block; background:rgba(251,146,60,.15); color:#ea580c; font-size:.7rem; font-weight:700; padding:2px 7px; border-radius:4px; }

