.dialogue { display:flex; flex-direction:column; gap:10px; }
.dl-turn  { display:flex; gap:12px; }
.speaker  { font-size:11px; font-weight:700; text-transform:uppercase; padding:3px 8px; border-radius:4px; white-space:nowrap; height:fit-content; margin-top:2px; flex-shrink:0; }
.speaker.pt { background:rgba(197,241,53,0.25); color:#3d6b00; }
.speaker.cl { background:rgba(96,165,250,0.2);  color:#1d4ed8; }
.dl-text { font-size: 0.88rem; color: #2d2d2d; line-height: 1.6; }

/* ── CLEAN LIST ── */
.clean-list { list-style:none; display:flex; flex-direction:column; gap:8px; margin:14px 0; }
.clean-list li {
  background: #ffffff;
  border-radius: 8px;
