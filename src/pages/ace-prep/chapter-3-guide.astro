/* ── TAKEAWAY ── */
.takeaway {
  background: linear-gradient(135deg, rgba(197,241,53,0.1), rgba(5,150,105,0.06));
  border: 1px solid rgba(197,241,53,0.4);
  border-radius: 14px;
  padding: 24px 28px;
  margin: 40px 0 0;
}
.takeaway h3 { margin:0 0 14px; color:#0d6636; font-size:0.95rem; text-transform:uppercase; letter-spacing:.08em; font-weight:800; }
.takeaway ul { list-style:none; display:flex; flex-direction:column; gap:8px; }
