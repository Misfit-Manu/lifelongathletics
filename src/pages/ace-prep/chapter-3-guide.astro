.highlight.blue   { background:#eff6ff; border-left-color:#60a5fa; }
.highlight.orange { background:#fff7ed; border-left-color:#fb923c; }
.highlight.teal   { background:#f0fdfa; border-left-color:#2dd4bf; }
.highlight.purple { background:#faf5ff; border-left-color:#a78bfa; }
.highlight p { margin: 0; font-size: 0.9rem; color: #333; }

/* ── SOURCES LIST ── */
.sources-list { list-style:none; display:flex; flex-direction:column; gap:10px; margin:14px 0; }
.sources-list li {
  background: #ffffff;
  border: 1px solid #e8e8e8;
  border-radius: 8px;
  padding: 12px 14px;
