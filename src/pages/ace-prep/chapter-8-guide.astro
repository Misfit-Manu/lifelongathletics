---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="The Complete Guide to Cardiorespiratory Training | Lifelong Athletics" description="A comprehensive, science-backed guide covering the physiology, assessments, and programming of cardiorespiratory training.">

<style is:global>
    /* ── Base reset & typography (Astra-compatible) ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
      font-size: 17px;
      line-height: 1.75;
      color: #1a1a2e;
      background: #ffffff;
    }
    .blog-container {
      max-width: 860px;
      margin: 0 auto;
      padding: 40px 24px 80px;
    }

    /* ── Hero ── */
    .hero {
      background: linear-gradient(135deg, #0f3460 0%, #16213e 60%, #1a1a2e 100%);
      color: #fff;
      border-radius: 16px;
      padding: 56px 48px;
      margin-bottom: 48px;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 280px; height: 280px;
      background: rgba(255,255,255,0.04);
      border-radius: 50%;
    }
    .hero-tag {
      display: inline-block;
      background: #e94560;
      color: #fff;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 20px;
      margin-bottom: 20px;
    }
    .hero h1 {
      font-size: 2.4rem;
      font-weight: 800;
      line-height: 1.2;
      margin-bottom: 20px;
      color: #fff;
    }
    .hero p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.82);
      max-width: 620px;
      margin-bottom: 24px;
    }
    .hero-meta {
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
      font-size: 13px;
      color: rgba(255,255,255,0.6);
    }
    .hero-meta span { display: flex; align-items: center; gap: 6px; }

    /* ── Hero image ── */
    .hero-img {
      width: 100%;
      border-radius: 12px;
      margin-bottom: 48px;
      object-fit: contain;
      display: block;
      background: linear-gradient(135deg, #e8f4fd, #d1e8f5);
    }
    .img-placeholder {
      width: 100%;
      border-radius: 12px;
      margin: 28px 0;
      background: linear-gradient(135deg, #f0f8ff, #dbeafe);
      border: 2px dashed #93c5fd;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
      color: #3b82f6;
      font-size: 14px;
      text-align: center;
      gap: 8px;
    }
    .img-placeholder .img-icon { font-size: 36px; }
    .img-placeholder strong { font-size: 15px; color: #1d4ed8; }

    /* ── TOC ── */
    .toc {
      background: #f8faff;
      border-left: 4px solid #0f3460;
      border-radius: 0 12px 12px 0;
      padding: 28px 32px;
      margin-bottom: 48px;
    }
    .toc h2 {
      font-size: 1rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #0f3460;
      margin-bottom: 16px;
    }
    .toc ol {
      padding-left: 20px;
    }
    .toc li {
      margin-bottom: 8px;
      font-size: 15px;
    }
    .toc a {
      color: #0f3460;
      text-decoration: none;
      font-weight: 500;
    }
    .toc a:hover { text-decoration: underline; color: #e94560; }

    /* ── Headings ── */
    h2 {
      font-size: 1.75rem;
      font-weight: 800;
      color: #0f3460;
      margin: 52px 0 18px;
      padding-top: 8px;
      border-top: 3px solid #e94560;
      display: inline-block;
    }
    h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #16213e;
      margin: 32px 0 14px;
    }
    h4 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #0f3460;
      margin: 24px 0 10px;
    }
    p { margin-bottom: 18px; }

    /* ── Callout boxes ── */
    .callout {
      border-radius: 12px;
      padding: 22px 26px;
      margin: 28px 0;
      position: relative;
    }
    .callout-key {
      background: #fffbeb;
      border-left: 5px solid #f59e0b;
    }
    .callout-science {
      background: #f0fdf4;
      border-left: 5px solid #22c55e;
    }
    .callout-warning {
      background: #fff1f2;
      border-left: 5px solid #e94560;
    }
    .callout-tip {
      background: #eff6ff;
      border-left: 5px solid #3b82f6;
    }
    .callout-label {
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      margin-bottom: 8px;
      opacity: 0.75;
    }
    .callout-key .callout-label { color: #92400e; }
    .callout-science .callout-label { color: #166534; }
    .callout-warning .callout-label { color: #9f1239; }
    .callout-tip .callout-label { color: #1e40af; }
    .callout p { margin: 0; font-size: 15px; line-height: 1.65; }
    .callout strong { font-weight: 700; }

    /* ── Highlight stat ── */
    .stat-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
      margin: 32px 0;
    }
    .stat-card {
      background: linear-gradient(135deg, #0f3460, #16213e);
      color: #fff;
      border-radius: 12px;
      padding: 24px 20px;
      text-align: center;
    }
    .stat-card .stat-num {
      font-size: 2rem;
      font-weight: 800;
      color: #fbbf24;
      line-height: 1;
      margin-bottom: 8px;
    }
    .stat-card .stat-label {
      font-size: 12px;
      color: rgba(255,255,255,0.75);
      line-height: 1.4;
    }

    /* ── Tables ── */
    .table-wrap {
      overflow-x: auto;
      margin: 28px 0;
      border-radius: 12px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14.5px;
    }
    thead th {
      background: #0f3460;
      color: #fff;
      padding: 14px 16px;
      text-align: left;
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.5px;
    }
    tbody tr:nth-child(even) { background: #f8faff; }
    tbody tr:hover { background: #eff6ff; }
    td { padding: 12px 16px; border-bottom: 1px solid #e5e7eb; vertical-align: top; line-height: 1.55; }

    /* ── Zone badges ── */
    .zone {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 700;
    }
    .zone1 { background: #dcfce7; color: #166534; }
    .zone2 { background: #fef9c3; color: #854d0e; }
    .zone3 { background: #fee2e2; color: #991b1b; }

    /* ── Bullet lists ── */
    ul, ol { padding-left: 22px; margin-bottom: 18px; }
    li { margin-bottom: 8px; line-height: 1.65; }

    /* ── Section divider ── */
    .divider {
      border: none;
      height: 3px;
      background: linear-gradient(to right, #0f3460, #e94560, transparent);
      border-radius: 2px;
      margin: 56px 0;
    }

    /* ── Anatomy diagram text ── */
    .anatomy-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin: 24px 0;
    }
    .anatomy-card {
      background: #f8faff;
      border: 1px solid #dbeafe;
      border-radius: 10px;
      padding: 20px;
    }
    .anatomy-card h4 { margin-top: 0; color: #0f3460; font-size: 0.95rem; }
    .anatomy-card ul { margin-bottom: 0; }
    .anatomy-card li { font-size: 14px; }

    /* ── Phase cards ── */
    .phase-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin: 28px 0;
    }
    .phase-card {
      border-radius: 12px;
      padding: 26px 22px;
      border-top: 4px solid;
    }
    .phase-base { background: #f0fdf4; border-color: #22c55e; }
    .phase-fitness { background: #fffbeb; border-color: #f59e0b; }
    .phase-performance { background: #fff1f2; border-color: #e94560; }
    .phase-card h3 { margin-top: 0; font-size: 1.1rem; }
    .phase-base h3 { color: #166534; }
    .phase-fitness h3 { color: #92400e; }
    .phase-performance h3 { color: #9f1239; }
    .phase-card p { font-size: 14px; margin-bottom: 10px; }
    .phase-card ul { font-size: 14px; }

    /* ── Intensity methods grid ── */
    .method-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 14px;
      margin: 24px 0;
    }
    .method-card {
      background: #fff;
      border: 1.5px solid #e5e7eb;
      border-radius: 10px;
      padding: 18px 16px;
      transition: border-color 0.2s;
    }
    .method-card:hover { border-color: #0f3460; }
    .method-card h4 { margin: 0 0 6px; font-size: 0.95rem; color: #0f3460; }
    .method-card p { font-size: 13px; color: #4b5563; margin: 0; }

    /* ── Key takeaways ── */
    .takeaways {
      background: linear-gradient(135deg, #0f3460, #1a237e);
      color: #fff;
      border-radius: 16px;
      padding: 36px 40px;
      margin-top: 56px;
    }
    .takeaways h2 {
      color: #fbbf24;
      border-color: #fbbf24;
      font-size: 1.4rem;
      margin-top: 0;
    }
    .takeaways ul { padding-left: 20px; }
    .takeaways li {
      color: rgba(255,255,255,0.9);
      margin-bottom: 12px;
      font-size: 15px;
      line-height: 1.6;
    }
    .takeaways li strong { color: #fbbf24; }

    /* ── Formula box ── */
    .formula {
      background: #1e293b;
      color: #e2e8f0;
      font-family: 'Courier New', monospace;
      font-size: 15px;
      padding: 18px 24px;
      border-radius: 10px;
      margin: 20px 0;
      border-left: 4px solid #fbbf24;
    }
    .formula span { color: #fbbf24; font-weight: 700; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .hero { padding: 36px 24px; }
      .hero h1 { font-size: 1.75rem; }
      h2 { font-size: 1.4rem; }
      .anatomy-grid { grid-template-columns: 1fr; }
      .stat-row { grid-template-columns: 1fr 1fr; }
    }

/* === Site-integration fixes === */
/* Clear the fixed Nav at top + mobile tab bar at bottom */
.blog-container { padding: 100px 24px 140px !important; }
@media (max-width: 600px) {
  .blog-container { padding: 90px 16px 120px !important; }
}
/* Anchor jumps land below Nav */
h2[id], .section[id], .hero, .takeaways { scroll-margin-top: 90px; }

/* Cross-link banner at bottom */
.crosslink-bottom {
  background: linear-gradient(135deg,#f1f5f9,#e2e8f0);
  border: 1px solid #cbd5e1;
  border-left: 4px solid #e94560;
  border-radius: 12px;
  padding: 32px 36px;
  margin: 56px 0 0;
  text-align: center;
}
.crosslink-bottom h3 {
  font-size: 1.2rem; font-weight: 700; color: #0f3460;
  margin: 0 0 8px;
}
.crosslink-bottom p { font-size: 14px; color: #475569; margin: 0 0 18px; }
.crosslink-bottom a {
  display: inline-block; background: #0f3460; color: #fff;
  padding: 12px 28px; border-radius: 24px;
  font-size: 14px; font-weight: 700; text-decoration: none;
  transition: background 0.2s, transform 0.2s;
}
.crosslink-bottom a:hover { background: #e94560; transform: translateY(-2px); }
@media (max-width: 600px) {
  .crosslink-bottom { padding: 24px 20px; }
  .crosslink-bottom h3 { font-size: 1.05rem; }
}
</style>

