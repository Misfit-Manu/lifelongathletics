---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Preparticipation Health Screening — Theory Guide | ACE Prep · Lifelong Athletics" description="Complete theory guide covering the ACSM Preparticipation Algorithm, 3-Step Checklist, PAR-Q+, 9 Signs & Symptoms, Cardiac Rehab, Additional Forms, and Medications & Exercise HR for ACE-CPT Chapter 5.">

<style is:global>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif;
  font-size: 17px;
  line-height: 1.75;
  color: #1a1a2e;
  background: #f7f6f2;
}
.blog-container {
  max-width: 860px;
  margin: 0 auto;
  padding: 40px 24px 80px;
  background: #f7f6f2;
}

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, #0d1f35 0%, #0a1a28 50%, #0f2028 100%);
  color: #fff;
  border-radius: 16px;
  padding: 56px 48px;
  margin-bottom: 48px;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -40px; right: -40px;
  width: 280px; height: 280px;
  background: rgba(197,241,53,0.06);
  border-radius: 50%;
}
.hero-tag {
  display: inline-block;
  background: #c5f135;
  color: #000;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 4px 14px;
  border-radius: 20px;
  margin-bottom: 20px;
}
.hero h1 {
  font-size: clamp(24px, 4vw, 38px);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16px;
  max-width: 640px;
}
.hero p {
  color: rgba(255,255,255,0.65);
  font-size: 15px;
  max-width: 560px;
  margin-bottom: 24px;
}
.back-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #c5f135;
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
}
.back-link:hover { text-decoration: underline; }

/* ── TOC BAR ── */
.toc-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(247,246,242,0.98);
  border-bottom: 1px solid #dddbd6;
  padding: 0;
  margin-bottom: 48px;
  overflow-x: auto;
  white-space: nowrap;
}
.toc-inner {
  display: inline-flex;
  gap: 0;
  padding: 0 4px;
}
.toc-link {
  display: inline-block;
  padding: 14px 16px;
  font-size: 12px;
  font-weight: 600;
  color: #6b7280;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border-bottom: 2px solid transparent;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}
.toc-link:hover { color: #111; border-bottom-color: #c5f135; }

/* ── SECTION ── */
.section { margin-bottom: 64px; }
.section-tag {
  display: inline-block;
  background: #c5f135;
  color: #000;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 3px 12px;
  border-radius: 20px;
  margin-bottom: 16px;
}
.section-tag.teal   { background: #22d3ee; color: #000; }
.section-tag.blue   { background: #3b82f6; color: #fff; }
.section-tag.purple { background: #a855f7; color: #fff; }
.section-tag.orange { background: #f97316; color: #fff; }
.section-tag.green  { background: #10b981; color: #fff; }
.section-tag.red    { background: #ef4444; color: #fff; }
.section h2 {
  font-size: clamp(22px, 3vw, 30px);
  font-weight: 800;
  color: #111827;
  margin-bottom: 16px;
  line-height: 1.25;
}
.section p {
  color: #374151;
  margin-bottom: 18px;
  font-size: 16px;
}
.section p strong { color: #111827; }

/* ── DIVIDER ── */
.divider { height: 1px; background: #e5e7eb; margin: 56px 0; }

/* ── CALLOUT ── */
.callout {
  background: #ffffff;
  border-left: 4px solid #c5f135;
  border-radius: 0 8px 8px 0;
  padding: 16px 20px;
  margin: 24px 0;
}
.callout.teal   { border-left-color: #22d3ee; }
.callout.blue   { border-left-color: #3b82f6; }
.callout.purple { border-left-color: #a855f7; }
.callout.orange { border-left-color: #f97316; }
.callout.green  { border-left-color: #10b981; }
.callout.red    { border-left-color: #ef4444; }
.callout p { font-size: 14px; margin: 0 0 6px; color: #374151; line-height: 1.65; }
.callout p:last-child { margin-bottom: 0; }
.callout strong { color: #111; }
.callout ul { padding-left: 18px; margin-top: 6px; }
.callout li { font-size: 14px; color: #374151; margin-bottom: 4px; line-height: 1.55; }

/* ── CARD GRID ── */
.card-grid {
  display: grid;
  gap: 14px;
  margin: 24px 0;
}
.card-grid-2 { grid-template-columns: 1fr 1fr; }
.card-grid-3 { grid-template-columns: 1fr 1fr 1fr; }

.card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 18px;
  border-left: 3px solid #c5f135;
}
.card.teal   { border-left-color: #22d3ee; }
.card.blue   { border-left-color: #3b82f6; }
.card.purple { border-left-color: #a855f7; }
.card.orange { border-left-color: #f97316; }
.card.green  { border-left-color: #10b981; }
.card.red    { border-left-color: #ef4444; }
.card h4 {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 8px;
  color: #111;
}
.card p { font-size: 13px; color: #374151; margin: 0; line-height: 1.6; }
.card ul { padding-left: 16px; margin-top: 4px; }
.card li { font-size: 13px; color: #374151; margin-bottom: 4px; line-height: 1.5; }

/* ── ALGORITHM TABLE ── */
.alg-table { width: 100%; border-collapse: collapse; margin: 24px 0; }
.alg-table th, .alg-table td {
  padding: 14px 16px;
  text-align: left;
  font-size: 14px;
  border: 1px solid #e5e7eb;
  vertical-align: top;
}
.alg-table thead th {
  background: #eeece9;
  color: #6b7280;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.alg-table .row-label {
  background: #ffffff;
  font-weight: 700;
  color: #111827;
  font-size: 13px;
  white-space: nowrap;
}
.alg-table td.cell-safe   { background: #f0fdf4; color: #16a34a; font-weight: 600; }
.alg-table td.cell-caution { background: #fff7ed; color: #c2410c; font-weight: 600; }
.alg-table td.cell-stop   { background: #fef2f2; color: #dc2626; font-weight: 600; }
.alg-table td p { font-size: 13px; font-weight: 400; color: #374151; margin-top: 4px; }

/* ── 3-STEP CHECKLIST ── */
.steps { margin: 24px 0; }
.step {
  display: flex;
  gap: 20px;
  padding: 20px 0;
  border-bottom: 1px solid #e5e7eb;
}
.step:last-child { border-bottom: none; }
.step-num {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 18px;
}
.step-num.teal   { background: #e0f9fe; color: #0891b2; }
.step-num.orange { background: #fff7ed; color: #ea580c; }
.step-num.green  { background: #f0fdf4; color: #16a34a; }
.step-body h3 { font-size: 16px; font-weight: 700; color: #111827; margin-bottom: 6px; }
.step-body p { font-size: 14px; color: #374151; margin-bottom: 8px; line-height: 1.6; }
.step-body ul { padding-left: 18px; margin-bottom: 8px; }
.step-body li { font-size: 14px; color: #374151; margin-bottom: 4px; line-height: 1.5; }

/* ── STOP CALLOUT ── */
.stop-callout {
  background: #fef2f2;
  border: 1px solid #fca5a5;
  border-left: 4px solid #ef4444;
  border-radius: 0 8px 8px 0;
  padding: 14px 18px;
  margin-top: 12px;
}
.stop-callout h4 { font-size: 13px; font-weight: 800; color: #dc2626; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
.stop-callout p  { font-size: 13px; color: #374151; margin: 0; line-height: 1.55; }

/* ── SYMPTOM GRID ── */
.symptom-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 10px;
  margin: 24px 0;
}
.symptom-item {
  background: #fef2f2;
  border: 1px solid #fca5a5;
  border-left: 3px solid #ef4444;
  border-radius: 0 8px 8px 0;
  padding: 12px 14px;
}
.symptom-item strong {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: #dc2626;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 4px;
}
.symptom-item p { font-size: 13px; color: #374151; margin: 0; line-height: 1.5; }

/* ── FORM CARDS ── */
.forms-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin: 24px 0; }
.form-card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-top: 3px solid #f97316;
  border-radius: 10px;
  padding: 20px;
}
.form-card h4 { font-size: 14px; font-weight: 700; color: #c2410c; margin-bottom: 8px; }
.form-card p  { font-size: 13px; color: #374151; margin-bottom: 8px; line-height: 1.6; }
.form-card ul { padding-left: 16px; }
.form-card li { font-size: 13px; color: #374151; margin-bottom: 3px; }

/* ── MEDICATIONS TABLE ── */
.med-table-wrap { overflow-x: auto; margin: 24px 0; border-radius: 10px; border: 1px solid #e5e7eb; }
.med-table { width: 100%; border-collapse: collapse; font-size: 14px; }
.med-table thead th {
  background: #eeece9;
  color: #6b7280;
  font-weight: 700;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 12px 14px;
  text-align: left;
  border-bottom: 1px solid #e5e7eb;
}
.med-table tbody tr { border-top: 1px solid #e5e7eb; }
.med-table tbody tr:hover td { background: #ffffff; }
.med-table tbody td { padding: 12px 14px; color: #374151; vertical-align: top; }
.med-table td.drug-name { font-weight: 700; color: #111827; }
.med-table td.up   { color: #dc2626; font-weight: 700; }
.med-table td.down { color: #16a34a; font-weight: 700; }
.med-table td.flat { color: #9ca3af; }
.med-table td.var  { color: #d97706; font-style: italic; }

/* ── DEEP DIVE CARDS ── */
.deep-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; margin: 24px 0; }
.deep-card {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 18px;
  border-top: 3px solid #6b7280;
}
.deep-card.red    { border-top-color: #ef4444; }
.deep-card.orange { border-top-color: #f97316; }
.deep-card.blue   { border-top-color: #3b82f6; }
.deep-card.purple { border-top-color: #a855f7; }
.deep-card.green  { border-top-color: #10b981; }
.deep-card.teal   { border-top-color: #22d3ee; }
.deep-card h4 { font-size: 14px; font-weight: 700; color: #111827; margin-bottom: 8px; }
.deep-card p  { font-size: 13px; color: #374151; margin: 0; line-height: 1.6; }

/* ── KEY TAKEAWAYS ── */
.takeaways {
  background: #f0fdf4;
  border: 1px solid #bbf7d0;
  border-radius: 12px;
  padding: 32px;
  margin: 48px 0;
}
.takeaways h3 {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #16a34a;
  margin-bottom: 20px;
}
.takeaway-item {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  padding: 10px 0;
  border-bottom: 1px solid #d1fae5;
}
.takeaway-item:last-child { border: none; }
.tick { color: #16a34a; font-size: 14px; margin-top: 3px; flex-shrink: 0; }
.takeaway-item p { font-size: 14px; color: #374151; margin: 0; line-height: 1.55; }

/* ── BACK FOOTER ── */
.page-footer {
  text-align: center;
  color: #9ca3af;
  font-size: 13px;
  padding: 32px 24px;
  border-top: 1px solid #e5e7eb;
  margin-top: 64px;
}
.page-footer a { color: #374151; font-weight: 600; text-decoration: none; }
.page-footer a:hover { color: #000; }

/* ── INTENSITY TABLE ── */
.int-table { width: 100%; border-collapse: collapse; margin: 16px 0; }
.int-table th, .int-table td {
  padding: 10px 14px;
  text-align: left;
  font-size: 13px;
  border-bottom: 1px solid #e5e7eb;
}
.int-table th { background: #eeece9; color: #6b7280; font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
.int-table tr:hover td { background: #ffffff; }
.int-lbl-light  { color: #22d3ee; font-weight: 700; }
.int-lbl-mod    { color: #f97316; font-weight: 700; }
.int-lbl-vig    { color: #ef4444; font-weight: 700; }

@media (max-width: 680px) {
  .hero { padding: 36px 24px; }
  .card-grid-2, .card-grid-3, .deep-grid, .forms-grid, .symptom-grid { grid-template-columns: 1fr; }
  .alg-table td, .alg-table th { font-size: 12px; padding: 10px 10px; }
  .step { flex-direction: column; gap: 12px; }
}

