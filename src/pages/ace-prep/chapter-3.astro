function buildCases() {
  const sec = document.getElementById('case-mcq-section');
  sec.innerHTML = '';
  const letters = ['A','B','C','D'];
  let qn = 0;
  CASES.forEach((cs, ci) => {
    const block = document.createElement('div');
    block.className = 'case-block';
    block.innerHTML = `
      <div class="case-header">
        <div class="case-num-badge">${cs.num}</div>
        <div class="case-topic-label">${cs.topic}</div>
      </div>
      <div class="scenario-box">${cs.scenario}</div>
    `;
    cs.qs.forEach((q, qi) => {
      qn++;
      const card = document.createElement('div');
      card.className = 'q-card';
      card.id = `cq-${qn}`;
      card.innerHTML = `
        <div class="q-num">Question ${qn}</div>
        <div class="q-text">${q.q}</div>
        <div class="q-options">
          ${q.opts.map((o, oi) => `
            <div class="q-option" onclick="pickCase(${ci},${qi},${oi},this)">
              <span class="opt-letter">${letters[oi]}</span>
              <span>${o}</span>
            </div>`).join('')}
        </div>
        <div class="answer-banner" id="cbanner-${qn}"></div>
      `;
      block.appendChild(card);
    });
    sec.appendChild(block);
  });
}

function pickCase(ci, qi, oi, el) {
  if (caseGraded) return;
  const opts = el.closest('.q-options').querySelectorAll('.q-option');
  opts.forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  caseAnswers[`${ci}-${qi}`] = oi;
  updateCaseProgress();
}

function updateCaseProgress() {
  const done = Object.keys(caseAnswers).length;
  const pct  = Math.round((done / 35) * 100);
  document.getElementById('case-progress-text').textContent = `${done} of 35 answered`;
  document.getElementById('case-progress-pct').textContent  = `${pct}%`;
  document.getElementById('case-prog-bar').style.width       = `${pct}%`;
}

function submitCases() {
  if (caseGraded) return;
  caseGraded = true;
  document.getElementById('case-submit-btn').disabled = true;
  const letters = ['A','B','C','D'];
  let correct = 0, wrong = 0, skip = 0;
  let qn = 0;
  CASES.forEach((cs, ci) => {
    cs.qs.forEach((q, qi) => {
      qn++;
      const sel  = caseAnswers[`${ci}-${qi}`];
      const opts = document.querySelectorAll(`#cq-${qn} .q-option`);
      opts.forEach(o => { o.style.pointerEvents = 'none'; });
      if (sel === undefined) {
        opts[q.ans].classList.add('reveal-correct');
        skip++;
        showCaseBanner(qn, `Correct: ${letters[q.ans]}) ${q.opts[q.ans]}`);
      } else if (sel === q.ans) {
        opts[sel].classList.add('correct-ans');
        correct++;
      } else {
        opts[sel].classList.add('wrong-ans');
        opts[q.ans].classList.add('reveal-correct');
        wrong++;
        showCaseBanner(qn, `Correct: ${letters[q.ans]}) ${q.opts[q.ans]}`);
      }
    });
  });
  showModal(correct, wrong, skip);
}

function showCaseBanner(qn, msg) {
  const el = document.getElementById(`cbanner-${qn}`);
  if (el) { el.textContent = msg; el.classList.add('show'); }
}

function retakeCases() {
  caseAnswers = {};
  caseGraded  = false;
  document.getElementById('result-modal').classList.remove('open');
  document.getElementById('case-submit-btn').disabled = false;
  buildCases();
  updateCaseProgress();
  document.getElementById('tab-cases').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function showModal(correct, wrong, skip) {
  const pct   = Math.round((correct / 35) * 100);
  const grade = pct >= 90 ? 'A' : pct >= 80 ? 'B' : pct >= 70 ? 'C' : 'D';
  const bands = {
    A: "Strong command of behavior change theory — ready to apply these models with real clients.",
    B: "Solid understanding. Review any missed questions and reinforce the weaker topics.",
    C: "Core concepts need more review. Revisit the Theory Guide and focus on missed areas.",
    D: "Return to the chapter material before retaking. Focus on the models you found hardest."
  };
  const titles = { A:"Excellent Work!", B:"Well Done!", C:"Good Effort!", D:"Keep Studying!" };

  document.getElementById('modal-ring').className    = `modal-grade-ring grade-${grade}`;
  document.getElementById('modal-ring').textContent  = grade;
  document.getElementById('modal-title').textContent = titles[grade];
  document.getElementById('modal-correct').textContent = correct;
  document.getElementById('modal-wrong').textContent   = wrong;
  document.getElementById('modal-skip').textContent    = skip;
  document.getElementById('modal-pct').textContent     = pct + '%';
  document.getElementById('modal-band').textContent    = bands[grade];
  document.getElementById('result-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('result-modal').classList.remove('open');
}

