            <tr><td><strong style="color:var(--mtv-green)">Intensity</strong></td><td>% of 1-RM; inversely related to volume</td><td class="td-green">Strength ≥85% | Hypertrophy 67–85%</td></tr>
            <tr><td><strong style="color:var(--mtv-purple)">Tempo</strong></td><td>6 sec/rep standard; concentric 1–3 sec, eccentric 2–4 sec</td><td class="td-purple">Eccentric = DOMS trigger</td></tr>
            <tr><td><strong style="color:var(--mtv-teal)">Rest</strong></td><td>Longer rest for heavier loads; PC: 50/75/95% at 30s/1min/2min</td><td class="td-teal">Endurance ≤30s | Strength 2–5 min</td></tr>
          </tbody>
        </table>
      </div>
    </section>

