          <div class="mg-band-label"><div class="name">A-BAND</div><div class="desc">Myosin + actin<br>overlap zone</div></div>
          <div class="mg-band-label"><div class="name">I-BAND</div><div class="desc">Actin only<br>no myosin</div></div>
