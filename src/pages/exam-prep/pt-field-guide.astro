<div id="pfg-page-muscles" class="pfg-page">
<div class="pfg-container">

  <div class="pfg-section-label">
    <div class="pfg-sl-num">03</div>
    <div class="pfg-sl-text"><h2>Muscle Group Reference</h2><p>Anatomy, exercises, training frequency by group</p></div>
  </div>

  <div class="pfg-muscle-body-wrap">

    <!-- CHEST -->
    <div class="pfg-muscle-region">
      <div class="pfg-muscle-region-header pfg-mr-chest">💪 CHEST — Pectoralis</div>
      <div class="pfg-muscle-region-body">
        <p>Muscles</p>
        <ul>
          <li>Pectoralis major (upper/mid/lower)</li>
          <li>Pectoralis minor (beneath major)</li>
          <li>Serratus anterior (assists)</li>
        </ul>
        <p style="margin-top:10px;">Exercises</p>
        <ul>
          <li>Barbell bench press (mid)</li>
          <li>Incline DB press (upper)</li>
          <li>Decline press (lower)</li>
          <li>Cable chest fly (mid)</li>
          <li>Push-up variations (all)</li>
          <li>Dips (lower pec emphasis)</li>
          <li>Machine pec-deck</li>
        </ul>
        <p style="margin-top:10px;">Frequency</p>
        <ul><li>2–3× per week, ≥48–72 hr rest</li></ul>
      </div>
    </div>

    <!-- BACK -->
    <div class="pfg-muscle-region">
      <div class="pfg-muscle-region-header pfg-mr-back">🎯 BACK — Posterior Chain Upper</div>
      <div class="pfg-muscle-region-body">
        <p>Muscles</p>
        <ul>
