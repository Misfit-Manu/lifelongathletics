---
import { getCollection } from 'astro:content';
import { render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const examEntries = await getCollection('exam');
  return examEntries.map(entry => ({
    params: { id: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} — Lifelong Athletics`} description={entry.data.description}>
  
  <div class="back-bar">
    <a href="/exam-prep" class="back-link">← Back to Exam study hub</a>
  </div>

  <header class="article-header">
    <p class="article-category">Exam Prep / {entry.data.topic.toUpperCase()}</p>
    <h1 class="article-title">{entry.data.title}</h1>
    <p class="article-subtitle">{entry.data.description}</p>
    <div class="article-meta">
      <span class="meta-author">Lifelong Athletics Academy</span>
      <div class="meta-divider"></div>
      <span>{entry.data.duration}</span>
      <div class="meta-divider"></div>
      <span>Target: {entry.data.exams}</span>
    </div>
  </header>

  <article class="article-body">
    <Content />
  </article>

<style>
  .back-bar { max-width: 780px; margin: 0 auto; padding: 110px 40px 0; }
  .back-link {
    font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; display: inline-flex;
    align-items: center; gap: 8px; transition: color 0.2s;
  }
  .back-link:hover { color: var(--gold); }

  .article-header {
    max-width: 780px; margin: 0 auto; padding: 40px 40px 60px;
    border-bottom: 1px solid var(--border);
    opacity: 0;
    animation: fadeUp 0.9s ease 0.1s forwards;
  }
  .article-category {
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 20px;
  }
  .article-title {
    font-family: var(--font-display); font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 300; line-height: 1.1; margin-bottom: 24px; color: var(--white);
  }
  .article-subtitle {
    font-size: 1.1rem; color: var(--muted); line-height: 1.7;
    margin-bottom: 32px; font-style: italic; font-family: var(--font-display);
  }
  .article-meta {
    display: flex; align-items: center; gap: 24px; font-size: 0.75rem; color: var(--muted);
  }
  .meta-divider { width: 1px; height: 12px; background: var(--border); }
  .meta-author { color: var(--white); }

  .article-body {
    max-width: 780px; margin: 0 auto; padding: 60px 40px 100px;
    opacity: 0; animation: fadeUp 0.9s ease 0.3s forwards;
  }
  
  .article-body :global(p) {
    font-size: 1rem; color: rgba(245,240,232,0.8); line-height: 1.85; margin-bottom: 28px;
  }
  .article-body :global(h2) {
    font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 300;
    color: var(--white); margin: 56px 0 20px; padding-top: 56px; border-top: 1px solid var(--border); line-height: 1.2;
  }
  .article-body :global(h2 em) { font-style: italic; color: var(--gold); }
  .article-body :global(h3) {
    font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; color: var(--white); margin: 36px 0 16px;
  }
  .article-body :global(strong) { font-weight: 500; color: var(--gold); }
  .article-body :global(ul), .article-body :global(ol) { margin: 0 0 28px 24px; color: rgba(245,240,232,0.8); }
  .article-body :global(li) { font-size: 1rem; line-height: 1.8; margin-bottom: 8px; }
  .article-body :global(ul li::marker) { color: var(--gold); }

  .article-body :global(.callout) {
    background: var(--surface); border-left: 3px solid var(--gold); padding: 24px 28px; margin: 36px 0; border-radius: 0 2px 2px 0;
  }
  .article-body :global(.callout p) {
    margin: 0 !important; font-family: var(--font-display); font-size: 1.15rem; font-style: italic; color: var(--white) !important; line-height: 1.6;
  }

  .article-body :global(.takeaway) {
    background: rgba(201,168,76,0.06); border: 1px solid rgba(201,168,76,0.2); padding: 28px 32px; margin: 40px 0; border-radius: 2px;
  }
  .article-body :global(.takeaway-label) {
    font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; display: block;
  }
  .article-body :global(.takeaway p) {
    margin: 0 !important; font-size: 0.95rem !important; color: rgba(245,240,232,0.85) !important;
  }
  .article-body :global(.section-divider) {
    width: 40px; height: 1px; background: var(--gold); opacity: 0.4; margin: 48px 0;
  }
  .article-body :global(.article-cta) {
    background: var(--surface); border: 1px solid var(--border); border-top: 2px solid var(--gold); padding: 40px; margin-top: 60px; text-align: center; border-radius: 2px;
  }
  .article-body :global(.article-cta p) {
    font-family: var(--font-display); font-size: 1.5rem; font-style: italic; color: var(--white) !important; margin-bottom: 8px !important;
  }
  .article-body :global(.article-cta span) {
    font-size: 0.85rem; color: var(--muted); display: block; margin-bottom: 24px;
  }
  .article-body :global(.btn-gold) {
    display: inline-block; background: var(--gold); color: var(--black); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; padding: 14px 36px; border-radius: 2px; text-decoration: none; transition: opacity 0.2s;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .back-bar { padding: 100px 24px 0; }
    .article-header, .article-body { padding-left: 24px; padding-right: 24px; }
  }
</style>
</Layout>
