---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Fetch all the raw markdown exams the user creates
const allExams = await getCollection('exam');

// Organize the categories
const topics = [
  { id: 'muscle', title: 'Muscle Specific <em>Exercises</em>', desc: 'Targeted movement breakdowns' }
];
---

<Layout title="Exam Prep — Lifelong Athletics" description="Concept-first breakdowns of the exercise science topics that matter most.">
  
  <div class="page-hero">
    <p class="eyebrow">Fitness Certification Study Hub</p>
    <h1>Learn the science.<br/><em>Ace the exam.</em></h1>
    <p>Concept-first breakdowns of the exercise science topics that matter most — written the way they should have been taught. No fluff, no memorisation tricks. Just understanding.</p>
  </div>

  <div class="exam-strip">
    <span class="exam-strip-label">Concepts relevant to</span>
    <span class="exam-badge">ACE-CPT</span>
    <span class="exam-badge">NASM-CPT</span>
    <span class="exam-badge">NASM-CES</span>
    <span class="exam-badge">CSCS</span>
    <span class="exam-badge">ERPS</span>
    <span class="exam-note">Not exam-specific — universal exercise science.</span>
  </div>

  <div class="ace-banner-wrap">
    <a href="/ace-prep" class="ace-banner">
      <span class="ace-banner-glow"></span>
      <div class="ace-banner-top">
        <span class="ace-tag">✦ The Complete ACE-CPT System</span>
        <span class="ace-free-badge">100% Free</span>
      </div>
      <h2>Chapterwise <em>ACE</em> Preparation</h2>
      <p class="ace-pain">Stop re-reading the 400-page manual. Master each chapter once — with mind maps, quizzes, and real exam-style case studies — then walk in knowing you'll pass.</p>
      <div class="ace-features">
        <span class="ace-feature"><span class="afi">🧠</span> Mind Maps</span>
        <span class="ace-feature"><span class="afi">📝</span> Theory Quizzes</span>
        <span class="ace-feature"><span class="afi">🩺</span> Case Studies</span>
        <span class="ace-feature"><span class="afi">📋</span> Quick Reference</span>
      </div>
      <div class="ace-stats">
        <div class="ace-stat"><strong>17</strong><span>Chapters</span></div>
        <div class="ace-stat"><strong>1,000+</strong><span>Quiz Questions</span></div>
        <div class="ace-stat"><strong>300+</strong><span>Case Studies</span></div>
      </div>
      <span class="ace-cta">Start Studying — Free <span class="ace-cta-arrow">→</span></span>
    </a>
  </div>

  <div class="filter-wrap">
    <button class="filter-btn active" onclick="filterCards('all', this)">All Topics</button>
    {topics.map(t => (
      <button class="filter-btn" onclick={`filterCards('${t.id}', this)`}>{t.title.replace(/<[^>]*>?/gm, '')}</button>
    ))}
  </div>

  <div class="topics-wrap">
    {topics.map(topicGroup => {
      // Find the markdown markdown posts that belong to this category
      const activeExams = allExams.filter(exam => exam.data.topic.toLowerCase() === topicGroup.id);
      
      return (
        <div class="topic-section" data-section={topicGroup.id}>
          <div class="topic-section-header">
            <h2 class="topic-section-title" set:html={topicGroup.title}></h2>
            <span class="topic-count">{topicGroup.desc}</span>
          </div>
          <div class="cards-grid">
            
            {/* The Dynamically rendered content */}
            {activeExams.map(post => (
              <a href={`/exam-prep/${post.id}`} class="article-card" data-topic={topicGroup.id}>
                <div class="card-body">
                  <div class="card-tags">
                    <span class="tag tag-topic" style="text-transform: capitalize;">{topicGroup.id}</span>
                    <span class="tag tag-exam">{post.data.exams}</span>
                  </div>
                  <h3 class="card-title">{post.data.title}</h3>
                  <p class="card-desc">{post.data.description}</p>
                  <div class="card-footer">
                    <span class="card-read">{post.data.duration}</span>
                    <span class="card-arrow">→</span>
                  </div>
                </div>
              </a>
            ))}

            {/* The Fallback Placeholders */}
            <div class="article-card coming" data-topic={topicGroup.id}>
              <div class="card-body">
                <div class="card-tags"><span class="tag tag-soon">Coming soon</span></div>
                <h3 class="card-title" style="color:var(--muted)">More {topicGroup.id} modules</h3>
                <p class="card-desc" style="opacity:0.5">High-yield study guides are currently in development.</p>
                <div class="card-footer"><span class="card-soon-label">Not published yet</span></div>
              </div>
            </div>

          </div>
        </div>
      );
    })}
  </div>

<style>
  .page-hero {
    padding: 160px 60px 80px; border-bottom: 1px solid var(--border); max-width: 1100px; margin: 0 auto;
  }
  .eyebrow {
    font-size: 0.8rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; opacity: 0; animation: fadeUp 0.8s ease 0.2s forwards;
  }
  .page-hero h1 {
    font-family: var(--font-display); font-size: clamp(3rem, 7vw, 6rem); font-weight: 300; line-height: 1; margin-bottom: 24px; opacity: 0; animation: fadeUp 0.9s ease 0.3s forwards;
  }
  .page-hero h1 em { font-style: italic; color: var(--gold); }
  .page-hero p {
    font-size: 1rem; color: var(--muted); max-width: 560px; line-height: 1.8; opacity: 0; animation: fadeUp 0.9s ease 0.4s forwards;
  }

  .exam-strip {
    max-width: 1100px; margin: 0 auto; padding: 40px 60px; display: flex; align-items: center; gap: 16px; flex-wrap: wrap; border-bottom: 1px solid var(--border); opacity: 0; animation: fadeUp 0.8s ease 0.5s forwards;
  }
  .exam-strip-label { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-right: 8px; }
  .exam-badge { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 500; padding: 6px 16px; border-radius: 2px; border: 1px solid rgba(201,168,76,0.3); color: var(--gold); background: rgba(201,168,76,0.05); }
  .exam-note { font-size: 0.78rem; color: var(--muted); margin-left: auto; font-style: italic; }

  .ace-banner-wrap { max-width: 1100px; margin: 0 auto; padding: 60px 60px 0; opacity: 0; animation: fadeUp 0.8s ease 0.55s forwards; }
  .ace-banner { position: relative; overflow: hidden; display: flex; flex-direction: column; align-items: flex-start; gap: 22px; background: linear-gradient(135deg, rgba(197,241,53,0.07), rgba(197,241,53,0.012) 60%); border: 1px solid rgba(197,241,53,0.28); border-radius: 12px; padding: 40px 44px; text-decoration: none; transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s; animation: aceGlow 3.6s ease-in-out 1.4s infinite; }
  .ace-banner:hover { transform: translateY(-4px); border-color: #c5f135; box-shadow: 0 14px 50px rgba(197,241,53,0.16); animation-play-state: paused; }
  .ace-banner > *:not(.ace-banner-glow) { position: relative; z-index: 1; }
  .ace-banner-glow { position: absolute; top: -90px; right: -70px; width: 360px; height: 360px; background: radial-gradient(circle, rgba(197,241,53,0.13), transparent 70%); border-radius: 50%; pointer-events: none; z-index: 0; }

  .ace-banner-top { display: flex; align-items: center; justify-content: space-between; width: 100%; gap: 16px; }
  .ace-tag { display: inline-flex; align-items: center; gap: 6px; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: #c5f135; background: rgba(197,241,53,0.1); padding: 6px 13px; border-radius: 20px; font-weight: 600; }
  .ace-free-badge { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; font-weight: 700; color: #080808; background: #c5f135; padding: 6px 14px; border-radius: 20px; white-space: nowrap; }

  .ace-banner h2 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.9rem); color: var(--white); margin: 0; line-height: 1.05; font-weight: 400; }
  .ace-banner h2 em { font-style: italic; color: #c5f135; }
  .ace-pain { font-size: 0.98rem; color: rgba(245,240,232,0.62); max-width: 640px; line-height: 1.65; margin: -6px 0 0; }

  .ace-features { display: flex; flex-wrap: wrap; gap: 10px; }
  .ace-feature { display: inline-flex; align-items: center; gap: 7px; font-size: 0.8rem; font-weight: 500; color: var(--white); background: rgba(255,255,255,0.03); border: 1px solid rgba(197,241,53,0.2); padding: 8px 15px; border-radius: 24px; transition: border-color 0.2s, background 0.2s; }
  .ace-banner:hover .ace-feature { border-color: rgba(197,241,53,0.4); }
  .ace-feature .afi { font-size: 0.95rem; line-height: 1; }

  .ace-stats { display: flex; flex-wrap: wrap; gap: 40px; width: 100%; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08); }
  .ace-stat { display: flex; flex-direction: column; gap: 3px; }
  .ace-stat strong { font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: #c5f135; line-height: 1; }
  .ace-stat span { font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }

  .ace-cta { display: inline-flex; align-items: center; gap: 10px; background: #c5f135; color: #080808; font-family: var(--font-body); font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 15px 34px; border-radius: 30px; transition: gap 0.25s, box-shadow 0.3s; }
  .ace-banner:hover .ace-cta { gap: 16px; box-shadow: 0 8px 24px rgba(197,241,53,0.32); }
  .ace-cta-arrow { font-size: 1.05rem; }

  @keyframes aceGlow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(197,241,53,0); border-color: rgba(197,241,53,0.28); }
    50%      { box-shadow: 0 0 32px rgba(197,241,53,0.1); border-color: rgba(197,241,53,0.5); }
  }
  @media (prefers-reduced-motion: reduce) { .ace-banner { animation: none; } }

  .filter-wrap { max-width: 1100px; margin: 0 auto; padding: 40px 60px 0; display: flex; gap: 8px; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.8s ease 0.6s forwards; }
  .filter-btn { font-family: var(--font-body); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); background: transparent; border: 1px solid var(--border); padding: 8px 20px; border-radius: 2px; cursor: pointer; transition: all 0.2s; }
  .filter-btn:hover { color: var(--white); border-color: rgba(255,255,255,0.2); }
  .filter-btn.active { color: var(--gold); border-color: var(--gold); }

  .topics-wrap { max-width: 1100px; margin: 0 auto; padding: 60px 60px 120px; }
  .topic-section { margin-bottom: 72px; }
  .topic-section-header { display: flex; align-items: baseline; gap: 20px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid var(--border); }
  .topic-section-title { font-family: var(--font-display); font-size: 1.6rem; font-weight: 300; color: var(--white); }
  .topic-section-title :global(em) { font-style: italic; color: var(--gold); }
  .topic-count { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }

  .cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); }
  .article-card { background: var(--surface); text-decoration: none; display: flex; flex-direction: column; transition: background 0.3s; position: relative; overflow: hidden; opacity: 1; }
  .article-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--gold); transform: scaleX(0); transition: transform 0.3s ease; transform-origin: left; }
  .article-card:hover::before { transform: scaleX(1); }
  .article-card:hover { background: var(--surface2); }
  
  .article-card.coming { cursor: default; }
  .article-card.coming:hover { background: var(--surface); }
  .article-card.coming::before { display: none; }

  .card-body { padding: 32px 28px; flex: 1; display: flex; flex-direction: column; }
  .card-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
  .tag { font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 3px 8px; border-radius: 2px; }
  .tag-topic { background: rgba(201,168,76,0.08); color: var(--gold); border: 1px solid rgba(201,168,76,0.2); }
  .tag-exam  { background: rgba(255,255,255,0.04); color: var(--muted); border: 1px solid var(--border); }
  .tag-soon  { background: transparent; color: var(--muted); border: 1px dashed var(--border); }

  .card-title { font-family: var(--font-display); font-size: 1.3rem; font-weight: 300; line-height: 1.25; color: var(--white); margin-bottom: 10px; flex: 1; }
  .card-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.6; margin-bottom: 20px; }
  .card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 16px; border-top: 1px solid var(--border); }
  .card-read { font-size: 0.7rem; color: var(--muted); }
  .card-arrow { font-size: 0.85rem; color: var(--gold); transition: transform 0.2s; }
  .article-card:hover .card-arrow { transform: translateX(4px); }
  .card-soon-label { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); }

  @media (max-width: 768px) {
    .page-hero { padding: 120px 24px 60px; }
    .exam-strip { padding: 32px 24px; }
    .ace-banner-wrap { padding: 32px 24px 0; }
    .ace-banner { padding: 28px 24px; gap: 18px; }
    .ace-banner h2 { font-size: 1.75rem; }
    .ace-stats { gap: 22px; }
    .ace-stat strong { font-size: 1.6rem; }
    .ace-cta { width: 100%; justify-content: center; }
    .filter-wrap { padding: 32px 24px 0; }
    .topics-wrap { padding: 40px 24px 80px; }
    .cards-grid { grid-template-columns: 1fr; }
    .topic-section-header { flex-direction: column; gap: 4px; }
  }
</style>

<script is:inline>
  function filterCards(topic, btn) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    document.querySelectorAll('.topic-section').forEach(section => {
      const sectionTopic = section.getAttribute('data-section');
      if (topic === 'all' || topic === sectionTopic) {
        section.style.display = '';
      } else {
        section.style.display = 'none';
      }
    });
  }
</script>
</Layout>
