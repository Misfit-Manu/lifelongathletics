    desc: 'Tight junctions are sealed. Intestinal cells are connected by claudins, occludin, and other proteins. Only nutrients pass through. Bad stuff stays out.',
    details: [
      'Tight junctions are CLOSED, only letting nutrients through',
      'Zonulin levels are low (no gap-opening signal)',
      'Intestinal lining is strong and intact'
    ],
    damageFactors: [],
    integrity: 100, zonulin: 5, permeability: 0, inflammation: 10,
    visual: '🔒🔒🔒', color: 'good'
  },
  {
    name: 'Beginning Stress: Junctions Start Opening',
    desc: 'Stress, poor diet, or inflammatory foods trigger zonulin release. Gaps begin to appear between intestinal cells.',
    details: [
      'Zonulin rises in response to stress or gluten',
      'Gaps begin opening between tight junctions',
      'First bacterial endotoxins start leaking through'
    ],
    damageFactors: [
      'Chronic stress (high cortisol)',
      'Gluten (in sensitive individuals)',
      'High-sugar diet',
      'Lack of sleep',
      'Excess exercise without recovery'
    ],
    integrity: 70, zonulin: 35, permeability: 20, inflammation: 30,
    visual: '🔒🔓🔒', color: 'warning'
  },
  {
    name: 'Moderate Damage: Barrier Compromised',
    desc: 'Multiple holes now exist in the intestinal lining. Larger molecules, bacteria, and bacterial byproducts start crossing into bloodstream.',
    details: [
      'Zonulin stays elevated (ongoing trigger)',
      'LPS (bacterial endotoxin) enters bloodstream',
      'Immune system recognizes "invaders" and inflames'
    ],
    damageFactors: [
      'Chronic gluten consumption',
      'NSAIDs (ibuprofen, naproxen)',
      'Excessive alcohol',
      'Processed foods & additives',
      'Dysbiosis (bad gut bacteria overgrowth)',
      'Constant stress',
      'Nutrient deficiencies (zinc, L-glutamine)'
    ],
    integrity: 40, zonulin: 65, permeability: 60, inflammation: 70,
    visual: '🔓🔓🔓', color: 'danger'
  },
  {
    name: 'Leaky Gut Syndrome',
    desc: 'Severe intestinal permeability. Large gaps allow undigested food particles, bacterial lipopolysaccharides (LPS), and toxins to enter bloodstream freely.',
    details: [
      'Gut bacteria and LPS trigger systemic inflammation',
      'Immune system attacks "invaders" 24/7',
      'Can lead to food sensitivities, autoimmune, chronic fatigue'
    ],
    damageFactors: [
      'All factors from moderate damage (continued)',
      'Multiple food sensitivities developing',
      'Autoimmune response (IgG antibodies to food)',
      'Severe dysbiosis',
      'Intestinal cell damage (enterocytes dying)',
      'Nutritional malabsorption',
      'Systemic inflammation (low-grade endotoxemia)'
    ],
    integrity: 15, zonulin: 90, permeability: 95, inflammation: 95,
    visual: '💨💨💨', color: 'danger'
  },
  {
    name: 'Healing Phase: Barrier Repair',
    desc: 'Triggers removed. Zonulin drops. Tight junctions reseal. Intestinal cells regenerate. Healing takes 4-8 weeks with proper nutrition.',
    details: [
      'Remove triggers (gluten, NSAIDs, stress)',
      'Restore with L-glutamine, zinc, bone broth',
      'Rebuild microbiome with fermented foods & fiber',
      'Tight junctions gradually reseal'
    ],
    damageFactors: [],
    integrity: 70, zonulin: 15, permeability: 30, inflammation: 25,
    visual: '🔒🔐🔒', color: 'good'
  }
];

function gbtUpdateTimeline(value) {
  const normalized = value / 100;
  let idx = Math.min(Math.floor(normalized * gbtPhases.length), gbtPhases.length - 1);
  const phase = gbtPhases[idx];

  document.getElementById('timeDisplay').textContent = phase.name;
  document.getElementById('barrierVisual').textContent = phase.visual;
  gbtUpdateMetrics(phase);
  gbtUpdatePhaseInfo(phase);

  const damageBox = document.getElementById('damageFactors');
  if (phase.damageFactors.length > 0) {
    damageBox.classList.add('show');
    document.getElementById('damageList').innerHTML = phase.damageFactors.map(f =>
      `<div class="damage-item">${f}</div>`
    ).join('');
  } else {
    damageBox.classList.remove('show');
  }

  document.querySelectorAll('.phase-marker').forEach((m, i) => {
    m.classList.toggle('active', i === idx);
  });
}

function gbtUpdateMetrics(phase) {
  document.getElementById('integrity').style.width = phase.integrity + '%';
  document.getElementById('integrityValue').textContent = phase.integrity + '%';
  document.getElementById('integrity').className = 'metric-fill ' + (phase.integrity > 60 ? 'good' : phase.integrity > 30 ? 'warning' : 'danger');

  document.getElementById('zonulin').style.width = phase.zonulin + '%';
  document.getElementById('zonulinValue').textContent = phase.zonulin < 20 ? 'Low' : phase.zonulin < 50 ? 'Elevated' : 'Very High';
  document.getElementById('zonulin').className = 'metric-fill ' + (phase.zonulin < 20 ? 'good' : phase.zonulin < 50 ? 'warning' : 'danger');

  document.getElementById('permeability').style.width = phase.permeability + '%';
  document.getElementById('permeabilityValue').textContent = phase.permeability + '%';
  document.getElementById('permeability').className = 'metric-fill ' + (phase.permeability < 30 ? 'good' : phase.permeability < 60 ? 'warning' : 'danger');

  document.getElementById('inflammation').style.width = phase.inflammation + '%';
  document.getElementById('inflammationValue').textContent = phase.inflammation < 30 ? 'Low' : phase.inflammation < 60 ? 'Moderate' : 'High';
  document.getElementById('inflammation').className = 'metric-fill ' + (phase.inflammation < 30 ? 'good' : phase.inflammation < 60 ? 'warning' : 'danger');
}

function gbtUpdatePhaseInfo(phase) {
  document.getElementById('phaseName').textContent = phase.name;
  document.getElementById('phaseDesc').textContent = phase.desc;
  document.querySelector('.phase-details').innerHTML = phase.details.map((d, i) =>
    `<div class="detail-item" id="detail${i}">${d}</div>`
  ).join('');
}

function gbtSetPhase(value) {
  document.getElementById('timeSlider').value = value;
  gbtUpdateTimeline(value);
}

function gbtPlay() {
  let value = parseInt(document.getElementById('timeSlider').value);
  const interval = setInterval(() => {
    value += 2;
    if (value > 100) { clearInterval(interval); return; }
    document.getElementById('timeSlider').value = value;
    gbtUpdateTimeline(value);
  }, 150);
}

gbtUpdateTimeline(0);
</script>

</Layout>
