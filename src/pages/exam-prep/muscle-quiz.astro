// ═══════════════ STATE ═══════════════
let mcqAnswers = new Array(25).fill(null);
let tfAnswers  = new Array(10).fill(null);
let openAnswers= new Array(8).fill('');
let score = 0;
let answered = 0;
let mcqScore = 0;
let tfScore  = 0;

// ═══════════════ BUILD UI ═══════════════
function buildMCQ() {
  const container = document.getElementById('mq-mcq-section');
  mcqData.forEach((q, i) => {
    const card = document.createElement('div');
    card.className = 'mq-q-card';
    card.style.animationDelay = (i * 0.03) + 's';
    card.id = `mcq-${i}`;

    const opts = q.opts.map((o, j) => `
      <div class="mq-option" id="mcq-opt-${i}-${j}" onclick="selectMCQ(${i},${j})">
        <div class="mq-opt-letter">${['A','B','C','D'][j]}</div>
        <span>${o}</span>
        <span class="mq-opt-icon" id="mcq-icon-${i}-${j}"></span>
      </div>
    `).join('');

    card.innerHTML = `
      <div class="mq-q-number">
        Q${i+1} &nbsp; <span class="mq-q-category">${q.cat}</span>
      </div>
      <div class="mq-q-text">${q.q}</div>
      <div class="mq-options" id="opts-${i}">${opts}</div>
      <div class="mq-feedback" id="fb-${i}"></div>
    `;
    container.appendChild(card);
  });
}

function buildTF() {
  const container = document.getElementById('mq-tf-section');
  tfData.forEach((q, i) => {
    const card = document.createElement('div');
    card.className = 'mq-q-card';
    card.id = `tf-${i}`;
    card.style.animationDelay = (i * 0.03) + 's';

    card.innerHTML = `
      <div class="mq-q-number">
        Q${i+26} &nbsp; <span class="mq-q-category">${q.cat}</span>
      </div>
      <div class="mq-q-text">${q.q}</div>
      <div class="mq-tf-options">
        <button class="mq-tf-btn mq-true-btn" id="tf-T-${i}" onclick="selectTF(${i}, true)">✓ TRUE</button>
        <button class="mq-tf-btn mq-false-btn" id="tf-F-${i}" onclick="selectTF(${i}, false)">✗ FALSE</button>
      </div>
      <div class="mq-feedback" id="tf-fb-${i}"></div>
    `;
    container.appendChild(card);
  });
}

function buildOpen() {
  const container = document.getElementById('mq-open-section');
  openData.forEach((q, i) => {
    const card = document.createElement('div');
    card.className = 'mq-q-card';
    card.id = `open-${i}`;
    card.style.animationDelay = (i * 0.03) + 's';

    card.innerHTML = `
      <div class="mq-q-number">
        Q${i+36} &nbsp; <span class="mq-q-category">${q.cat}</span>
      </div>
      <div class="mq-q-text">${q.q}</div>
      <textarea class="mq-open-area" id="open-area-${i}" placeholder="Write your answer here..." oninput="saveOpen(${i})"></textarea>
      <br>
      <button class="mq-reveal-btn" id="reveal-${i}" onclick="revealModel(${i})">REVEAL MODEL ANSWER</button>
      <div class="mq-model-answer" id="model-${i}">
        <strong>📖 Model Answer</strong>
        ${q.model}
      </div>
    `;
    container.appendChild(card);
  });
}

// ═══════════════ INTERACTIONS ═══════════════
function selectMCQ(qi, opt) {
  if (mcqAnswers[qi] !== null) return; // already answered
  mcqAnswers[qi] = opt;
  answered++;

  const correct = mcqData[qi].ans;
  const opts = document.querySelectorAll(`[id^="mcq-opt-${qi}-"]`);
  opts.forEach((el, j) => {
    el.classList.add('mq-locked');
    if (j === correct) {
      el.classList.add('mq-correct');
      document.getElementById(`mcq-icon-${qi}-${j}`).textContent = '✓';
    } else if (j === opt && opt !== correct) {
      el.classList.add('mq-wrong');
      document.getElementById(`mcq-icon-${qi}-${j}`).textContent = '✗';
    }
  });

  const fb = document.getElementById(`fb-${qi}`);
  if (opt === correct) {
    mcqScore++;
    score++;
    fb.className = 'feedback correct-fb';
    fb.textContent = '✓ Correct! ' + mcqData[qi].exp;
  } else {
    fb.className = 'feedback wrong-fb';
    fb.textContent = '✗ Incorrect. ' + mcqData[qi].exp;
  }

  updateProgress();
}

function selectTF(qi, val) {
  if (tfAnswers[qi] !== null) return;
  tfAnswers[qi] = val;
  answered++;

  const correct = tfData[qi].ans;
  const tBtn = document.getElementById(`tf-T-${qi}`);
  const fBtn = document.getElementById(`tf-F-${qi}`);
  tBtn.classList.add('mq-locked');
  fBtn.classList.add('mq-locked');

  const isCorrect = val === correct;

  if (isCorrect) {
    tfScore++;
    score++;
    (val ? tBtn : fBtn).classList.add('mq-correct');
  } else {
    (val ? tBtn : fBtn).classList.add('mq-wrong');
    (correct ? tBtn : fBtn).classList.add('mq-show-correct');
  }

  const fb = document.getElementById(`tf-fb-${qi}`);
  fb.className = isCorrect ? 'feedback correct-fb' : 'feedback wrong-fb';
  fb.textContent = (isCorrect ? '✓ ' : '✗ ') + tfData[qi].exp;

  updateProgress();
}

function saveOpen(i) {
  openAnswers[i] = document.getElementById(`open-area-${i}`).value;
}

function revealModel(i) {
  const model = document.getElementById(`model-${i}`);
  model.classList.add('mq-shown');
  const btn = document.getElementById(`reveal-${i}`);
  btn.textContent = '✓ MODEL ANSWER SHOWN';
  btn.disabled = true;
  document.getElementById(`open-area-${i}`).classList.add('mq-submitted');
}

function updateProgress() {
  const pct = (answered / 35) * 100;
  document.getElementById('mq-progress-bar').style.width = Math.min(pct,100) + '%';
  document.getElementById('mq-live-score').textContent = score;
  document.getElementById('mq-q-current').textContent = Math.min(answered + 1, 43);
}

// ═══════════════ SUBMIT ═══════════════
function submitQuiz() {
  // Auto-answer any unselected
  mcqData.forEach((q, i) => {
    if (mcqAnswers[i] === null) {
      const opts = document.querySelectorAll(`[id^="mcq-opt-${i}-"]`);
      opts.forEach(el => el.classList.add('mq-locked'));
      document.getElementById(`mcq-opt-${i}-${q.ans}`).classList.add('mq-show-correct');
    }
  });
  tfData.forEach((q, i) => {
    if (tfAnswers[i] === null) {
      document.getElementById(`tf-T-${i}`).classList.add('mq-locked');
      document.getElementById(`tf-F-${i}`).classList.add('mq-locked');
      (q.ans ? document.getElementById(`tf-T-${i}`) : document.getElementById(`tf-F-${i}`)).classList.add('mq-show-correct');
    }
  });

  showResults();
}

// ═══════════════ RESULTS ═══════════════
function showResults() {
  document.getElementById('mq-quiz').style.display = 'none';
  document.getElementById('mq-results').style.display = 'block';
  window.scrollTo({top:0, behavior:'smooth'});

  const total = 35; // MCQ + TF only (open ended not scored)
  const pct = Math.round((score / total) * 100);

  let grade, msg, color;
  if (pct >= 90) { grade='A+'; msg='Outstanding! You clearly understand muscle physiology deeply.'; color='var(--mq-green)'; }
  else if (pct >= 80) { grade='A'; msg='Excellent work. Strong grasp of the material.'; color='var(--mq-green)'; }
  else if (pct >= 70) { grade='B'; msg='Good performance. Review the missed questions to solidify.'; color='var(--mq-accent2)'; }
  else if (pct >= 60) { grade='C'; msg='Decent effort. Some key concepts need reinforcing.'; color='var(--mq-gold)'; }
  else { grade='D'; msg='Keep studying — revisit the visual guide and retry.'; color='var(--mq-accent)'; }

  document.getElementById('mq-grade-letter').textContent = grade;
  document.getElementById('mq-grade-letter').style.color = color;
  document.getElementById('mq-score-text').textContent = `${score} / ${total} CORRECT (${pct}%)`;
  document.getElementById('mq-result-message').textContent = msg;
  document.getElementById('mq-mcq-score').textContent = `${mcqScore}/25`;
  document.getElementById('mq-tf-score').textContent = `${tfScore}/10`;

  // Build review
  const reviewList = document.getElementById('mq-review-list');
  reviewList.innerHTML = '';

  mcqData.forEach((q, i) => {
    if (mcqAnswers[i] === null) return;
    const isRight = mcqAnswers[i] === q.ans;
    const div = document.createElement('div');
    div.className = `review-item ${isRight ? 'mq-r-correct' : 'mq-r-wrong'}`;
    div.innerHTML = `
      <div class="mq-review-q">${isRight ? '✓' : '✗'} Q${i+1}: ${q.q.replace(/<[^>]+>/g,'')}</div>
      <div class="mq-review-your ${isRight ? 'mq-rv-correct' : 'mq-rv-wrong'}">
        Your answer: ${q.opts[mcqAnswers[i]]}
        ${!isRight ? ` | Correct: ${q.opts[q.ans]}` : ''}
      </div>
    `;
    reviewList.appendChild(div);
  });

  tfData.forEach((q, i) => {
    if (tfAnswers[i] === null) return;
    const isRight = tfAnswers[i] === q.ans;
    const div = document.createElement('div');
    div.className = `review-item ${isRight ? 'mq-r-correct' : 'mq-r-wrong'}`;
    div.innerHTML = `
      <div class="mq-review-q">${isRight ? '✓' : '✗'} Q${i+26}: ${q.q.replace(/<[^>]+>/g,'')}</div>
      <div class="mq-review-your ${isRight ? 'mq-rv-correct' : 'mq-rv-wrong'}">
        Your answer: ${tfAnswers[i] ? 'TRUE' : 'FALSE'}
        ${!isRight ? ` | Correct: ${q.ans ? 'TRUE' : 'FALSE'}` : ''}
      </div>
    `;
    reviewList.appendChild(div);
  });
}

// ═══════════════ NAVIGATION ═══════════════
function startQuiz() {
  document.getElementById('mq-cover').style.display = 'none';
  document.getElementById('mq-quiz').style.display = 'block';
  window.scrollTo({top:0, behavior:'smooth'});
}

function retryQuiz() {
  mcqAnswers = new Array(25).fill(null);
  tfAnswers  = new Array(10).fill(null);
  openAnswers= new Array(8).fill('');
  score = 0; answered = 0; mcqScore = 0; tfScore = 0;

  document.getElementById('mq-mcq-section').innerHTML = '';
  document.getElementById('mq-tf-section').innerHTML = '';
  document.getElementById('mq-open-section').innerHTML = '';

  buildMCQ(); buildTF(); buildOpen();
  updateProgress();

  document.getElementById('mq-results').style.display = 'none';
  document.getElementById('mq-quiz').style.display = 'block';
  window.scrollTo({top:0, behavior:'smooth'});
}

// ═══════════════ INIT ═══════════════
buildMCQ();
buildTF();
buildOpen();

</script>

</Layout>
