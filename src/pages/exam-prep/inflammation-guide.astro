---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Types of Inflammation — Visual Guide | Lifelong Athletics"
  description="The 8 types of inflammation, how each works, and what to do about them. From acute trauma response to chronic metabolic damage — the complete reference."
>

<div class="infl-back-bar">
  <a href="/exam-prep" class="infl-back-link">← Back to Study Hub</a>
</div>

<style is:global>

  .infl-back-bar { max-width: 1100px; margin: 0 auto; padding: 110px 60px 0; }
  .infl-back-link {
    font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; display: inline-flex;
    align-items: center; gap: 8px; transition: color 0.2s;
  }
  .infl-back-link:hover { color: var(--gold); }

  .infl-hub {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: linear-gradient(180deg, #0a0a0a 0%, #151515 50%, #0a0a0a 100%);
    color: #e0e0e0;
    min-height: 100vh;
    padding: 3rem 2rem;
  }

  .infl-container { max-width: 1400px; margin: 0 auto; }

  /* HEADER */
  .infl-hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .infl-hero h1 {
    font-size: 48px;
    font-weight: 700;
    background: linear-gradient(135deg, #ffd700, #ffed4e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }

  .infl-hero p {
    font-size: 16px;
    color: #999;
    max-width: 700px;
    margin: 0 auto;
  }

  /* BASIC INFLAMMATION VISUAL */
  .infl-mechanism-section {
    background: rgba(255, 215, 0, 0.05);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 12px;
    padding: 2rem;
    margin-bottom: 3rem;
  }

  .infl-mechanism-title {
    font-size: 22px;
    color: #ffd700;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .infl-mechanism-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .infl-mechanism-step {
    text-align: center;
    position: relative;
  }

  .infl-step-circle {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ffd700, #ffed4e);
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    font-weight: 700;
    color: #000;
    box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
  }

  .infl-step-arrow {
    position: absolute;
    right: -25px;
    top: 30px;
    font-size: 24px;
    color: #ffd700;
    animation: infl-bounce 2s infinite;
  }

  .infl-mechanism-step:last-child .infl-step-arrow { display: none; }

  @keyframes infl-bounce {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(6px); }
  }

  .infl-step-label {
    font-size: 12px;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .infl-step-text {
    font-size: 13px;
    color: #ddd;
    line-height: 1.5;
  }

  /* INFLAMMATION TYPES GRID */
  .infl-types-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .infl-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1.5px solid;
    border-radius: 12px;
    padding: 0;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    position: relative;
  }

  .infl-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  /* Color coding */
  .infl-card-trauma    { border-color: #51cf66; background: linear-gradient(135deg, rgba(81, 207, 102, 0.08) 0%, rgba(81, 207, 102, 0.02) 100%); }
  .infl-card-metabolic { border-color: #ff922b; background: linear-gradient(135deg, rgba(255, 146, 43, 0.08) 0%, rgba(255, 146, 43, 0.02) 100%); }
  .infl-card-leaky     { border-color: #ff6b6b; background: linear-gradient(135deg, rgba(255, 107, 107, 0.08) 0%, rgba(255, 107, 107, 0.02) 100%); }
  .infl-card-autoimmune{ border-color: #a78bfa; background: linear-gradient(135deg, rgba(167, 139, 250, 0.08) 0%, rgba(167, 139, 250, 0.02) 100%); }
  .infl-card-allergic  { border-color: #06b6d4; background: linear-gradient(135deg, rgba(6, 182, 212, 0.08) 0%, rgba(6, 182, 212, 0.02) 100%); }
  .infl-card-infectious{ border-color: #f87171; background: linear-gradient(135deg, rgba(248, 113, 113, 0.08) 0%, rgba(248, 113, 113, 0.02) 100%); }
  .infl-card-neuro     { border-color: #fbbf24; background: linear-gradient(135deg, rgba(251, 191, 36, 0.08) 0%, rgba(251, 191, 36, 0.02) 100%); }
  .infl-card-intestinal{ border-color: #34d399; background: linear-gradient(135deg, rgba(52, 211, 153, 0.08) 0%, rgba(52, 211, 153, 0.02) 100%); }

  .infl-card-header {
    padding: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .infl-card-icon {
    font-size: 36px;
    margin-bottom: 0.75rem;
    display: block;
  }

  .infl-card-title {
    font-size: 16px;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .infl-card-type {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0;
  }

  .infl-card-trauma .infl-card-type    { color: #51cf66; }
  .infl-card-metabolic .infl-card-type { color: #ff922b; }
  .infl-card-leaky .infl-card-type     { color: #ff6b6b; }
  .infl-card-autoimmune .infl-card-type{ color: #a78bfa; }
  .infl-card-allergic .infl-card-type  { color: #06b6d4; }
  .infl-card-infectious .infl-card-type{ color: #f87171; }
  .infl-card-neuro .infl-card-type     { color: #fbbf24; }
  .infl-card-intestinal .infl-card-type{ color: #34d399; }

  .infl-card-body { padding: 1.5rem; }

  .infl-metric-row {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .infl-metric-row:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .infl-metric-label {
    font-size: 10px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .infl-metric-value {
    font-size: 14px;
    font-weight: 600;
    color: #fff;
  }

  .infl-duration-bar {
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    overflow: hidden;
    margin-top: 0.5rem;
  }

  .infl-duration-fill { height: 100%; border-radius: 2px; }

  .infl-card-trauma .infl-duration-fill    { background: #51cf66; }
  .infl-card-metabolic .infl-duration-fill { background: #ff922b; }
  .infl-card-leaky .infl-duration-fill     { background: #ff6b6b; }
  .infl-card-autoimmune .infl-duration-fill{ background: #a78bfa; }
  .infl-card-allergic .infl-duration-fill  { background: #06b6d4; }
  .infl-card-infectious .infl-duration-fill{ background: #f87171; }
  .infl-card-neuro .infl-duration-fill     { background: #fbbf24; }
  .infl-card-intestinal .infl-duration-fill{ background: #34d399; }

  /* DETAILED BREAKDOWN SECTION */
  .infl-breakdown-section { margin: 3rem 0; }

  .infl-breakdown-title {
    font-size: 24px;
    color: #ffd700;
    font-weight: 600;
    margin-bottom: 2rem;
    text-align: center;
  }

  .infl-breakdown-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .infl-breakdown-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .infl-breakdown-card:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 215, 0, 0.4);
  }

  .infl-breakdown-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid rgba(255, 215, 0, 0.2);
  }

  .infl-breakdown-icon { font-size: 32px; }

  .infl-breakdown-name {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
  }

  .infl-breakdown-content { display: grid; gap: 1rem; }

  .infl-info-block {
    background: rgba(255, 215, 0, 0.05);
    padding: 1rem;
    border-radius: 6px;
    border-left: 3px solid #ffd700;
  }

  .infl-info-label {
    font-size: 11px;
    color: #ffd700;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .infl-info-text {
    font-size: 13px;
    color: #ddd;
    line-height: 1.6;
  }

  .infl-list-item {
    font-size: 13px;
    color: #bbb;
    margin-bottom: 0.75rem;
    padding-left: 1.25rem;
    position: relative;
  }

  .infl-list-item:before {
    content: '→';
    position: absolute;
    left: 0;
    color: #ffd700;
    font-weight: 600;
  }

  /* TIMELINE VISUALIZATION */
  .infl-timeline-section {
    background: rgba(255, 215, 0, 0.05);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 12px;
    padding: 2rem;
    margin: 3rem 0;
  }

  .infl-timeline-title {
    font-size: 20px;
    color: #ffd700;
    font-weight: 600;
    margin-bottom: 2rem;
    text-align: center;
  }

  .infl-timeline-comparison {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .infl-timeline-track {
    position: relative;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 8px;
    padding: 1.5rem;
  }

  .infl-timeline-label {
    font-size: 13px;
    font-weight: 600;
    color: #ffd700;
    margin-bottom: 1rem;
  }

  .infl-timeline-line {
    height: 6px;
    background: linear-gradient(90deg, #51cf66 0%, transparent 100%);
    border-radius: 3px;
    margin-bottom: 1rem;
    position: relative;
  }

  .infl-timeline-line.infl-chronic {
    background: linear-gradient(90deg, #ff6b6b 0%, #ff6b6b 100%);
  }

  .infl-timeline-markers {
    font-size: 11px;
    color: #999;
    display: flex;
    justify-content: space-between;
  }

  .infl-timeline-desc {
    font-size: 12px;
    color: #bbb;
    margin-top: 1rem;
    line-height: 1.6;
  }

  /* COMPARISON TABLE */
  .infl-comparison-table {
    width: 100%;
    margin: 3rem 0;
    border-collapse: collapse;
    font-size: 13px;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid rgba(255, 215, 0, 0.2);
  }

  .infl-comparison-table th {
    background: linear-gradient(90deg, rgba(255, 215, 0, 0.1) 0%, rgba(255, 215, 0, 0.05) 100%);
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    color: #ffd700;
    border-bottom: 1px solid rgba(255, 215, 0, 0.2);
  }

  .infl-comparison-table td {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: #ddd;
  }

  .infl-comparison-table tr:hover { background: rgba(255, 215, 0, 0.05); }
  .infl-comparison-table tr:last-child td { border-bottom: none; }

  .infl-type-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .infl-badge-trauma     { background: rgba(81, 207, 102, 0.2); color: #51cf66; }
  .infl-badge-metabolic  { background: rgba(255, 146, 43, 0.2);  color: #ff922b; }
  .infl-badge-leaky      { background: rgba(255, 107, 107, 0.2); color: #ff6b6b; }
  .infl-badge-autoimmune { background: rgba(167, 139, 250, 0.2); color: #a78bfa; }
  .infl-badge-allergic   { background: rgba(6, 182, 212, 0.2);   color: #06b6d4; }
  .infl-badge-infectious { background: rgba(248, 113, 113, 0.2); color: #f87171; }
  .infl-badge-neuro      { background: rgba(251, 191, 36, 0.2);  color: #fbbf24; }
  .infl-badge-intestinal { background: rgba(52, 211, 153, 0.2);  color: #34d399; }

  /* PREVENTIONS & CURES */
  .infl-solutions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin: 3rem 0;
  }

  .infl-solutions-box {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 215, 0, 0.2);
    border-radius: 12px;
    padding: 2rem;
  }

  .infl-solutions-title {
    font-size: 18px;
    font-weight: 600;
    color: #ffd700;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .infl-solutions-list { display: grid; gap: 1rem; }

  .infl-solution-item {
    background: rgba(255, 215, 0, 0.05);
    padding: 1rem;
    border-radius: 6px;
    border-left: 3px solid #ffd700;
  }

  .infl-solution-title {
    font-size: 12px;
    font-weight: 600;
    color: #ffd700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
  }

  .infl-solution-text {
    font-size: 12px;
    color: #bbb;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .infl-back-bar { padding: 110px 24px 0; }
    .infl-types-grid { grid-template-columns: 1fr; }
    .infl-breakdown-grid { grid-template-columns: 1fr; }
    .infl-timeline-comparison { grid-template-columns: 1fr; }
    .infl-solutions-grid { grid-template-columns: 1fr; }
    .infl-mechanism-grid { grid-template-columns: repeat(2, 1fr); }
    .infl-hero h1 { font-size: 36px; }
    .infl-comparison-table { font-size: 11px; }
    .infl-comparison-table th, .infl-comparison-table td { padding: 0.6rem; }
  }
</style>

<div class="infl-hub">
  <div class="infl-container">

    <!-- HERO -->
    <div class="infl-hero">
      <h1>Understanding Inflammation</h1>
      <p>From acute immune response to chronic systemic damage — the complete visual guide</p>
    </div>

    <!-- BASIC MECHANISM -->
    <div class="infl-mechanism-section">
      <div class="infl-mechanism-title">How Inflammation Works: The 5-Step Cascade</div>
      <div class="infl-mechanism-grid">
        <div class="infl-mechanism-step">
          <div class="infl-step-circle">🚨</div>
          <div class="infl-step-label">Step 1</div>
          <div class="infl-step-text"><strong>Threat Detected</strong><br>Bacteria, toxin, injury</div>
          <div class="infl-step-arrow">→</div>
        </div>
        <div class="infl-mechanism-step">
          <div class="infl-step-circle">🔔</div>
          <div class="infl-step-label">Step 2</div>
          <div class="infl-step-text"><strong>Signal Released</strong><br>TNF-α, IL-6, IL-8</div>
          <div class="infl-step-arrow">→</div>
        </div>
        <div class="infl-mechanism-step">
          <div class="infl-step-circle">🚔</div>
          <div class="infl-step-label">Step 3</div>
          <div class="infl-step-text"><strong>Immune Arrives</strong><br>Neutrophils, macrophages</div>
          <div class="infl-step-arrow">→</div>
        </div>
        <div class="infl-mechanism-step">
          <div class="infl-step-circle">💥</div>
          <div class="infl-step-label">Step 4</div>
          <div class="infl-step-text"><strong>Inflammation Peaks</strong><br>Redness, swelling, pain</div>
          <div class="infl-step-arrow">→</div>
        </div>
        <div class="infl-mechanism-step">
          <div class="infl-step-circle">✅</div>
          <div class="infl-step-label">Step 5</div>
          <div class="infl-step-text"><strong>Resolution</strong><br>Heal or chronify</div>
        </div>
      </div>
    </div>

    <!-- 8 TYPES OF INFLAMMATION -->
    <div style="margin-bottom: 3rem;">
      <h2 style="font-size: 24px; color: #ffd700; text-align: center; margin-bottom: 2rem;">8 Types of Inflammation</h2>
      <div class="infl-types-grid">

        <!-- TRAUMA -->
        <div class="infl-card infl-card-trauma">
          <div class="infl-card-header">
            <span class="infl-card-icon">⚡</span>
            <div class="infl-card-title">Trauma Inflammation</div>
            <p class="infl-card-type">Acute (Good)</p>
          </div>
          <div class="infl-card-body">
            <div class="infl-metric-row">
              <div class="infl-metric-label">Duration</div>
              <div class="infl-metric-value">7-14 days</div>
              <div class="infl-duration-bar"><div class="infl-duration-fill" style="width: 15%;"></div></div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Trigger</div>
              <div class="infl-metric-value">Injury, surgery</div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Feeling</div>
              <div class="infl-metric-value">Sharp pain, swelling</div>
            </div>
          </div>
        </div>

        <!-- METABOLIC -->
        <div class="infl-card infl-card-metabolic">
          <div class="infl-card-header">
            <span class="infl-card-icon">🍔</span>
            <div class="infl-card-title">Metabolic Inflammation</div>
            <p class="infl-card-type">Chronic (Bad)</p>
          </div>
          <div class="infl-card-body">
            <div class="infl-metric-row">
              <div class="infl-metric-label">Duration</div>
              <div class="infl-metric-value">Months–Years</div>
              <div class="infl-duration-bar"><div class="infl-duration-fill" style="width: 95%;"></div></div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Trigger</div>
              <div class="infl-metric-value">High sugar, calories</div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Feeling</div>
              <div class="infl-metric-value">Tired, joint aches</div>
            </div>
          </div>
        </div>

        <!-- LEAKY GUT -->
        <div class="infl-card infl-card-leaky">
          <div class="infl-card-header">
            <span class="infl-card-icon">💨</span>
            <div class="infl-card-title">Leaky Gut Inflammation</div>
            <p class="infl-card-type">Chronic (Severe)</p>
          </div>
          <div class="infl-card-body">
            <div class="infl-metric-row">
              <div class="infl-metric-label">Duration</div>
              <div class="infl-metric-value">Months–Years</div>
              <div class="infl-duration-bar"><div class="infl-duration-fill" style="width: 95%;"></div></div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Trigger</div>
              <div class="infl-metric-value">LPS endotoxemia</div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Feeling</div>
              <div class="infl-metric-value">Brain fog, fatigue</div>
            </div>
          </div>
        </div>

        <!-- AUTOIMMUNE -->
        <div class="infl-card infl-card-autoimmune">
          <div class="infl-card-header">
            <span class="infl-card-icon">🔫</span>
            <div class="infl-card-title">Autoimmune Inflammation</div>
            <p class="infl-card-type">Chronic (Severe)</p>
          </div>
          <div class="infl-card-body">
            <div class="infl-metric-row">
              <div class="infl-metric-label">Duration</div>
              <div class="infl-metric-value">Months–Years</div>
              <div class="infl-duration-bar"><div class="infl-duration-fill" style="width: 95%;"></div></div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Trigger</div>
              <div class="infl-metric-value">Immune attacks self</div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Feeling</div>
              <div class="infl-metric-value">Tissue-specific pain</div>
            </div>
          </div>
        </div>

        <!-- ALLERGIC -->
        <div class="infl-card infl-card-allergic">
          <div class="infl-card-header">
            <span class="infl-card-icon">🐚</span>
            <div class="infl-card-title">Allergic Inflammation</div>
            <p class="infl-card-type">Acute (Good)</p>
          </div>
          <div class="infl-card-body">
            <div class="infl-metric-row">
              <div class="infl-metric-label">Duration</div>
              <div class="infl-metric-value">Minutes–Hours</div>
              <div class="infl-duration-bar"><div class="infl-duration-fill" style="width: 5%;"></div></div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Trigger</div>
              <div class="infl-metric-value">Allergen exposure</div>
            </div>
            <div class="infl-metric-row">
              <div class="infl-metric-label">Feeling</div>
              <div class="infl-metric-value">Itching, hives, swelling</div>
            </div>
          </div>
        </div>

        <!-- INFECTIOUS -->
        <div class="infl-card infl-card-infectious">
          <div class="infl-card-header">
            <span class="infl-card-icon">🦠</span>
            <div class="infl-card-title">Infectious Inflammation</div>
            <p class="infl-card-type">Acute → Chronic</p>
          </div>
          <div class="infl-card-body">
            <div class="infl-metric-row">
              <div class="infl-metric-label">Duration</div>
              <div class="infl-metric-value">Days–Weeks</div>
              <div class="infl-duration-bar"><div class="infl-duration-fill" style="width: 25%;"></div></div>
