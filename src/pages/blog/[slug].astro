---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// This tells Astro to generate a route for every markdown file in the 'blog' folder
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} — Lifelong Athletics`} description={entry.data.description}>
  
  <div class="back-bar">
    <a href="/blog" class="back-link">← Back to Education</a>
  </div>

  <header class="article-header">
    <p class="article-category">{entry.data.category}</p>
    <h1 class="article-title" set:html={entry.data.title}></h1>
    <p class="article-subtitle">{entry.data.description}</p>
  </header>

  <article class="article-body">
    {/* This <Content /> tag magically parses all the markdown into HTML! */}
    <Content />
  </article>

<style>
  .back-bar { max-width: 780px; margin: 0 auto; padding: 110px 40px 0; }
  .back-link {
    font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--muted); text-decoration: none; display: inline-flex;
    align-items: center; gap: 8px; transition: color 0.2s;
  }
  .back-link:hover { color: var(--gold); }

  .article-header {
    max-width: 780px; margin: 0 auto; padding: 40px 40px 60px;
    border-bottom: 1px solid var(--border);
  }
  .article-category {
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 20px;
  }
  .article-title {
    font-family: var(--font-display); font-size: clamp(2.4rem, 5vw, 4.2rem);
    font-weight: 300; line-height: 1.1; margin-bottom: 24px; color: var(--white);
  }
  .article-subtitle {
    font-size: 1.1rem; color: var(--muted); line-height: 1.7;
    margin-bottom: 32px; font-style: italic; font-family: var(--font-display);
  }

  .article-body {
    max-width: 780px; margin: 0 auto; padding: 60px 40px 100px;
  }
  
  /* We use :global() because the Markdown HTML is injected at runtime */
  .article-body :global(p) {
    font-size: 1.05rem; color: rgba(245,240,232,0.85); line-height: 1.85; margin-bottom: 28px;
  }
  .article-body :global(h2) {
    font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 300; color: var(--white); margin: 64px 0 24px;
    padding-top: 40px; border-top: 1px solid var(--border); line-height: 1.2;
  }
  .article-body :global(h2 em) { font-style: italic; color: var(--gold); }
  .article-body :global(h3) {
    font-family: var(--font-display); font-size: 1.5rem; font-weight: 600;
    color: var(--white); margin: 40px 0 16px;
  }
  .article-body :global(strong) { font-weight: 600; color: var(--gold); }
  .article-body :global(ul) { margin-bottom: 28px; padding-left: 20px; }
  .article-body :global(li) { font-size: 1.05rem; color: rgba(245,240,232,0.85); line-height: 1.85; margin-bottom: 12px; }

  .article-body :global(.chart-box) {
    background: var(--surface2); border: 1px solid var(--border);
    border-top: 3px solid var(--gold); padding: 40px; margin: 48px 0;
    border-radius: 4px; text-align: center;
  }
  .article-body :global(.chart-title) {
    font-family: var(--font-display); font-size: 1.4rem; font-weight: 600;
    color: var(--white); margin-bottom: 8px;
  }
  .article-body :global(.chart-sub) { font-size: 0.85rem; color: var(--muted); margin-bottom: 32px; }
  
  .article-body :global(.callout) {
    background: var(--surface); border-left: 3px solid var(--gold);
    padding: 24px 32px; margin: 40px 0;
  }
  .article-body :global(.callout p) {
    margin: 0 !important; font-family: var(--font-display); font-size: 1.25rem;
    font-style: italic; color: var(--white) !important; line-height: 1.5;
  }
  .article-body :global(.takeaway) {
    background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.2);
    padding: 32px; margin: 40px 0; border-radius: 4px; border-left: 4px solid var(--gold);
  }
  .article-body :global(.takeaway-label) {
    font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 12px; display: block; font-weight: 700;
  }
  .article-body :global(.article-cta) {
    background: var(--surface); border: 1px solid var(--border);
    padding: 48px; margin-top: 80px; text-align: center; border-radius: 4px;
    background-image: linear-gradient(to bottom, rgba(201,168,76,0.03), transparent);
  }
  .article-body :global(.article-cta p) {
    font-family: var(--font-display); font-size: 1.8rem; font-style: italic;
    color: var(--white) !important; margin-bottom: 12px !important;
  }
  .article-body :global(.btn-gold) {
    display: inline-block; background: var(--gold); color: var(--black);
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.15em;
    text-transform: uppercase; padding: 16px 40px; border-radius: 2px;
    text-decoration: none; margin-top: 24px; transition: opacity 0.2s;
  }
  .article-body :global(.btn-gold:hover) { opacity: 0.9; }

  @media (max-width: 768px) {
    .article-header, .article-body { padding-left: 24px; padding-right: 24px; }
  }
</style>
</Layout>
