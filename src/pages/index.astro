        const clampedP = Math.min(1, p);
        const headPos = clampedP * totalSegs;
        const headIdx = Math.min(totalSegs - 1, Math.floor(headPos));
        const segProgress = headPos - headIdx;

        const segFrom = positions[path[headIdx]];
        const segTo   = positions[path[headIdx + 1]];
        const headX = segFrom.x + (segTo.x - segFrom.x) * segProgress;
        const headY = segFrom.y + (segTo.y - segFrom.y) * segProgress;

        // 3a. Trail — completed segments fade with distance from head
        ctx.lineCap = 'round';
        for (let i = 0; i < headIdx; i++) {
          const distFromHead = headIdx - i;
          const a = Math.max(0, 0.55 - distFromHead * 0.085) * overallFade;
          if (a < 0.01) continue;
          ctx.lineWidth = 1.7;
          ctx.strokeStyle = 'rgba(201, 168, 76, ' + a.toFixed(3) + ')';
          const f = positions[path[i]], t = positions[path[i + 1]];
          ctx.beginPath();
          ctx.moveTo(f.x, f.y);
          ctx.lineTo(t.x, t.y);
          ctx.stroke();
        }

        // 3b. Current segment — the brightest, with the pulse's leading edge
        if (p < 1) {
          ctx.strokeStyle = 'rgba(245, 214, 132, ' + (0.85 * overallFade).toFixed(3) + ')';
          ctx.lineWidth = 2.1;
          ctx.beginPath();
          ctx.moveTo(segFrom.x, segFrom.y);
          ctx.lineTo(headX, headY);
          ctx.stroke();

          // 3c. Glowing head — radial gradient halo
          const grd = ctx.createRadialGradient(headX, headY, 0, headX, headY, 16);
          grd.addColorStop(0,    'rgba(245, 214, 132, ' + (0.95 * overallFade).toFixed(3) + ')');
          grd.addColorStop(0.35, 'rgba(201, 168, 76, '  + (0.45 * overallFade).toFixed(3) + ')');
          grd.addColorStop(1,    'rgba(201, 168, 76, 0)');
          ctx.fillStyle = grd;
          ctx.beginPath();
          ctx.arc(headX, headY, 16, 0, Math.PI * 2);
          ctx.fill();
        } else {
          // 3d. Pulse has arrived at crown — final luminous flare
          const crown = positions[path[totalSegs]];
          const grd = ctx.createRadialGradient(crown.x, crown.y, 0, crown.x, crown.y, 26);
          grd.addColorStop(0,   'rgba(245, 214, 132, ' + (0.85 * overallFade).toFixed(3) + ')');
          grd.addColorStop(0.5, 'rgba(201, 168, 76, '  + (0.30 * overallFade).toFixed(3) + ')');
          grd.addColorStop(1,   'rgba(201, 168, 76, 0)');
          ctx.fillStyle = grd;
          ctx.beginPath();
          ctx.arc(crown.x, crown.y, 26, 0, Math.PI * 2);
          ctx.fill();
        }

        stillAlive.push(pulse);
      }
      pulses = stillAlive;

      // 4. Joint nodes — base dim, plus glow contribution from nearby pulses
      for (let i = 0; i < positions.length; i++) {
        const node = positions[i];
        let glow = 0;

        for (const pulse of pulses) {
          const elapsed = now - pulse.startTime;
          if (elapsed < 0) continue;
          const p = Math.min(1, elapsed / pulse.duration);
          const tailFade = (elapsed - pulse.duration) / 800;
          const overallFade = tailFade > 0 ? Math.max(0, 1 - tailFade) : 1;
          const path = PATHS[pulse.pathIdx];
          const idx = path.indexOf(i);
          if (idx === -1) continue;
          const totalSegs = path.length - 1;
          const nodeProgress = idx / totalSegs;
          const dist = Math.abs(p - nodeProgress);
          const closeness = Math.max(0, 1 - dist * (totalSegs + 1) * 0.55);
          glow = Math.max(glow, closeness * overallFade);
        }

        const baseAlpha = 0.20 + glow * 0.75;
        const r = 1.7 + glow * 3.2;
        ctx.fillStyle = 'rgba(201, 168, 76, ' + baseAlpha.toFixed(3) + ')';
        ctx.beginPath();
        ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
        ctx.fill();

        if (glow > 0.18) {
          ctx.fillStyle = 'rgba(245, 214, 132, ' + (glow * 0.75).toFixed(3) + ')';
          ctx.beginPath();
          ctx.arc(node.x, node.y, 0.9 + glow * 1.6, 0, Math.PI * 2);
          ctx.fill();
        }
      }
    }

