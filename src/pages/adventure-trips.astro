---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Get Outdoors — Adventure Trips by Lifelong Athletics" description="Adventure fitness in the wild. Offbeat treks, slow wilderness stays, and multi-day river expeditions.">

<section class="hero">
  <div class="hero-bg"></div>

  <!-- Mountain silhouette SVG -->
  <svg class="hero-mountains" viewBox="0 0 1440 280" fill="none" preserveAspectRatio="none">
    <path d="M0 280 L180 120 L320 200 L480 60 L640 180 L760 80 L900 160 L1060 40 L1200 140 L1360 90 L1440 160 L1440 280 Z" fill="rgba(42,61,46,0.6)"/>
    <path d="M0 280 L240 160 L400 220 L560 100 L720 200 L860 120 L1000 190 L1160 70 L1300 160 L1440 110 L1440 280 Z" fill="rgba(20,35,22,0.8)"/>
  </svg>

  <p class="initiative-tag">An initiative by Lifelong Athletics</p>
  <p class="brand-name">Get Outdoors</p>
  <h1>Move beyond<br/>the <em>gym.</em></h1>
  <p class="hero-sub">Adventure fitness in the wild. Offbeat treks, slow wilderness stays, and multi-day river expeditions — led by a certified mountaineer and licensed river guide.</p>
  <a href="#trips" class="hero-cta">Explore Trips</a>
  <p class="scroll-hint">↓ Scroll</p>
</section>

<!-- POSTCARDS -->
<section class="postcards-section" id="trips">
  <p class="section-eyebrow">What we do</p>
  <h2 class="section-title">Three ways to go <em>wild.</em></h2>

  <div class="postcards">

    <!-- POSTCARD 1 — Offbeat Trekking -->
    <div class="postcard postcard-trek">
      <div class="postcard-bg"></div>

      <!-- Illustration: mountains -->
      <div class="postcard-illustration">
        <svg viewBox="0 0 300 200" fill="none" width="100%" opacity="0.5">
          <path d="M20 180 L100 60 L150 110 L200 30 L280 180 Z" stroke="rgba(201,168,76,0.4)" stroke-width="1" fill="rgba(42,61,46,0.3)"/>
          <path d="M0 180 L80 90 L130 130 L180 50 L260 180 Z" stroke="rgba(201,168,76,0.2)" stroke-width="0.5" fill="rgba(30,50,35,0.2)"/>
          <line x1="200" y1="30" x2="200" y2="20" stroke="rgba(201,168,76,0.6)" stroke-width="1"/>
          <path d="M196 20 L200 14 L204 20 Z" fill="rgba(201,168,76,0.6)"/>
          <!-- Stars -->
          <circle cx="50" cy="30" r="1" fill="rgba(201,168,76,0.5)"/>
          <circle cx="130" cy="15" r="1.5" fill="rgba(201,168,76,0.6)"/>
          <circle cx="240" cy="25" r="1" fill="rgba(201,168,76,0.4)"/>
          <circle cx="270" cy="10" r="1" fill="rgba(201,168,76,0.3)"/>
        </svg>
      </div>

      <!-- Stamp -->
      <div class="postcard-stamp">
        <div class="stamp-icon">⛰</div>
        <div class="stamp-text">Trek</div>
      </div>

      <!-- Postmark -->
      <svg class="postcard-postmark" viewBox="0 0 60 60">
        <circle cx="30" cy="30" r="26" stroke="rgba(201,168,76,0.3)" stroke-width="1" fill="none"/>
        <circle cx="30" cy="30" r="20" stroke="rgba(201,168,76,0.2)" stroke-width="0.5" fill="none"/>
        <text x="30" y="27" text-anchor="middle" font-size="6" fill="rgba(201,168,76,0.5)" font-family="sans-serif" letter-spacing="1">GET OUTDOORS</text>
        <text x="30" y="36" text-anchor="middle" font-size="5" fill="rgba(201,168,76,0.4)" font-family="sans-serif">INDIA</text>
      </svg>

      <div class="postcard-content">
        <div class="postcard-number">01</div>
        <span class="postcard-label">Offbeat Trekking</span>
        <h3 class="postcard-name">Trails Less<br/>Travelled</h3>
        <p class="postcard-desc">Routes that don't make it to travel blogs. High-altitude passes, remote valleys, and hidden ridgelines — guided by someone who knows the mountain, not just the trail.</p>
        <div class="postcard-tags">
          <span class="ptag">Multi-day</span>
          <span class="ptag">High altitude</span>
          <span class="ptag">Small groups</span>
        </div>
      </div>
    </div>

    <!-- POSTCARD 2 — Slow Wild -->
    <div class="postcard postcard-wild" style="transition-delay:0.15s">
      <div class="postcard-bg"></div>

      <!-- Illustration: campfire / nature -->
      <div class="postcard-illustration">
        <svg viewBox="0 0 300 200" fill="none" width="100%" opacity="0.5">
          <!-- Trees -->
          <path d="M40 180 L40 120 M40 120 L20 145 L40 120 L60 145 M40 120 L25 135 L40 120 L55 135" stroke="rgba(139,90,43,0.5)" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M240 180 L240 100 M240 100 L215 130 L240 100 L265 130 M240 100 L220 118 L240 100 L260 118" stroke="rgba(139,90,43,0.5)" stroke-width="1.5" stroke-linecap="round"/>
          <!-- Stars -->
          <circle cx="80" cy="20" r="1.5" fill="rgba(201,168,76,0.6)"/>
          <circle cx="150" cy="10" r="1" fill="rgba(201,168,76,0.4)"/>
          <circle cx="220" cy="25" r="1.5" fill="rgba(201,168,76,0.5)"/>
          <!-- Moon -->
          <path d="M150 40 Q165 35 168 50 Q155 55 150 40" fill="rgba(201,168,76,0.3)" stroke="rgba(201,168,76,0.4)" stroke-width="0.5"/>
          <!-- Campfire -->
          <ellipse cx="150" cy="170" rx="18" ry="4" fill="rgba(139,90,43,0.3)"/>
          <path d="M142 165 Q146 150 150 145 Q154 150 158 165 Z" fill="rgba(201,168,76,0.35)"/>
          <path d="M145 165 Q149 155 150 150 Q151 155 155 165 Z" fill="rgba(201,100,30,0.3)"/>
          <!-- Ground line -->
          <line x1="0" y1="175" x2="300" y2="175" stroke="rgba(139,90,43,0.2)" stroke-width="0.5"/>
        </svg>
      </div>

      <div class="postcard-stamp">
        <div class="stamp-icon">🌿</div>
        <div class="stamp-text">Stay</div>
      </div>

      <svg class="postcard-postmark" viewBox="0 0 60 60">
        <circle cx="30" cy="30" r="26" stroke="rgba(201,168,76,0.3)" stroke-width="1" fill="none"/>
        <circle cx="30" cy="30" r="20" stroke="rgba(201,168,76,0.2)" stroke-width="0.5" fill="none"/>
        <text x="30" y="27" text-anchor="middle" font-size="6" fill="rgba(201,168,76,0.5)" font-family="sans-serif" letter-spacing="1">GET OUTDOORS</text>
        <text x="30" y="36" text-anchor="middle" font-size="5" fill="rgba(201,168,76,0.4)" font-family="sans-serif">INDIA</text>
      </svg>

      <div class="postcard-content">
        <div class="postcard-number">02</div>
        <span class="postcard-label">Slow Wild</span>
        <h3 class="postcard-name">Nature Stays &<br/>Village Life</h3>
        <p class="postcard-desc">Unplug. Slow down. Stay in remote mountain villages and forest camps — with campfires, starlit skies, and zero agenda. This is recovery, redefined.</p>
        <div class="postcard-tags">
          <span class="ptag">Immersive</span>
          <span class="ptag">Wellness-led</span>
          <span class="ptag">Off-grid</span>
        </div>
      </div>
    </div>

    <!-- POSTCARD 3 — River Expeditions -->
    <div class="postcard postcard-river" style="transition-delay:0.3s">
      <div class="postcard-bg"></div>

      <!-- Illustration: river waves -->
      <div class="postcard-illustration">
        <svg viewBox="0 0 300 200" fill="none" width="100%" opacity="0.5">
          <!-- River waves -->
          <path d="M0 120 Q30 105 60 120 Q90 135 120 120 Q150 105 180 120 Q210 135 240 120 Q270 105 300 120" stroke="rgba(30,100,160,0.6)" stroke-width="2" fill="none"/>
          <path d="M0 135 Q30 120 60 135 Q90 150 120 135 Q150 120 180 135 Q210 150 240 135 Q270 120 300 135" stroke="rgba(30,100,160,0.4)" stroke-width="1.5" fill="none"/>
          <path d="M0 150 Q30 135 60 150 Q90 165 120 150 Q150 135 180 150 Q210 165 240 150 Q270 135 300 150" stroke="rgba(30,100,160,0.25)" stroke-width="1" fill="none"/>
          <!-- Raft outline -->
          <rect x="110" y="98" width="80" height="20" rx="4" stroke="rgba(201,168,76,0.5)" stroke-width="1.5" fill="rgba(201,168,76,0.08)"/>
          <!-- Paddle figures -->
          <line x1="125" y1="108" x2="125" y2="88" stroke="rgba(201,168,76,0.4)" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="175" y1="108" x2="175" y2="88" stroke="rgba(201,168,76,0.4)" stroke-width="1.5" stroke-linecap="round"/>
          <!-- Canyon walls -->
          <path d="M0 0 L0 110 Q10 100 20 110 L20 0 Z" fill="rgba(20,40,60,0.5)"/>
          <path d="M300 0 L300 110 Q290 100 280 110 L280 0 Z" fill="rgba(20,40,60,0.5)"/>
          <!-- Stars -->
          <circle cx="150" cy="20" r="1.5" fill="rgba(201,168,76,0.5)"/>
          <circle cx="100" cy="35" r="1" fill="rgba(201,168,76,0.4)"/>
          <circle cx="200" cy="15" r="1" fill="rgba(201,168,76,0.3)"/>
        </svg>
      </div>

      <div class="postcard-stamp">
        <div class="stamp-icon">🌊</div>
        <div class="stamp-text">River</div>
      </div>

      <svg class="postcard-postmark" viewBox="0 0 60 60">
        <circle cx="30" cy="30" r="26" stroke="rgba(201,168,76,0.3)" stroke-width="1" fill="none"/>
        <circle cx="30" cy="30" r="20" stroke="rgba(201,168,76,0.2)" stroke-width="0.5" fill="none"/>
        <text x="30" y="27" text-anchor="middle" font-size="6" fill="rgba(201,168,76,0.5)" font-family="sans-serif" letter-spacing="1">GET OUTDOORS</text>
        <text x="30" y="36" text-anchor="middle" font-size="5" fill="rgba(201,168,76,0.4)" font-family="sans-serif">INDIA</text>
      </svg>

      <div class="postcard-content">
        <div class="postcard-number">03</div>
        <span class="postcard-label">River Expeditions</span>
        <h3 class="postcard-name">White Water<br/>Expeditions</h3>
        <p class="postcard-desc">Multi-day rafting expeditions through India's wildest rivers. Grade II to Grade V — led by a licensed river guide with a decade of whitewater experience.</p>
        <div class="postcard-tags">
          <span class="ptag">Multi-day</span>
          <span class="ptag">Grade II–V</span>
          <span class="ptag">Licensed guide</span>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- VIDEO SECTION -->
<div class="video-section">
  <div class="video-wrap">
    <div class="video-text">
      <p class="section-eyebrow">In the field</p>
      <h2>A decade in<br/>the <em>wild.</em></h2>
      <p>From high Himalayan passes to Himalayan river gorges — this is what a decade of guiding looks like. Watch the reel, then come join a trip.</p>
    </div>

    <!-- =====================================================
      VIDEO PLACEHOLDER
      To embed your YouTube video:
      1. Go to your YouTube video
      2. Click Share → Embed
      3. Copy the URL after "src=" (looks like: https://www.youtube.com/embed/XXXXXXXXXXX)
      4. Replace YOUR_YOUTUBE_VIDEO_ID below with your actual video ID
      ===================================================== -->
    <div class="video-placeholder" id="videoPlaceholder" onclick="loadVideo()">
      <svg style="position:absolute;inset:0;width:100%;height:100%;opacity:0.06" viewBox="0 0 800 450" preserveAspectRatio="xMidYMid slice">
        <rect width="800" height="450" fill="#1a2a1e"/>
        <path d="M0 450 L160 280 L300 360 L440 180 L580 300 L720 200 L800 250 L800 450 Z" fill="rgba(42,61,46,0.8)"/>
        <path d="M0 450 L200 320 L380 400 L520 220 L680 340 L800 280 L800 450 Z" fill="rgba(20,35,22,0.6)"/>
      </svg>
      <div class="video-overlay" id="videoOverlay">
        <div class="play-btn">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
            <path d="M8 5.5L17 11L8 16.5V5.5Z" fill="#080808"/>
          </svg>
        </div>
        <span class="video-label">Watch the adventure reel</span>
      </div>
      <!-- YouTube iframe loads on click -->
      <div id="iframeContainer" style="display:none;position:absolute;inset:0;z-index:3;"></div>
    </div>
  </div>
</div>

<!-- GUIDE SECTION -->
<div class="guide-section">
  <div class="guide-wrap">

    <div class="guide-left">
      <p class="section-eyebrow">Your guide</p>
      <h2>A decade in<br/>the <em>mountains</em><br/>and on the <em>river.</em></h2>
      <p>I didn't become a guide after a weekend course. This is ten years of leading real clients through real terrain — with the certifications, the experience, and the emergency training to back it up.</p>
      <p>Every trip I lead is safety-first, wilderness-first, and experience-first. No cutting corners on the mountain or the river.</p>
    </div>

    <div class="guide-right">
      <div class="stat-strip">
        <div class="stat-box">
          <div class="stat-num">10+</div>
          <div class="stat-desc">Years of active mountaineering and river guiding experience</div>
        </div>
        <div class="stat-box" style="transition-delay:0.1s">
          <div class="stat-num">100+</div>
          <div class="stat-desc">Clients safely guided through treks and expeditions</div>
        </div>
        <div class="stat-box" style="transition-delay:0.2s">
          <div class="stat-num">WFR</div>
          <div class="stat-desc">Wilderness First Responder certified — emergency ready in the field</div>
        </div>
      </div>

      <div class="credentials-list" style="margin-top:2px">
        <div class="cred">
          <div class="cred-dot-g"></div>
          <div class="cred-text">
            Certified Mountaineer
            <span>Indian Institute of Skiing & Mountaineering (IISM)</span>
          </div>
        </div>
        <div class="cred">
          <div class="cred-dot-g"></div>
          <div class="cred-text">
            Licensed River Rafting Guide & White Water Rafter
            <span>Certified for Grade II–V expeditions</span>
          </div>
        </div>
        <div class="cred">
          <div class="cred-dot-g"></div>
          <div class="cred-text">
            Wilderness First Responder (WFR)
            <span>Certified emergency response in remote terrain</span>
          </div>
        </div>
        <div class="cred">
          <div class="cred-dot-g"></div>
          <div class="cred-text">
            Adventure Fitness Coach
            <span>Integrating movement science with wilderness expeditions</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- CTA -->
<div class="cta-section">
  <h2>Ready to go <em>outdoors?</em></h2>
  <p>Spots on every trip are limited. Send a message and let's find the right expedition for you.</p>
  <div class="cta-buttons">
    <a href="https://wa.me/91XXXXXXXXXX" class="btn-gold">WhatsApp to Book →</a>
    <a href="/#apply" class="btn-ghost">Or apply for coaching first</a>
  </div>
</div>


<style>


  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 60px;
    background: rgba(8,8,8,0.97);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links { display: flex; align-items: center; gap: 28px; list-style: none; }
  .nav-links a {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-links a.active { color: var(--gold); }
  .nav-cta {
    color: var(--gold) !important;
    border: 1px solid var(--gold);
    padding: 10px 24px;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s !important;
  }
  .nav-cta:hover { background: var(--gold) !important; color: var(--black) !important; }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 120px 60px 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 50% 100%, rgba(42,61,46,0.4) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 30% 60%, rgba(201,168,76,0.04) 0%, transparent 60%);
  }
  /* Mountain silhouette */
  .hero-mountains {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 280px;
    opacity: 0.12;
  }
  .initiative-tag {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-weight: 300;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 40px;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.3s forwards;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 300;
    line-height: 0.95;
    margin-bottom: 20px;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.4s forwards;
  }
  .hero h1 em { font-style: italic; color: var(--gold); }
  .hero-sub {
    font-size: 1rem;
    color: var(--muted);
    max-width: 520px;
    margin-bottom: 52px;
    line-height: 1.8;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.6s forwards;
  }
  .hero-cta {
    display: inline-block;
    background: var(--gold);
    color: var(--black);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 16px 44px;
    border-radius: 2px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    opacity: 0;
    animation: fadeUp 0.9s ease 0.8s forwards;
  }
  .hero-cta:hover { opacity: 0.88; transform: translateY(-2px); }
  .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 1s ease 1.2s forwards;
  }

  /* POSTCARDS SECTION */
  .postcards-section {
    padding: 120px 60px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-eyebrow {
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
    text-align: center;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    text-align: center;
    margin-bottom: 72px;
    line-height: 1.15;
  }
  .section-title em { font-style: italic; color: var(--gold); }

  /* POSTCARD GRID */
  .postcards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .postcard {
    position: relative;
    border-radius: 3px;
    overflow: hidden;
    cursor: default;
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s ease, transform 0.8s ease;
    aspect-ratio: 3/4;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .postcard.visible { opacity: 1; transform: translateY(0); }

  /* Postcard illustrated backgrounds */
  .postcard-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Trek card — forest greens */
  .postcard-trek .postcard-bg {
    background: linear-gradient(160deg, #1a2a1e 0%, #0d1a10 40%, #080808 100%);
  }
  /* Slow Wild card — warm earthy */
  .postcard-wild .postcard-bg {
    background: linear-gradient(160deg, #2a1e0d 0%, #1a1208 40%, #080808 100%);
  }
  /* River card — deep blue */
  .postcard-river .postcard-bg {
    background: linear-gradient(160deg, #0d1a2a 0%, #081018 40%, #080808 100%);
  }

  /* Postcard illustration overlay */
  .postcard-illustration {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 32px 160px;
  }

  /* Postcard stamp (top right corner detail) */
  .postcard-stamp {
    position: absolute;
    top: 20px;
    right: 20px;
    z-index: 3;
    width: 52px;
    height: 64px;
    border: 1.5px solid rgba(201,168,76,0.4);
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    background: rgba(8,8,8,0.6);
  }
  .stamp-icon { font-size: 20px; line-height: 1; }
  .stamp-text {
    font-size: 7px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    text-align: center;
    line-height: 1.2;
  }

  /* Postmark circle */
  .postcard-postmark {
    position: absolute;
    top: 16px;
    left: 20px;
    z-index: 3;
    width: 60px;
    height: 60px;
  }

  /* Postcard content */
  .postcard-content {
    position: relative;
    z-index: 4;
    padding: 0 28px 32px;
  }
  .postcard-number {
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 300;
    color: rgba(201,168,76,0.15);
    line-height: 1;
    margin-bottom: -8px;
  }
  .postcard-label {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 10px;
    display: block;
  }
  .postcard-name {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 12px;
  }
  .postcard-desc {
    font-size: 0.82rem;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 20px;
  }
  .postcard-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .ptag {
    font-size: 0.6rem;
    letter-spacing: 0.1em;
