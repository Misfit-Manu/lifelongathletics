---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, '').split('/').pop();
---

<nav id="navbar">
  <a href="/" class="nav-logo">Lifelong <span>Athletics</span></a>
  
  <!-- Desktop Links -->
  <ul class="nav-links desktop-only">
    <li><a href="/#services">Services</a></li>
    <li><a href="/#longevity">Longevity</a></li>
    <li><a class={currentPath === "blog" ? "active" : ""} href="/blog">Education</a></li>
    <li><a class={currentPath === "exam-prep" ? "active" : ""} href="/exam-prep">Exam Prep</a></li>
    <li><a class={currentPath === "adventure-trips" ? "active" : ""} href="/adventure-trips">Adventure Trips</a></li>
    <li><a href="/#apply" class="nav-cta">Apply Now</a></li>
  </ul>
</nav>

<!-- App-Style Bottom Tab Bar (Mobile Only) -->
<div class="mobile-bottom-bar">
  <a href="/" class={`tab-item ${currentPath === "" ? "active" : ""}`}>
    <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
    <span>Home</span>
  </a>
  <a href="/blog" class={`tab-item ${currentPath === "blog" ? "active" : ""}`}>
    <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
    <span>Education</span>
  </a>
  <a href="/exam-prep" class={`tab-item ${currentPath === "exam-prep" ? "active" : ""}`}>
    <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path d="M6 12v5c3 3 9 3 12 0v-5"></path></svg>
    <span>Exams</span>
  </a>
  <a href="/adventure-trips" class={`tab-item ${currentPath === "adventure-trips" ? "active" : ""}`}>
    <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><polygon points="8 3 2 15 14 15"></polygon><polygon points="17 8 12 15 22 15"></polygon></svg>
    <span>Trips</span>
  </a>
</div>

<style>
  .mobile-bottom-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,0.05);
    z-index: 9998;
    padding-bottom: env(safe-area-inset-bottom);
  }
  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--muted);
    padding: 12px 0;
    width: 25%;
    transition: color 0.2s;
  }
  .tab-item svg {
    width: 24px;
    height: 24px;
    margin-bottom: 4px;
  }
  .tab-item span {
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .tab-item.active {
    color: var(--gold);
  }
  .tab-item.active svg {
    stroke: var(--gold);
    fill: rgba(201,168,76,0.1);
  }

  @media (max-width: 980px) {
    .desktop-only { display: none !important; }
    .mobile-bottom-bar { display: flex; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 60);
    });
  }
</script>
